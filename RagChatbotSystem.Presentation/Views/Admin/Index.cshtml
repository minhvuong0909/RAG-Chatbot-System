@{
    ViewData["Title"] = "Admin Dashboard";
    var users = ViewBag.Users as IReadOnlyList<RagChatbotSystem.Business.DTOs.UserDto> ?? new List<RagChatbotSystem.Business.DTOs.UserDto>();
    var teachers = ViewBag.Teachers as IReadOnlyList<RagChatbotSystem.Business.DTOs.UserDto> ?? new List<RagChatbotSystem.Business.DTOs.UserDto>();
    var datasets = ViewBag.Datasets as IReadOnlyList<RagChatbotSystem.Business.DTOs.DatasetDto> ?? new List<RagChatbotSystem.Business.DTOs.DatasetDto>();
    var unassignedDatasets = ViewBag.UnassignedDatasets as IReadOnlyList<RagChatbotSystem.Business.DTOs.DatasetDto> ?? new List<RagChatbotSystem.Business.DTOs.DatasetDto>();
    var assignments = ViewBag.Assignments as IReadOnlyList<RagChatbotSystem.Business.DTOs.TeacherSubjectAssignmentDto> ?? new List<RagChatbotSystem.Business.DTOs.TeacherSubjectAssignmentDto>();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: var(--ink); margin: 0; background: linear-gradient(135deg, #fff 30%, var(--accent-strong) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Admin Dashboard</h2>
            <p class="text-muted m-0 mt-1">Manage system users, approve subjects, and control permissions.</p>
        </div>
    </div>

    @if (TempData["AdminSuccess"] != null)
    {
        <div class="alert alert-success">@TempData["AdminSuccess"]</div>
    }
    @if (TempData["AdminError"] != null)
    {
        <div class="alert alert-danger">@TempData["AdminError"]</div>
    }
    @if (!string.IsNullOrWhiteSpace(TempData["ImportErrors"]?.ToString()))
    {
        <div class="alert alert-warning">@TempData["ImportErrors"]</div>
    }

    <div class="row g-4 mb-5">
        <div class="col-lg-4">
            <div class="card border-0 h-100" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important; box-shadow: var(--shadow);">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h4 class="fw-bold m-0" style="color: var(--ink);">Create Subject</h4>
                    <p class="text-muted small m-0 mt-1">Create a subject that teachers can manage after assignment.</p>
                </div>
                <div class="card-body px-4 pb-4">
                    <form asp-controller="Datasets" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <label class="form-label small fw-bold">SUBJECT NAME</label>
                        <input name="name" type="text" required class="form-control mb-3" placeholder="PRN222" />

                        <label class="form-label small fw-bold">DESCRIPTION</label>
                        <textarea name="description" rows="3" class="form-control mb-3" placeholder="Short subject description"></textarea>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" name="isPublic" id="isPublicSubject" value="true" />
                            <label class="form-check-label" for="isPublicSubject">Public for all approved users</label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-bold">Create Subject</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 h-100" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important; box-shadow: var(--shadow);">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h4 class="fw-bold m-0" style="color: var(--ink);">Import Students</h4>
                    <p class="text-muted small m-0 mt-1">Upload an XLSX file with an Email column. FullName is optional.</p>
                </div>
                <div class="card-body px-4 pb-4">
                    <form asp-action="ImportStudents" method="post" enctype="multipart/form-data" class="admin-processing-form" data-processing-title="Importing students..." data-processing-message="The system is reading the XLSX file, creating accounts, and sending login emails. Please keep this page open.">
                        @Html.AntiForgeryToken()
                        <input type="file" name="studentsFile" accept=".xlsx" required class="form-control mb-3" />
                        <button type="submit" class="btn btn-success w-100 fw-bold">Import and Email Accounts</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 h-100" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important; box-shadow: var(--shadow);">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h4 class="fw-bold m-0" style="color: var(--ink);">Create Teacher</h4>
                    <p class="text-muted small m-0 mt-1">Create a teacher account and assign one or more subjects.</p>
                </div>
                <div class="card-body px-4 pb-4">
                    <form asp-action="CreateTeacher" method="post" class="row g-3 admin-processing-form" data-processing-title="Creating teacher..." data-processing-message="The system is creating the teacher account, assigning subjects, and sending the login email.">
                        @Html.AntiForgeryToken()
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">FULL NAME</label>
                            <input name="fullName" required class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">EMAIL</label>
                            <input name="email" type="email" required class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">ASSIGNED SUBJECTS</label>
                            <select name="datasetIds" multiple required class="form-select" size="5">
                                @foreach (var ds in unassignedDatasets)
                                {
                                    <option value="@ds.DatasetId">@ds.Name</option>
                                }
                            </select>
                            <div class="text-muted small mt-1">A subject can only be assigned to one teacher.</div>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary w-100 fw-bold">Create Teacher and Send Email</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 mb-5" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important; box-shadow: var(--shadow);">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
            <h4 class="fw-bold m-0" style="color: var(--ink);">Teacher Subject Assignments</h4>
            <p class="text-muted small m-0 mt-1">Teachers can upload documents only to assigned subjects.</p>
        </div>
        <div class="card-body px-4 pb-4">
            <div class="row g-3 mb-4">
                <div class="col-12">
                    <form asp-action="AssignTeacher" method="post" class="row g-2 align-items-end">
                        @Html.AntiForgeryToken()
                        <div class="col-md-5">
                            <label class="form-label small fw-bold">TEACHER</label>
                            <select name="teacherId" required class="form-select">
                                @foreach (var teacher in teachers)
                                {
                                    <option value="@teacher.UserId">@teacher.FullName (@teacher.Email)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label small fw-bold">UNASSIGNED SUBJECT</label>
                            <select name="datasetId" required class="form-select">
                                @foreach (var ds in unassignedDatasets)
                                {
                                    <option value="@ds.DatasetId">@ds.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-outline-info w-100 fw-bold">Assign</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle" style="color: var(--ink);">
                    <thead>
                        <tr>
                            <th>Teacher</th>
                            <th>Subject</th>
                            <th>Assigned At</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!assignments.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-4">No teacher assignments yet.</td></tr>
                        }
                        @foreach (var item in assignments)
                        {
                            <tr>
                                <td>
                                    <strong>@item.TeacherName</strong>
                                    <div class="text-muted small">@item.TeacherEmail</div>
                                </td>
                                <td>@item.DatasetName</td>
                                <td>@item.AssignedAt.ToLocalTime().ToString("g")</td>
                                <td class="text-end">
                                    <form asp-action="UnassignTeacher" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="datasetId" value="@item.DatasetId" />
                                        <button type="submit" class="btn btn-danger btn-sm">Unassign</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Section: Datasets Management -->
    <div class="card border-0 mb-5" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important; box-shadow: var(--shadow); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
            <h4 class="fw-bold m-0" style="color: var(--ink);">Subject Approvals & Permissions</h4>
            <p class="text-muted small m-0 mt-1">Review subjects and manage target student permissions.</p>
        </div>
        <div class="card-body px-4 pb-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle" style="color: var(--ink);">
                    <thead>
                        <tr style="border-bottom: 2px solid var(--line); color: var(--muted); font-size: 0.85rem; text-transform: uppercase;">
                            <th class="py-3">Subject Name</th>
                            <th class="py-3">Description</th>
                            <th class="py-3">Type</th>
                            <th class="py-3">Status</th>
                            <th class="py-3 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!datasets.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">No subjects available in the system.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var ds in datasets)
                            {
                                <tr style="border-bottom: 1px solid var(--line); transition: background-color 0.2s;">
                                    <td class="py-3">
                                        <div class="fw-bold" style="color: var(--ink);">@ds.Name</div>
                                        <div class="text-muted small" style="font-size: 0.75rem;">ID: @ds.DatasetId</div>
                                    </td>
                                    <td class="py-3">@(string.IsNullOrEmpty(ds.Description) ? "No description" : ds.Description)</td>
                                    <td class="py-3">
                                        @if (ds.IsPublic)
                                        {
                                            <span class="status-pill">Public</span>
                                        }
                                        else
                                        {
                                            <span class="status-pill text-muted" style="background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1);">Private</span>
                                        }
                                    </td>
                                    <td class="py-3">
                                        @if (ds.IsApproved)
                                        {
                                            <span class="status-pill" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border-color: rgba(16, 185, 129, 0.2);">Approved</span>
                                        }
                                        else
                                        {
                                            <span class="status-pill processing">Pending Approval</span>
                                        }
                                    </td>
                                    <td class="py-3 text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a asp-action="Permissions" asp-route-id="@ds.DatasetId" class="btn btn-outline-secondary btn-sm" style="border-radius: 6px; border-color: rgba(255,255,255,0.15); color: var(--ink); font-weight: 600;">
                                                Manage Permissions
                                            </a>
                                            <form asp-action="ApproveDataset" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@ds.DatasetId" />
                                                @if (ds.IsApproved)
                                                {
                                                    <input type="hidden" name="approve" value="false" />
                                                    <button type="submit" class="btn btn-danger btn-sm text-white" style="border-radius: 6px; font-weight: 600;">
                                                        Unapprove
                                                    </button>
                                                }
                                                else
                                                {
                                                    <input type="hidden" name="approve" value="true" />
                                                    <button type="submit" class="btn btn-success btn-sm text-white" style="border-radius: 6px; font-weight: 600; background: #10b981; border: none; box-shadow: 0 0 10px rgba(16,185,129,0.3);">
                                                        Approve
                                                    </button>
                                                }
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Section: Users Management -->
    <div class="card border-0" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important; box-shadow: var(--shadow); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
            <h4 class="fw-bold m-0" style="color: var(--ink);">System Users</h4>
            <p class="text-muted small m-0 mt-1">View registered student and teacher profiles in the application.</p>
        </div>
        <div class="card-body px-4 pb-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle" style="color: var(--ink);">
                    <thead>
                        <tr style="border-bottom: 2px solid var(--line); color: var(--muted); font-size: 0.85rem; text-transform: uppercase;">
                            <th class="py-3">Full Name</th>
                            <th class="py-3">Email Address</th>
                            <th class="py-3">Role</th>
                            <th class="py-3">Created At</th>
                            <th class="py-3">Status</th>
                            <th class="py-3 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in users)
                        {
                            <tr style="border-bottom: 1px solid var(--line);">
                                <td class="py-3 fw-bold" style="color: var(--ink);">@user.FullName</td>
                                <td class="py-3 text-muted">@user.Email</td>
                                <td class="py-3">
                                    @if (user.Role == "Admin")
                                    {
                                        <span class="status-pill" style="background: rgba(239, 68, 68, 0.1); color: var(--danger); border-color: rgba(239, 68, 68, 0.2);">Admin</span>
                                    }
                                    else if (user.Role == "Teacher")
                                    {
                                        <span class="status-pill" style="background: rgba(217, 70, 239, 0.1); color: var(--accent); border-color: rgba(217, 70, 239, 0.25);">Teacher</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill">Student</span>
                                    }
                                </td>
                                <td class="py-3 text-muted">@user.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td class="py-3">
                                    @if (user.IsApproved)
                                    {
                                        <span class="status-pill" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border-color: rgba(16, 185, 129, 0.2);">Active</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill processing">Pending Approval</span>
                                    }
                                </td>
                                <td class="py-3 text-end">
                                    @if (user.Role == "Teacher")
                                    {
                                        <form asp-action="ApproveUser" method="post" class="m-0 d-inline-block">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.UserId" />
                                            @if (user.IsApproved)
                                            {
                                                <input type="hidden" name="approve" value="false" />
                                                <button type="submit" class="btn btn-danger btn-sm text-white" style="border-radius: 6px; font-weight: 600;">
                                                    Deactivate
                                                </button>
                                            }
                                            else
                                            {
                                                <input type="hidden" name="approve" value="true" />
                                                <button type="submit" class="btn btn-success btn-sm text-white" style="border-radius: 6px; font-weight: 600; background: #10b981; border: none; box-shadow: 0 0 10px rgba(16,185,129,0.3);">
                                                    Approve
                                                </button>
                                            }
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="adminProcessingOverlay" style="display:none; position: fixed; inset: 0; z-index: 9999; background: rgba(15, 23, 42, 0.72); backdrop-filter: blur(6px); align-items: center; justify-content: center;">
    <div style="background: #fff; border: 1px solid rgba(148, 163, 184, 0.35); border-radius: 16px; padding: 28px; width: min(440px, calc(100vw - 32px)); text-align: center; box-shadow: 0 24px 60px rgba(15, 23, 42, 0.24);">
        <div style="width: 48px; height: 48px; margin: 0 auto 16px; border: 4px solid rgba(37, 99, 235, 0.16); border-top-color: #2563eb; border-radius: 50%; animation: adminSpin 0.85s linear infinite;"></div>
        <h3 id="adminProcessingTitle" style="margin: 0 0 8px; color: #0f172a; font-size: 1.2rem;">Processing...</h3>
        <p id="adminProcessingMessage" style="margin: 0; color: #475569; line-height: 1.5;">Please keep this page open.</p>
    </div>
</div>

@section Scripts {
    <style>
        @@keyframes adminSpin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
    <script>
        const processingOverlay = document.getElementById("adminProcessingOverlay");
        const processingTitle = document.getElementById("adminProcessingTitle");
        const processingMessage = document.getElementById("adminProcessingMessage");

        document.querySelectorAll(".admin-processing-form").forEach((form) => {
            form.addEventListener("submit", () => {
                if (!processingOverlay) return;

                if (processingTitle) {
                    processingTitle.textContent = form.dataset.processingTitle || "Processing...";
                }
                if (processingMessage) {
                    processingMessage.textContent = form.dataset.processingMessage || "Please keep this page open.";
                }

                const submitButton = form.querySelector("button[type='submit']");
                if (submitButton) {
                    submitButton.disabled = true;
                    submitButton.dataset.originalText = submitButton.textContent;
                    submitButton.textContent = "Processing...";
                }

                processingOverlay.style.display = "flex";
            });
        });
    </script>
}
