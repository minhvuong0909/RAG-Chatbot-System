@model RagChatbotSystem.Presentation.Models.WorkspaceViewModel
@{
    var defaultMobileTab = Model.SelectedMessageId.HasValue ? "reference-panel" : "chat-panel";
}

<section class="workspace" data-rag-app data-active-tab="@defaultMobileTab">
    <!-- Mobile Navigation Tabs (Only visible on mobile screens) -->
    <div class="mobile-workspace-tabs" aria-label="Workspace navigation">
        <button class="mobile-tab-btn @(defaultMobileTab == "chat-panel" ? "active" : "")" data-target="chat-panel">💬 Chat</button>
        <button class="mobile-tab-btn @(defaultMobileTab == "management-panel" ? "active" : "")" data-target="management-panel">📚 Knowledge</button>
        <button class="mobile-tab-btn @(defaultMobileTab == "reference-panel" ? "active" : "")" data-target="reference-panel">
            🔍 Sources @(Model.Citations.Count > 0 ? $"({Model.Citations.Count})" : "")
        </button>
    </div>

    <!-- Cột 1: Bảng điều khiển quản lý (Management) -->
    <aside class="workspace-panel management-panel" aria-label="Dataset management">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Management</p>
                <h1>Knowledge workspace</h1>
            </div>
            <a class="icon-button" href="?datasetId=@Model.SelectedDatasetId&sessionId=@Model.SelectedSessionId" title="Refresh workspace" aria-label="Refresh workspace" style="text-decoration: none;">
                <span aria-hidden="true">↻</span>
            </a>
        </div>

        <!-- Thông báo lỗi hoặc thành công -->
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" style="background: rgba(180, 35, 24, 0.1); border: 1px solid rgba(180, 35, 24, 0.2); padding: 0.75rem; border-radius: 8px; color: var(--danger); margin-bottom: 1rem; font-size: 0.84rem; font-weight: 500;">
                @Model.ErrorMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success" style="background: rgba(15, 118, 110, 0.1); border: 1px solid rgba(15, 118, 110, 0.2); padding: 0.75rem; border-radius: 8px; color: var(--accent-strong); margin-bottom: 1rem; font-size: 0.84rem; font-weight: 500;">
                @Model.SuccessMessage
            </div>
        }

        <!-- Thông tin người dùng đăng nhập -->
        <div style="border-bottom: 1px solid var(--line); padding-bottom: 12px; margin-bottom: 16px;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 1.2rem;">👤</span>
                <div>
                    <div class="fw-bold" style="color: var(--ink); font-size: 0.95rem;">@Model.SelectedUser?.FullName</div>
                    <div class="text-muted small text-uppercase" style="font-size: 0.75rem; font-weight: bold; color: var(--accent-strong);">Role: @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                </div>
            </div>
        </div>

        <!-- Quản lý Datasets -->
        <div class="section-block">
            <div class="section-title">
                <h2>Datasets</h2>
                <span>@Model.Datasets.Count</span>
            </div>

            @if (!User.IsInRole("Student"))
            {
                <form asp-controller="Datasets" asp-action="Create" method="post" class="create-form">
                    @Html.AntiForgeryToken()
                    <input name="name" type="text" placeholder="Dataset name" required />
                    <textarea name="description" rows="2" placeholder="Short description"></textarea>
                    
                    <div style="display: flex; align-items: center; gap: 6px; margin: 8px 0;">
                        <input type="checkbox" name="isPublic" id="isPublic" value="true" checked style="width: auto; height: auto;" />
                        <label for="isPublic" style="font-size: 0.85rem; color: var(--muted); cursor: pointer; margin: 0;">Public Dataset (Công khai)</label>
                    </div>

                    <button type="submit">Create dataset</button>
                </form>
            }

            <div class="dataset-list" aria-live="polite">
                @if (Model.Datasets.Count == 0)
                {
                    <p class="helper-text">No datasets yet.</p>
                }
                @foreach (var ds in Model.Datasets)
                {
                    <div style="position: relative; display: block; margin-bottom: 6px;">
                        <a class="dataset-item @(Model.SelectedDatasetId == ds.DatasetId ? "active" : "")" 
                           href="?datasetId=@ds.DatasetId"
                           style="text-decoration: none; display: block; padding-right: 75px;">
                            <span class="dataset-name" style="display: flex; align-items: center; gap: 4px;">
                                @if (!ds.IsApproved)
                                {
                                    <span title="Pending approval" style="color: var(--warning);">⏳</span>
                                }
                                @ds.Name
                                @if (!ds.IsPublic)
                                {
                                    <span title="Private dataset" style="font-size: 0.8rem; color: var(--muted);">🔒</span>
                                }
                            </span>
                            <span class="dataset-meta">@ds.DocumentCount document(s)</span>
                        </a>

                        @if (User.IsInRole("Admin") || ds.CreatedBy == Model.SelectedUserId)
                        {
                            <!-- Nút xóa Dataset với z-index cao để không bị đè nút -->
                            <form asp-controller="Datasets" asp-action="Delete" method="post" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); margin: 0; padding: 0; z-index: 100;" onsubmit="return confirm('Xóa Dataset này sẽ xóa toàn bộ tài liệu bên trong. Bạn chắc chắn chứ?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@ds.DatasetId" />
                                <button type="submit" style="background: rgba(220, 38, 38, 0.05); border: 1px solid rgba(220, 38, 38, 0.25); border-radius: 6px; font-size: 0.8rem; font-weight: 600; color: var(--danger); cursor: pointer; padding: 4px 8px; display: inline-flex; align-items: center; gap: 4px; transition: all 0.2s;" onmouseover="this.style.background='rgba(220, 38, 38, 0.15)';" onmouseout="this.style.background='rgba(220, 38, 38, 0.05)';" title="Delete dataset">🗑️ Xóa</button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Quản lý Tài liệu (Documents) -->
        <div class="section-block">
            <div class="section-title">
                <h2>Documents</h2>
                <span>@Model.Documents.Count</span>
            </div>
            @if (Model.SelectedDatasetId.HasValue)
            {
                @if (!User.IsInRole("Student") && (User.IsInRole("Admin") || Model.SelectedDataset?.CreatedBy == Model.SelectedUserId))
                {
                    <form asp-controller="Documents" asp-action="Upload" method="post" enctype="multipart/form-data" class="upload-form" id="upload-doc-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                        <div id="upload-dropzone" style="position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 2px dashed var(--line); border-radius: 12px; padding: 22px 16px; background: var(--surface-muted); text-align: center; cursor: pointer; transition: all 0.2s;" onclick="if(!this.dataset.uploading) document.getElementById('file-upload').click();" onmouseover="this.style.borderColor='var(--accent)';" onmouseout="this.style.borderColor='var(--line)';">
                            <div id="upload-idle-state" style="display: flex; flex-direction: column; align-items: center;">
                                <span style="font-size: 1.8rem; margin-bottom: 6px;">📤</span>
                                <span style="font-weight: 700; font-size: 0.9rem; color: var(--ink);">Upload documents for RAG</span>
                                <span style="font-size: 0.75rem; color: var(--muted); margin-top: 4px;">PDF, TXT, MD, or DOCX files supported</span>
                            </div>
                            <div id="upload-loading-state" style="display: none; flex-direction: column; align-items: center; justify-content: center; padding: 10px 0;">
                                <span style="display: inline-block; font-size: 1.8rem; margin-bottom: 6px; animation: spin 1s linear infinite;">⏳</span>
                                <span style="font-weight: 700; font-size: 0.9rem; color: var(--accent);">Uploading &amp; Processing...</span>
                                <span style="font-size: 0.75rem; color: var(--muted); margin-top: 4px;">Please wait while we extract text, chunk and index embeddings.</span>
                            </div>
                            <input id="file-upload" name="file" type="file" required style="display: none;" onchange="triggerUpload();" />
                        </div>
                    </form>
                }
                
                <div class="document-list" aria-live="polite">
                    @if (Model.Documents.Count == 0)
                    {
                        <p class="helper-text">No documents in this dataset. Hỗ trợ file: TXT, PDF, DOCX.</p>
                    }
                    @foreach (var doc in Model.Documents)
                    {
                        <div class="document-item">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px;">
                                <div style="min-width: 0; flex-grow: 1;">
                                    <strong class="document-name" style="text-overflow: ellipsis; overflow: hidden; white-space: nowrap;" title="@doc.FileName">@doc.FileName</strong>
                                    <span class="document-meta">@doc.FileType.ToUpper() - @Math.Ceiling(doc.FileSize / 1024.0) KB</span>
                                </div>
                                @if (User.IsInRole("Admin") || doc.UploadedBy == Model.SelectedUserId)
                                {
                                    <form asp-controller="Documents" asp-action="Delete" method="post" style="margin: 0; padding: 0; z-index: 10;" onsubmit="return confirm('Are you sure you want to delete this document?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                                        <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                        <button type="submit" style="background: rgba(220, 38, 38, 0.05); border: 1px solid rgba(220, 38, 38, 0.25); border-radius: 6px; font-size: 0.8rem; font-weight: 600; color: var(--danger); cursor: pointer; padding: 4px 8px; display: inline-flex; align-items: center; gap: 4px; transition: all 0.2s;" onmouseover="this.style.background='rgba(220, 38, 38, 0.15)';" onmouseout="this.style.background='rgba(220, 38, 38, 0.05)';" title="Delete document">🗑️ Xóa</button>
                                    </form>
                                }
                            </div>
                            <div class="progress-track" aria-hidden="true">
                                <span class="progress-fill" style="width: @(doc.Status.Equals("Processing", StringComparison.OrdinalIgnoreCase) ? "55%" : "100%")"></span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 6px;">
                                <span class="status-pill @doc.Status.ToLower()">@doc.Status</span>
                                @if (doc.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase))
                                {
                                    <button class="view-chunks-btn" data-document-id="@doc.DocumentId" data-document-name="@doc.FileName" style="background: rgba(59, 130, 246, 0.08); border: 1px solid rgba(59, 130, 246, 0.25); border-radius: 6px; font-size: 0.75rem; font-weight: 600; color: var(--accent); cursor: pointer; padding: 2px 6px; transition: all 0.2s;" onmouseover="this.style.background='rgba(59, 130, 246, 0.18)';" onmouseout="this.style.background='rgba(59, 130, 246, 0.08)';">🔍 Xem Chunks</button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="helper-text">Select a dataset to view documents.</p>
            }
        </div>

        <!-- Quản lý Chat Sessions -->
        <div class="section-block">
            <div class="section-title">
                <h2>Chat sessions</h2>
                <span>@Model.Sessions.Count</span>
            </div>
            <p class="helper-text">A dataset can have many conversations. Select one or start a fresh session.</p>
            @if (Model.SelectedDatasetId.HasValue)
            {
                <form asp-controller="ChatSessions" asp-action="Create" method="post" class="create-form" style="margin-bottom: 6px;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                    <div class="input-row">
                        <input name="title" type="text" placeholder="Session title (optional)" />
                        <button type="submit">New</button>
                    </div>
                </form>
                <div class="session-list" aria-live="polite">
                    @if (Model.Sessions.Count == 0)
                    {
                        <p class="helper-text">No sessions yet.</p>
                    }
                    @foreach (var ss in Model.Sessions)
                    {
                        <a class="session-item @(Model.SelectedSessionId == ss.SessionId ? "active" : "")" 
                           href="?datasetId=@Model.SelectedDatasetId&sessionId=@ss.SessionId"
                           style="text-decoration: none;">
                            <span class="session-name">@ss.Title</span>
                            <span class="session-meta">Updated @ss.UpdatedAt.ToString("HH:mm dd/MM")</span>
                        </a>
                    }
                </div>
            }
        </div>

        <!-- Statistics Block (Mock Web3 style matching user screenshot) -->
        <div class="section-block mt-4 pt-3" style="border-top: 1px solid var(--line);">
            <div class="section-title mb-2">
                <h2 style="font-size: 1rem; font-weight: 700; color: var(--ink);">Statistics</h2>
            </div>
            <div class="d-flex flex-column gap-2" style="font-size: 0.85rem;">
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Total Documents</span>
                    <strong style="color: var(--accent); font-weight: 700;">@Model.Documents.Count</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Embeddings</span>
                    <strong style="color: #8b5cf6; font-weight: 700;">@(Model.Documents.Count * 25)</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Queries Today</span>
                    <strong style="color: #10b981; font-weight: 700;">156</strong>
                </div>
            </div>
        </div>

        <!-- Web3 Features Block (Mock Web3 style matching user screenshot) -->
        <div class="section-block mt-4 pt-3" style="border-top: 1px solid var(--line); background: rgba(59, 130, 246, 0.03); margin: 0 -18px -18px -18px; padding: 18px; border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;">
            <div class="section-title mb-2">
                <h2 style="font-size: 0.9rem; font-weight: 700; color: var(--accent); display: flex; align-items: center; gap: 6px;">
                    <span style="display:inline-block; width:6px; height:6px; background:#10b981; border-radius:50%;"></span>
                    Web3 Features
                </h2>
            </div>
            <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.8rem; display: flex; flex-direction: column; gap: 6px; color: var(--muted);">
                <li><span style="color: #10b981; margin-right: 6px; font-weight: bold;">✓</span> Decentralized storage (IPFS)</li>
                <li><span style="color: #10b981; margin-right: 6px; font-weight: bold;">✓</span> On-chain verification</li>
                <li><span style="color: #10b981; margin-right: 6px; font-weight: bold;">✓</span> Token-gated access</li>
                <li><span style="color: #10b981; margin-right: 6px; font-weight: bold;">✓</span> Smart contract integration</li>
            </ul>
        </div>
    </aside>

    <!-- Cột 2: Giao diện Hội thoại (Chat Panel) -->
    <main class="chat-panel" aria-label="Chat interface">
        <div class="chat-header">
            <div>
                <p class="eyebrow">Chat</p>
                @if (Model.SelectedSession != null)
                {
                    <h2 data-chat-title>@Model.SelectedSession.Title</h2>
                }
                else if (Model.SelectedDataset != null)
                {
                    <h2 data-chat-title>Select or create a chat session</h2>
                }
                else
                {
                    <h2 data-chat-title>Select a dataset to start</h2>
                }
            </div>
            @if (Model.SelectedDatasetId.HasValue)
            {
                <form asp-controller="ChatSessions" asp-action="Create" method="post" style="margin: 0; padding: 0;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                    <input type="hidden" name="title" value="Dataset chat" />
                    <button class="secondary-button" type="submit">New session</button>
                </form>
            }
        </div>

        <div class="chat-stream" aria-live="polite" id="chatStream">
            @if (Model.SelectedSession != null)
            {
                if (Model.MessageHistory.Count == 0)
                {
                    <div class="empty-state">
                        <h3>Ask questions grounded in your uploaded documents.</h3>
                        <p>Type your message below. The AI will retrieve the most relevant sections of your documents to provide answers.</p>
                    </div>
                }
                else
                {
                    @foreach (var msg in Model.MessageHistory)
                    {
                        <div class="message @msg.Role.ToLower()">
                            <div class="message-bubble">
                                <p style="margin: 0; white-space: pre-wrap;">@msg.Content</p>
                            </div>
                            <div class="message-meta">
                                @(msg.Role == "User" ? "You" : "Assistant") • @msg.CreatedAt.ToString("HH:mm")
                            </div>
                            @if (msg.Role == "Assistant")
                            {
                                <div class="citation-row" style="margin-top: 8px;">
                                    <button class="citation-chip view-sources-btn" 
                                       data-message-id="@msg.MessageId"
                                       style="background: none; border: none; font: inherit; text-decoration: none; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 4px;">
                                        🔍 View Sources
                                    </button>
                                </div>
                            }
                        </div>
                    }
                }
            }
            else
            {
                <div class="empty-state">
                    <h3>Ask questions grounded in your uploaded documents.</h3>
                    <p>Create or select a dataset, upload a document, then start a chat session.</p>
                </div>
            }
        </div>

        @if (Model.SelectedSessionId.HasValue)
        {
            <form asp-controller="ChatSessions" asp-action="SendMessage" method="post" class="composer">
                @Html.AntiForgeryToken()
                <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                <input type="hidden" name="sessionId" value="@Model.SelectedSessionId" />
                <textarea name="question" rows="1" placeholder="Ask about this dataset..." required id="chatQuestionTextarea"></textarea>
                <button type="submit">Send</button>
            </form>
        }
    </main>

    <!-- Cột 3: Hiển thị trích dẫn tài liệu tham chiếu (Reference Panel) -->
    <aside class="workspace-panel reference-panel" aria-label="Citation references">
        <div class="panel-header">
            <div>
                <p class="eyebrow">References</p>
                <h2>Sources</h2>
            </div>
        </div>

        @if (Model.SelectedMessageId.HasValue && Model.Citations.Count > 0)
        {
            <div class="reference-content">
                @foreach (var c in Model.Citations)
                {
                    <div class="reference-card">
                        <h3 title="@c.FileName">@c.FileName</h3>
                        <p><strong>Page:</strong> @(c.PageNumber > 0 ? c.PageNumber.ToString() : "1")</p>
                        <p><strong>Source label:</strong> @c.SourceLabel</p>
                        <p style="margin-top: 6px; font-style: italic; background: var(--surface-muted); padding: 8px; border-radius: 6px; border-left: 3px solid var(--accent);">
                            "@c.QuoteText"
                        </p>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="reference-empty">
                <h3>No citation selected</h3>
                <p>When an AI answer includes sources, select a reference to inspect the chunk and file name.</p>
            </div>
        }
    </aside>
</section>

@section Scripts {
    <style>
        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
    <script>
        // Tự động cuộn khung chat xuống dưới cùng khi có tin nhắn mới hoặc tải trang
        const chatStream = document.getElementById("chatStream");
        if (chatStream) {
            chatStream.scrollTop = chatStream.scrollHeight;
        }

        function escapeHtml(str) {
            if (!str) return "";
            return str
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        // Hỗ trợ gửi tin nhắn bằng tổ hợp phím Enter (nhưng cho phép Shift+Enter để xuống dòng)
        const textarea = document.getElementById("chatQuestionTextarea");
        if (textarea) {
            textarea.addEventListener("keydown", function(e) {
                if (e.key === "Enter" && !e.shiftKey) {
                    e.preventDefault();
                    // Kích hoạt submit form được xử lý bằng AJAX ở dưới
                    this.form.dispatchEvent(new Event("submit", { cancelable: true }));
                }
            });
        }

        // Xử lý gửi tin nhắn bằng AJAX (Không tải lại trang)
        const composerForm = document.querySelector(".composer");
        if (composerForm) {
            composerForm.addEventListener("submit", function(e) {
                e.preventDefault();
                
                const questionInput = document.getElementById("chatQuestionTextarea");
                if (!questionInput) return;
                const question = questionInput.value.trim();
                if (!question) return;
                
                // Clear và reset textarea ngay lập tức
                questionInput.value = "";
                questionInput.style.height = "auto";
                
                // 1. Hiển thị tin nhắn của User ngay lập tức lên màn hình
                appendMessage("user", question, new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }));
                
                // 2. Thêm bong bóng chờ trả lời (Loading) từ Assistant
                const loadingBubble = appendLoadingBubble();
                
                // Cuộn xuống cuối
                if (chatStream) {
                    chatStream.scrollTop = chatStream.scrollHeight;
                }
                
                // 3. Gửi yêu cầu qua Fetch API tới Backend
                const formData = new FormData(composerForm);
                formData.set("question", question);
                
                fetch("/ChatSessions/SendMessageAjax", {
                    method: "POST",
                    body: formData
                })
                .then(response => {
                    if (!response.ok) {
                        return response.json().then(data => { throw new Error(data.error || "Gửi tin nhắn thất bại.") });
                    }
                    return response.json();
                })
                .then(data => {
                    // Xóa bong bóng loading
                    if (loadingBubble) loadingBubble.remove();
                    
                    // Thêm câu trả lời của AI vào giao diện
                    appendMessage("assistant", data.assistantMessage.content, data.assistantMessage.createdAt, data.assistantMessage.messageId);
                    
                    // Hiển thị ngay các nguồn trích dẫn tương ứng bên cột phải
                    if (data.citations && data.citations.length > 0) {
                        renderCitationsDirectly(data.citations);
                    }
                    
                    // Cuộn xuống cuối
                    if (chatStream) {
                        chatStream.scrollTop = chatStream.scrollHeight;
                    }
                })
                .catch(err => {
                    console.error(err);
                    if (loadingBubble) loadingBubble.remove();
                    
                    // Hiển thị bong bóng lỗi
                    appendMessage("assistant", `❌ Lỗi: ${err.message}`, new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }));
                    
                    if (chatStream) {
                        chatStream.scrollTop = chatStream.scrollHeight;
                    }
                });
            });
        }

        function appendMessage(role, content, time, messageId = null) {
            const emptyState = chatStream.querySelector(".empty-state");
            if (emptyState) emptyState.remove();

            const messageDiv = document.createElement("div");
            messageDiv.className = `message ${role}`;
            
            let citationHtml = "";
            if (role === "assistant" && messageId) {
                citationHtml = `
                    <div class="citation-row" style="margin-top: 8px;">
                        <button class="citation-chip view-sources-btn" 
                                data-message-id="${messageId}"
                                style="background: none; border: none; font: inherit; text-decoration: none; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 4px;">
                            🔍 View Sources
                        </button>
                    </div>
                `;
            }

            messageDiv.innerHTML = `
                <div class="message-bubble">
                    <p style="margin: 0; white-space: pre-wrap;">${escapeHtml(content)}</p>
                </div>
                <div class="message-meta">
                    ${role === "user" ? "You" : "Assistant"} • ${time}
                </div>
                ${citationHtml}
            `;
            chatStream.appendChild(messageDiv);
        }

        function appendLoadingBubble() {
            const emptyState = chatStream.querySelector(".empty-state");
            if (emptyState) emptyState.remove();

            const loadingDiv = document.createElement("div");
            loadingDiv.className = "message assistant loading-bubble";
            loadingDiv.innerHTML = `
                <div class="message-bubble" style="display: flex; align-items: center; gap: 8px;">
                    <span style="display: inline-block; animation: spin 1s linear infinite;">⏳</span>
                    <span style="font-style: italic; color: var(--muted);">Searching knowledge base and thinking...</span>
                </div>
                <div class="message-meta">
                    Assistant • Loading
                </div>
            `;
            chatStream.appendChild(loadingDiv);
            return loadingDiv;
        }

        // Lắng nghe sự kiện click vào nút xem trích dẫn (Event Delegation để hỗ trợ cả tin nhắn mới)
        document.addEventListener("click", function(e) {
            const btn = e.target.closest(".view-sources-btn");
            if (btn) {
                e.preventDefault();
                const messageId = btn.getAttribute("data-message-id");
                fetchCitations(messageId);
            }
        });

        function fetchCitations(messageId) {
            const referencePanel = document.querySelector(".reference-panel");
            if (!referencePanel) return;

            // Render giao diện chờ tải trích dẫn bên cột phải
            referencePanel.innerHTML = `
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">References</p>
                        <h2>Sources</h2>
                    </div>
                </div>
                <div style="padding: 24px; text-align: center; color: var(--muted);">
                    <span style="display: inline-block; font-size: 1.5rem; margin-bottom: 8px; animation: spin 1.2s linear infinite;">⏳</span>
                    <p style="font-size: 0.85rem; margin: 0;">Retrieving source documents...</p>
                </div>
            `;

            // Tự động chuyển tab trên Mobile sang tab "Sources"
            const workspace = document.querySelector(".workspace");
            if (workspace && window.innerWidth <= 820) {
                workspace.setAttribute("data-active-tab", "reference-panel");
                const refTabBtn = document.querySelector('.mobile-tab-btn[data-target="reference-panel"]');
                if (refTabBtn) {
                    document.querySelectorAll(".mobile-tab-btn").forEach(b => b.classList.remove("active"));
                    refTabBtn.classList.add("active");
                }
            }

            // Gọi API lấy thông tin trích dẫn
            fetch(`/ChatSessions/GetCitations?messageId=${messageId}`)
                .then(response => {
                    if (!response.ok) throw new Error("Failed to load citations");
                    return response.json();
                })
                .then(citations => {
                    renderCitationsDirectly(citations);
                })
                .catch(err => {
                    console.error(err);
                    referencePanel.innerHTML = `
                        <div class="panel-header">
                            <div>
                                <p class="eyebrow">References</p>
                                <h2>Sources</h2>
                            </div>
                        </div>
                        <div style="padding: 24px; text-align: center; color: var(--danger);">
                            <p style="font-size: 0.85rem; margin: 0;">Error loading sources: ${err.message}</p>
                        </div>
                    `;
                });
        }

        function renderCitationsDirectly(citations) {
            const referencePanel = document.querySelector(".reference-panel");
            if (!referencePanel) return;

            let html = `
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">References</p>
                        <h2>Sources</h2>
                    </div>
                </div>
            `;

            if (!citations || citations.length === 0) {
                html += `
                    <div class="reference-empty">
                        <h3>No citations found</h3>
                        <p>No specific chunks were retrieved for this response.</p>
                    </div>
                `;
            } else {
                html += `<div class="reference-content">`;
                citations.forEach(c => {
                    html += `
                        <div class="reference-card">
                            <h3 title="${escapeHtml(c.fileName)}">${escapeHtml(c.fileName)}</h3>
                            <p><strong>Page:</strong> ${c.pageNumber > 0 ? c.pageNumber : 1}</p>
                            <p><strong>Source label:</strong> ${escapeHtml(c.sourceLabel || "N/A")}</p>
                            <p style="margin-top: 6px; font-style: italic; background: var(--surface-muted); padding: 8px; border-radius: 6px; border-left: 3px solid var(--accent);">
                                "${escapeHtml(c.quoteText)}"
                            </p>
                        </div>
                    `;
                });
                html += `</div>`;
            }
            referencePanel.innerHTML = html;
        }

        // Logic chuyển đổi Tab trên thiết bị di động
        const tabBtns = document.querySelectorAll(".mobile-tab-btn");
        const workspace = document.querySelector(".workspace");
        if (tabBtns && workspace) {
            tabBtns.forEach(btn => {
                btn.addEventListener("click", () => {
                    tabBtns.forEach(b => b.classList.remove("active"));
                    btn.classList.add("active");
                    const target = btn.getAttribute("data-target");
                    workspace.setAttribute("data-active-tab", target);
                });
            });
        }

        function triggerUpload() {
            const fileInput = document.getElementById('file-upload');
            if (fileInput && fileInput.files && fileInput.files.length > 0) {
                const file = fileInput.files[0];
                const maxSize = 50 * 1024 * 1024; // 50MB
                if (file.size > maxSize) {
                    alert('Kích thước tệp vượt quá giới hạn cho phép (tối đa 50MB). Vui lòng chọn tệp nhỏ hơn.');
                    fileInput.value = ""; // Reset
                    return;
                }
            }

            const dropzone = document.getElementById('upload-dropzone');
            const idleState = document.getElementById('upload-idle-state');
            const loadingState = document.getElementById('upload-loading-state');
            
            if (dropzone) {
                dropzone.dataset.uploading = "true";
                dropzone.style.cursor = "not-allowed";
                dropzone.style.borderColor = "var(--accent)";
            }
            if (idleState) idleState.style.display = "none";
            if (loadingState) loadingState.style.display = "flex";
            
            document.getElementById('upload-doc-form').submit();
        }

        // View Chunks & Embeddings Logic
        document.addEventListener("click", function(e) {
            const btn = e.target.closest(".view-chunks-btn");
            if (btn) {
                e.preventDefault();
                const docId = btn.getAttribute("data-document-id");
                const docName = btn.getAttribute("data-document-name");
                openChunksModal(docId, docName);
            }
        });

        const chunksModal = document.getElementById("chunksModal");
        const closeChunksModalBtn = document.getElementById("closeChunksModal");
        if (closeChunksModalBtn && chunksModal) {
            closeChunksModalBtn.onclick = function() {
                chunksModal.style.display = "none";
            }
            window.onclick = function(event) {
                if (event.target == chunksModal) {
                    chunksModal.style.display = "none";
                }
            }
        }

        function openChunksModal(docId, docName) {
            if (!chunksModal) return;
            
            document.getElementById("modalDocTitle").innerText = docName;
            document.getElementById("modalDocSub").innerText = "Loading chunks and embeddings...";
            
            const body = document.getElementById("modalChunksBody");
            body.innerHTML = `
                <div style="padding: 40px; text-align: center; color: var(--muted);">
                    <span style="display: inline-block; font-size: 2rem; margin-bottom: 8px; animation: spin 1s linear infinite;">⏳</span>
                    <p style="font-size: 0.9rem; margin: 0;">Retrieving embeddings and index partitions from PostgreSQL database...</p>
                </div>
            `;
            
            chunksModal.style.display = "flex";
            
            fetch(`/Documents/GetChunks?documentId=${docId}`)
                .then(response => {
                    if (!response.ok) throw new Error("Failed to load chunks");
                    return response.json();
                })
                .then(chunks => {
                    document.getElementById("modalDocSub").innerText = `Found ${chunks.length} chunks generated for this document.`;
                    
                    if (chunks.length === 0) {
                        body.innerHTML = `
                            <div style="padding: 30px; text-align: center; color: var(--muted);">
                                <p style="font-size: 0.9rem; margin: 0;">No index chunks found for this document. It might still be processing.</p>
                            </div>
                        `;
                        return;
                    }
                    
                    let html = "";
                    chunks.forEach(c => {
                        let vecPreview = "Embedding vector: No vector data found.";
                        if (c.embedding && c.embedding.length > 0) {
                            const dims = c.embedding.length;
                            const previewValues = c.embedding.slice(0, 8).map(v => v.toFixed(5)).join(", ");
                            vecPreview = `Embedding Vector (pgvector [384] - first 8 dimensions): [ ${previewValues}, ... ]`;
                        }
                        
                        html += `
                            <div class="chunk-card">
                                <div class="chunk-meta-info">
                                    <span><strong>Chunk Index:</strong> #${c.chunkIndex + 1}</span>
                                    <span><strong>Page:</strong> ${c.pageNumber > 0 ? c.pageNumber : 1}</span>
                                </div>
                                <p class="chunk-text-content">${escapeHtml(c.content)}</p>
                                <div class="vector-preview-box" title="Full size is 384 dimensions representation vector">
                                    ✨ ${vecPreview}
                                </div>
                            </div>
                        `;
                    });
                    
                    body.innerHTML = html;
                })
                .catch(err => {
                    console.error(err);
                    document.getElementById("modalDocSub").innerText = "Error loading index data.";
                    body.innerHTML = `
                        <div style="padding: 30px; text-align: center; color: var(--danger);">
                            <p style="font-size: 0.9rem; margin: 0;">Failed to fetch chunks: ${err.message}</p>
                        </div>
                    `;
                });
        }
    </script>

    <!-- Modal Xem Chunks & Embeddings -->
    <div id="chunksModal" style="display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0, 0, 0, 0.55); backdrop-filter: blur(4px); align-items: center; justify-content: center;">
        <div style="background-color: var(--surface); border: 1px solid var(--line); border-radius: 12px; width: 90%; max-width: 750px; max-height: 80vh; display: flex; flex-direction: column; box-shadow: 0 10px 25px rgba(0,0,0,0.25); animation: modalFadeIn 0.2s ease-out; margin: auto;">
            <!-- Header -->
            <div style="padding: 16px 20px; border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h2 id="modalDocTitle" style="font-size: 1.1rem; font-weight: 700; margin: 0; color: var(--ink);">Document Chunks &amp; Embeddings</h2>
                    <p id="modalDocSub" style="font-size: 0.8rem; color: var(--muted); margin: 2px 0 0 0;"></p>
                </div>
                <button id="closeChunksModal" style="background: none; border: none; font-size: 1.6rem; color: var(--muted); cursor: pointer; padding: 0; line-height: 1;">&times;</button>
            </div>
            <!-- Body -->
            <div id="modalChunksBody" style="padding: 20px; overflow-y: auto; flex-grow: 1; display: flex; flex-direction: column; gap: 14px; background: var(--surface);">
                <!-- Dynamic chunks -->
            </div>
        </div>
    </div>

    <style>
        #chunksModal {
            display: none;
        }
        @@keyframes modalFadeIn {
            from { opacity: 0; transform: scale(0.96); }
            to { opacity: 1; transform: scale(1); }
        }
        .chunk-card {
            border: 1px solid var(--line);
            border-radius: 8px;
            background: var(--surface-muted);
            padding: 12px 16px;
            transition: all 0.2s;
        }
        .chunk-card:hover {
            border-color: var(--accent);
            background: var(--surface);
        }
        .chunk-meta-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.78rem;
            color: var(--muted);
            border-bottom: 1px dashed var(--line);
            padding-bottom: 6px;
            margin-bottom: 8px;
        }
        .chunk-text-content {
            font-size: 0.86rem;
            color: var(--ink);
            line-height: 1.5;
            white-space: pre-wrap;
            margin: 0;
        }
        .vector-preview-box {
            margin-top: 10px;
            background: rgba(139, 92, 246, 0.05);
            border: 1px solid rgba(139, 92, 246, 0.15);
            border-radius: 6px;
            padding: 6px 10px;
            font-family: monospace;
            font-size: 0.72rem;
            color: #7c3aed;
            overflow-x: auto;
            white-space: nowrap;
        }
    </style>
}
