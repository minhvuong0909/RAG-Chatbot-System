@{
    ViewData["Title"] = "Change Password";
}

<div class="auth-container" style="min-height: calc(90vh - 104px);">
    <div class="auth-card" style="max-width: 480px;">
        <div class="auth-title">
            <span class="brand-mark mb-3" style="display: inline-grid; width: 54px; height: 54px; place-items: center; border-radius: 12px; font-size: 1.8rem; margin-bottom: 12px;">R</span>
            <h1>Change password</h1>
            <p>You must replace the temporary password before using the workspace.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger border-0 mb-4">
                <div asp-validation-summary="All" class="small list-unstyled m-0 fw-bold"></div>
            </div>
        }

        <form asp-action="ChangePassword" method="post" style="display: grid; gap: 16px;">
            @Html.AntiForgeryToken()

            <div>
                <label for="currentPassword" class="form-label small fw-bold mb-2">CURRENT PASSWORD</label>
                <input type="password" id="currentPassword" name="currentPassword" required style="min-height: 46px;" />
            </div>

            <div>
                <label for="newPassword" class="form-label small fw-bold mb-2">NEW PASSWORD</label>
                <input type="password" id="newPassword" name="newPassword" required minlength="8" style="min-height: 46px;" />
            </div>

            <div>
                <label for="confirmNewPassword" class="form-label small fw-bold mb-2">CONFIRM NEW PASSWORD</label>
                <input type="password" id="confirmNewPassword" name="confirmNewPassword" required minlength="8" style="min-height: 46px;" />
            </div>

            <button type="submit" style="width: 100%; min-height: 48px; border-radius: 8px; font-size: 0.9rem;">
                Save password
            </button>
        </form>
    </div>
</div>
