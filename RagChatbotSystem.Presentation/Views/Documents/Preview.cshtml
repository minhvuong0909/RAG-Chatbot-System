@model RagChatbotSystem.Business.DTOs.DocumentPreviewDto
@{
    ViewData["Title"] = "Document Preview";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <p class="eyebrow">Document Preview</p>
            <h2 class="fw-bold">@Model.FileName</h2>
            <p class="text-muted mb-0">@Model.DatasetName - @Model.FileType.ToUpper() - @Math.Ceiling(Model.FileSize / 1024.0) KB - @Model.Status</p>
        </div>
        <a asp-controller="Home" asp-action="Index" asp-route-datasetId="@Model.DatasetId" class="btn btn-outline-secondary">Back</a>
    </div>

    @if (!Model.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase))
    {
        <div class="alert alert-warning">
            This document is not completed yet. Current status: <strong>@Model.Status</strong>.
        </div>
    }

    <div class="card border-0" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important;">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
            <h4 class="fw-bold m-0">Indexed Chunks</h4>
            <p class="text-muted small m-0 mt-1">@Model.Chunks.Count chunk(s) extracted from this document.</p>
        </div>
        <div class="card-body px-4 pb-4">
            @if (Model.Chunks.Count == 0)
            {
                <p class="text-muted">No chunks are available for this document.</p>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var chunk in Model.Chunks)
                    {
                        <div class="p-3" style="border: 1px solid var(--line); border-radius: 10px; background: var(--surface-muted);">
                            <div class="d-flex justify-content-between gap-3 mb-2">
                                <strong>Chunk #@chunk.ChunkIndex</strong>
                                <span class="text-muted small">Page @chunk.PageNumber</span>
                            </div>
                            <pre style="white-space: pre-wrap; color: var(--ink); margin: 0; font-family: inherit;">@chunk.Content</pre>
                            @if (!string.IsNullOrWhiteSpace(chunk.MetadataJson))
                            {
                                <details class="mt-2">
                                    <summary class="text-muted small">Metadata</summary>
                                    <code>@chunk.MetadataJson</code>
                                </details>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
