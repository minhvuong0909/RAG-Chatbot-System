@page
@model RagChatbotSystem.Presentation.Pages.Teacher.AnalyticsModel
@{
    ViewData["Title"] = "Phân tích học tập";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white/60 backdrop-blur-xl border border-white shadow-sm p-6 rounded-2xl">
        <div>
            <p class="text-xs font-bold text-accent-strong tracking-wider uppercase mb-1">Không gian giảng dạy</p>
            <h1 class="text-2xl font-grotesk font-extrabold text-ink tracking-tight">Phân tích học tập</h1>
            <p class="text-sm text-gray-500 mt-1">Theo dõi mức độ học tập và tương tác trong các môn bạn phụ trách.</p>
        </div>
    </div>

    @if (Model.AssignedSubjects.Count == 0)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-16 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-50 text-gray-400 mb-4">
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            </div>
            <h2 class="text-xl font-bold text-ink mb-2">Bạn chưa được phân công môn học</h2>
            <p class="text-sm text-gray-500 max-w-md mx-auto">Vui lòng liên hệ quản trị viên để được phân công môn trước khi xem số liệu học tập.</p>
        </div>
    }
    else
    {
        <!-- Stats Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Stat Card 1 -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 flex items-center gap-4 transition-transform hover:-translate-y-1">
                <div class="w-12 h-12 rounded-xl bg-indigo-50 text-accent-strong flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path><path d="M6 6h10"></path><path d="M6 10h10"></path></svg>
                </div>
                <div>
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Môn đang phụ trách</p>
                    <p class="text-2xl font-bold text-ink leading-none">@Model.AssignedSubjects.Count.ToString("N0")</p>
                </div>
            </div>

            <!-- Stat Card 2 -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 flex items-center gap-4 transition-transform hover:-translate-y-1">
                <div class="w-12 h-12 rounded-xl bg-cyan-50 text-cyan-600 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                </div>
                <div>
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Tổng lượt hỏi</p>
                    <p class="text-2xl font-bold text-ink leading-none">@Model.Summary.TotalQueriesCount.ToString("N0")</p>
                </div>
            </div>

            <!-- Stat Card 3 -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 flex items-center gap-4 transition-transform hover:-translate-y-1">
                <div class="w-12 h-12 rounded-xl bg-amber-50 text-amber-500 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                </div>
                <div>
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Sinh viên hoạt động</p>
                    <p class="text-2xl font-bold text-ink leading-none">@Model.ActiveStudentsCount.ToString("N0")</p>
                </div>
            </div>

            <!-- Stat Card 4 -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 flex items-center gap-4 transition-transform hover:-translate-y-1">
                <div class="w-12 h-12 rounded-xl bg-green-50 text-green-600 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </div>
                <div>
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Tài liệu trích dẫn</p>
                    <p class="text-2xl font-bold text-ink leading-none">@Model.TopDocuments.Count.ToString("N0")</p>
                </div>
            </div>
        </div>

        <!-- Charts Row -->
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
            <!-- Line Chart -->
            <div class="lg:col-span-3 bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <div class="mb-6">
                    <h2 class="text-lg font-bold text-ink">Lượt hỏi theo ngày</h2>
                    <p class="text-sm text-gray-500 mt-1">Mức độ tương tác trong 7 ngày gần nhất</p>
                </div>
                <div class="relative h-72 w-full">
                    <canvas id="dailyChart"></canvas>
                </div>
            </div>

            <!-- Doughnut Chart -->
            <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <div class="mb-6">
                    <h2 class="text-lg font-bold text-ink">Nguồn tham khảo phổ biến</h2>
                    <p class="text-sm text-gray-500 mt-1">Các tài liệu được AI dùng nhiều nhất</p>
                </div>
                <div class="relative h-72 w-full flex items-center justify-center">
                    @if (Model.TopDocuments.Count > 0)
                    {
                        <canvas id="docsChart"></canvas>
                    }
                    else
                    {
                        <div class="text-center text-gray-400">
                            <svg class="w-12 h-12 mx-auto mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                            <p class="text-sm">Chưa có dữ liệu</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Details Table Row -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Table 1: Subject Activity -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-6 py-5 border-b border-gray-50 bg-white">
                    <h2 class="text-lg font-bold text-ink">Hoạt động theo môn học</h2>
                    <p class="text-sm text-gray-500 mt-1">Số lượt hỏi và sinh viên có hoạt động ở từng môn</p>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-50/50 border-b border-gray-100">
                                <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Môn học</th>
                                <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider text-center">Sinh viên</th>
                                <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Lượt hỏi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 bg-white">
                            @foreach (var subject in Model.TopSubjects)
                            {
                                <tr class="hover:bg-gray-50/50 transition-colors">
                                    <td class="py-3 px-6">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-lg bg-indigo-50 text-accent-strong flex items-center justify-center font-bold text-xs shrink-0 uppercase tracking-wider">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path><path d="M6 6h10"></path><path d="M6 10h10"></path></svg>
                                            </div>
                                            <div class="font-semibold text-ink text-sm">@subject.DatasetName</div>
                                        </div>
                                    </td>
                                    <td class="py-3 px-6 text-center">
                                        <span class="inline-flex items-center justify-center min-w-[28px] h-7 px-2 bg-gray-100 text-gray-700 text-xs font-bold rounded-lg">
                                            @subject.ActiveUsersCount.ToString("N0")
                                        </span>
                                    </td>
                                    <td class="py-3 px-6 text-right">
                                        <span class="inline-flex items-center justify-center min-w-[28px] h-7 px-2 bg-indigo-50 text-accent-strong text-xs font-bold rounded-lg">
                                            @subject.TotalQueriesCount.ToString("N0")
                                        </span>
                                    </td>
                                </tr>
                            }
                            @if (!Model.TopSubjects.Any())
                            {
                                <tr><td colspan="3" class="py-8 text-center text-sm text-gray-500">Chưa có dữ liệu.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Table 2: Top Students -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-6 py-5 border-b border-gray-50 bg-white">
                    <h2 class="text-lg font-bold text-ink">Mức độ tương tác của sinh viên</h2>
                    <p class="text-sm text-gray-500 mt-1">Các sinh viên đặt nhiều câu hỏi nhất trong môn bạn phụ trách</p>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-50/50 border-b border-gray-100">
                                <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider w-16">Hạng</th>
                                <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Sinh viên</th>
                                <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Lượt hỏi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 bg-white">
                            @{ var rank = 1; }
                            @foreach (var student in Model.StudentEngagement)
                            {
                                <tr class="hover:bg-gray-50/50 transition-colors">
                                    <td class="py-3 px-6 text-sm text-gray-500 font-medium">#@rank</td>
                                    <td class="py-3 px-6">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-indigo-100 to-cyan-100 text-accent-strong flex items-center justify-center font-bold text-xs">
                                                @(string.IsNullOrWhiteSpace(student.FullName) ? "?" : student.FullName.Substring(0, Math.Min(2, student.FullName.Length)).ToUpper())
                                            </div>
                                            <div>
                                                <div class="font-semibold text-ink text-sm leading-tight">@student.FullName</div>
                                                <div class="text-xs text-gray-500 leading-tight mt-0.5">@student.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3 px-6 text-right">
                                        <span class="inline-flex items-center justify-center min-w-[28px] h-7 px-2 bg-indigo-50 text-accent-strong text-xs font-bold rounded-lg">
                                            @student.TotalQueriesCount.ToString("N0")
                                        </span>
                                    </td>
                                </tr>
                                rank++;
                            }
                            @if (!Model.StudentEngagement.Any())
                            {
                                <tr><td colspan="3" class="py-8 text-center text-sm text-gray-500">Chưa có dữ liệu.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const accentStrong = '#4F46E5';
            const cyan = '#06B6D4';
            const gridColor = '#f3f4f6';
            const textColor = '#6b7280';
            const textBold = '#111827';
            
            Chart.defaults.font.family = '"Inter", "Segoe UI", sans-serif';
            Chart.defaults.color = textColor;
            
            const commonOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(255, 255, 255, 0.95)',
                        titleColor: textBold,
                        bodyColor: textColor,
                        borderColor: gridColor,
                        borderWidth: 1,
                        padding: 12,
                        boxPadding: 6,
                        usePointStyle: true,
                        cornerRadius: 8,
                        titleFont: { family: "'Inter', sans-serif", size: 13, weight: 'bold' },
                        bodyFont: { family: "'Inter', sans-serif", size: 12 }
                    }
                }
            };

            // Daily Chart Data
            const dailyLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyUsage.Select(d => d.FormattedDate)));
            const dailyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyUsage.Select(d => d.QueryCount)));

            const dailyCtx = document.getElementById('dailyChart');
            if (dailyCtx) {
                new Chart(dailyCtx, {
                    type: 'bar',
                    data: {
                        labels: dailyLabels,
                        datasets: [{
                            label: 'Lượt hỏi',
                            data: dailyData,
                            backgroundColor: 'rgba(79, 70, 229, 0.8)',
                            hoverBackgroundColor: 'rgba(79, 70, 229, 1)',
                            borderRadius: 6,
                            borderSkipped: false
                        }]
                    },
                    options: {
                        ...commonOptions,
                        scales: {
                            y: { beginAtZero: true, grid: { color: gridColor, drawBorder: false }, ticks: { color: textColor, precision: 0 } },
                            x: { grid: { display: false, drawBorder: false }, ticks: { color: textColor } }
                        }
                    }
                });
            }

            // Docs Chart Data
            const docLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopDocuments.Select(d => d.DocumentName)));
            const docData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopDocuments.Select(d => d.CitationCount)));

            const docsCtx = document.getElementById('docsChart');
            if (docsCtx) {
                new Chart(docsCtx, {
                    type: 'doughnut',
                    data: {
                        labels: docLabels,
                        datasets: [{
                            data: docData,
                            backgroundColor: [
                                accentStrong, cyan, '#10b981', '#f59e0b', '#8b5cf6', '#ec4899'
                            ],
                            borderWidth: 2,
                            borderColor: '#ffffff',
                            hoverOffset: 4
                        }]
                    },
                    options: {
                        ...commonOptions,
                        cutout: '65%',
                        plugins: {
                            legend: {
                                display: true,
                                position: 'right',
                                labels: { boxWidth: 12, usePointStyle: true, padding: 16 }
                            },
                            tooltip: commonOptions.plugins.tooltip
                        }
                    }
                });
            }
        });
    </script>
}
