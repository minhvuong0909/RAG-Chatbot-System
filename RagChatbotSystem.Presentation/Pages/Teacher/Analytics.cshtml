@page
@model RagChatbotSystem.Presentation.Pages.Teacher.AnalyticsModel
@{
    ViewData["Title"] = "Learning Analytics";
}

<section class="admin-page teacher-analytics-page prem-fade-in">
    <header class="admin-page-header" style="background: var(--surface-muted); padding: 24px; border-radius: var(--prem-radius-lg); margin-bottom: 24px; border: 1px solid var(--line);">
        <div>
            <p class="eyebrow" style="color: var(--accent); letter-spacing: 2px;">TEACHING WORKSPACE</p>
            <h1 style="font-size: 1.8rem; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 8px;">Learning Analytics</h1>
            <p class="helper-text" style="font-size: 0.95rem;">Track learning activity and engagement inside the subjects assigned to you.</p>
        </div>
    </header>

    @if (Model.AssignedSubjects.Count == 0)
    {
        <section class="admin-section">
            <div class="empty-state prem-card" style="padding: 64px 24px; text-align: center;">
                <h2 style="font-weight: 800; color: var(--ink);">No assigned subjects</h2>
                <p class="text-muted" style="max-width: 400px; margin: 0 auto;">Ask an admin to assign you to a subject before learning analytics can be shown.</p>
            </div>
        </section>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px; margin-bottom: 32px;">
            <div class="prem-card prem-stat-card">
                <div class="prem-stat-icon primary">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path><path d="M6 6h10"></path><path d="M6 10h10"></path></svg>
                </div>
                <div>
                    <div class="prem-stat-label">Assigned Subjects</div>
                    <div class="prem-stat-value">@Model.AssignedSubjects.Count.ToString("N0")</div>
                </div>
            </div>
            <div class="prem-card prem-stat-card">
                <div class="prem-stat-icon secondary">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                </div>
                <div>
                    <div class="prem-stat-label">Total Questions</div>
                    <div class="prem-stat-value">@Model.Summary.TotalQueriesCount.ToString("N0")</div>
                </div>
            </div>
            <div class="prem-card prem-stat-card">
                <div class="prem-stat-icon warning">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                </div>
                <div>
                    <div class="prem-stat-label">Active Students</div>
                    <div class="prem-stat-value">@Model.ActiveStudentsCount.ToString("N0")</div>
                </div>
            </div>
            <div class="prem-card prem-stat-card">
                <div class="prem-stat-icon success">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </div>
                <div>
                    <div class="prem-stat-label">Top Cited Docs</div>
                    <div class="prem-stat-value">@Model.TopDocuments.Count.ToString("N0")</div>
                </div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: minmax(0, 3fr) minmax(320px, 2fr); gap: 24px; margin-bottom: 32px;">
            <div class="prem-card" style="padding: 24px;">
                <div style="margin-bottom: 16px;">
                    <h2 style="font-size: 1.15rem; font-weight: 800; color: var(--ink); margin: 0;">Daily Questions</h2>
                    <p style="color: var(--muted); font-size: 0.85rem; margin: 4px 0 0 0;">Interaction volume over the past 7 days</p>
                </div>
                <div class="prem-chart-container" style="border: none; box-shadow: none; padding: 0;">
                    <canvas id="dailyChart"></canvas>
                </div>
            </div>

            <div class="prem-card" style="padding: 24px;">
                <div style="margin-bottom: 16px;">
                    <h2 style="font-size: 1.15rem; font-weight: 800; color: var(--ink); margin: 0;">Top Cited Documents</h2>
                    <p style="color: var(--muted); font-size: 0.85rem; margin: 4px 0 0 0;">Most used evidence in answers</p>
                </div>
                <div class="prem-chart-container" style="border: none; box-shadow: none; padding: 0;">
                    <canvas id="docsChart"></canvas>
                </div>
            </div>
        </div>

        <div class="prem-card" style="margin-bottom: 32px; padding: 24px;">
            <div style="margin-bottom: 20px;">
                <h2 style="font-size: 1.25rem; font-weight: 800; color: var(--ink); margin: 0;">Subject Activity</h2>
                <p style="color: var(--muted); font-size: 0.9rem; margin: 4px 0 0 0;">Questions and active students by assigned subject</p>
            </div>
            <div class="prem-table-container">
                <table class="prem-table">
                    <thead>
                        <tr>
                            <th>Subject</th>
                            <th>Active Students</th>
                            <th style="text-align: right;">Questions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.TopSubjects.Count == 0)
                        {
                            <tr>
                                <td colspan="3" style="text-align: center; color: var(--muted); padding: 32px;">No subject activity has been recorded yet.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var subject in Model.TopSubjects)
                            {
                                <tr>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: 12px;">
                                            <div style="width: 36px; height: 36px; border-radius: 8px; background: var(--accent-soft); color: var(--accent-strong); display: flex; align-items: center; justify-content: center; font-weight: 800;">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path><path d="M6 6h10"></path><path d="M6 10h10"></path></svg>
                                            </div>
                                            <strong style="color: var(--ink);">@subject.DatasetName</strong>
                                        </div>
                                    </td>
                                    <td><span style="font-weight: 600; color: var(--ink-soft);">@subject.ActiveUsersCount.ToString("N0")</span></td>
                                    <td style="text-align: right;"><strong style="color: var(--accent-strong); font-size: 1.1rem;">@subject.TotalQueriesCount.ToString("N0")</strong></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="prem-card" style="padding: 24px;">
            <div style="margin-bottom: 20px;">
                <h2 style="font-size: 1.25rem; font-weight: 800; color: var(--ink); margin: 0;">Student Engagement</h2>
                <p style="color: var(--muted); font-size: 0.9rem; margin: 4px 0 0 0;">Top students by question count in your assigned subjects</p>
            </div>
            <div class="prem-table-container">
                <table class="prem-table">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>Student</th>
                            <th style="text-align: right;">Questions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.StudentEngagement.Count == 0)
                        {
                            <tr>
                                <td colspan="3" style="text-align: center; color: var(--muted); padding: 32px;">No student activity has been recorded yet.</td>
                            </tr>
                        }
                        else
                        {
                            var rank = 1;
                            @foreach (var student in Model.StudentEngagement)
                            {
                                <tr>
                                    <td><span class="prem-rank">#@rank</span></td>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: 12px;">
                                            <div class="prem-avatar">@student.FullName.Substring(0, Math.Min(2, student.FullName.Length)).ToUpper()</div>
                                            <div>
                                                <div style="font-weight: 700; color: var(--ink);">@student.FullName</div>
                                                <div style="font-size: 0.8rem; color: var(--muted);">@student.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td style="text-align: right;"><strong style="color: var(--accent-strong); font-size: 1.1rem;">@student.TotalQueriesCount.ToString("N0")</strong></td>
                                </tr>
                                rank++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Chart Defaults
            Chart.defaults.font.family = '"Inter", "Segoe UI", sans-serif';
            Chart.defaults.color = '#64748b';

            // Daily Chart Data
            const dailyLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyUsage.Select(d => d.FormattedDate)));
            const dailyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyUsage.Select(d => d.QueryCount)));

            if (document.getElementById('dailyChart')) {
                new Chart(document.getElementById('dailyChart'), {
                    type: 'bar',
                    data: {
                        labels: dailyLabels,
                        datasets: [{
                            label: 'Questions',
                            data: dailyData,
                            backgroundColor: 'rgba(79, 70, 229, 0.8)',
                            hoverBackgroundColor: 'rgba(79, 70, 229, 1)',
                            borderRadius: 6,
                            borderSkipped: false
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: 'rgba(15, 23, 42, 0.9)',
                                padding: 12,
                                titleFont: { size: 13, weight: 'bold' },
                                bodyFont: { size: 14, weight: 'bold' },
                                cornerRadius: 8,
                                displayColors: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(0, 0, 0, 0.05)', drawBorder: false },
                                ticks: { precision: 0 }
                            },
                            x: {
                                grid: { display: false, drawBorder: false }
                            }
                        }
                    }
                });
            }

            // Docs Chart Data
            const docLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopDocuments.Select(d => d.DocumentName)));
            const docData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopDocuments.Select(d => d.CitationCount)));

            if (document.getElementById('docsChart')) {
                new Chart(document.getElementById('docsChart'), {
                    type: 'doughnut',
                    data: {
                        labels: docLabels,
                        datasets: [{
                            data: docData,
                            backgroundColor: [
                                '#4f46e5',
                                '#06b6d4',
                                '#10b981',
                                '#f59e0b',
                                '#8b5cf6',
                                '#ec4899'
                            ],
                            borderWidth: 2,
                            borderColor: '#ffffff',
                            hoverOffset: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '65%',
                        plugins: {
                            legend: {
                                position: 'right',
                                labels: { boxWidth: 12, usePointStyle: true, padding: 16 }
                            },
                            tooltip: {
                                backgroundColor: 'rgba(15, 23, 42, 0.9)',
                                padding: 12,
                                cornerRadius: 8,
                                bodyFont: { size: 14, weight: 'bold' }
                            }
                        }
                    }
                });
            }
        });
    </script>
}
