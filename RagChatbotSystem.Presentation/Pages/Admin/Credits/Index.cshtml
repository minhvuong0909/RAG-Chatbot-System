@page
@using System.Globalization
@using RagChatbotSystem.Business.DTOs
@using RagChatbotSystem.DataAccess.Models
@model RagChatbotSystem.Presentation.Pages.Admin.Credits.IndexModel
@{
    ViewData["Title"] = "Quản lý Credit";
    var vietnameseCulture = CultureInfo.GetCultureInfo("vi-VN");
    var packagesById = Model.Packages.ToDictionary(package => package.Id);

    string FormatCurrency(decimal amount, string currency) =>
        string.Equals(currency, "VND", StringComparison.OrdinalIgnoreCase)
            ? $"{amount.ToString("N0", vietnameseCulture)} ₫"
            : $"{amount.ToString("N0", vietnameseCulture)} {currency}";

    string LedgerTypeLabel(CreditLedgerType type) => type switch
    {
        CreditLedgerType.DAILY_RESET => "Đặt lại hằng ngày",
        CreditLedgerType.FREE_GRANT => "Tặng miễn phí",
        CreditLedgerType.PURCHASE => "Nạp Credit",
        CreditLedgerType.ADMIN_GRANT => "Cấp Credit",
        CreditLedgerType.ADJUSTMENT => "Điều chỉnh",
        CreditLedgerType.SPEND => "Sử dụng",
        CreditLedgerType.REFUND => "Hoàn Credit",
        CreditLedgerType.EXPIRED => "Hết hạn",
        _ => type.ToString()
    };

    string LedgerTypeColor(CreditLedgerType type) => type switch
    {
        CreditLedgerType.DAILY_RESET => "bg-blue-50 text-blue-700 border-blue-200",
        CreditLedgerType.FREE_GRANT => "bg-green-50 text-green-700 border-green-200",
        CreditLedgerType.PURCHASE => "bg-teal-50 text-teal-700 border-teal-200",
        CreditLedgerType.ADMIN_GRANT => "bg-indigo-50 text-indigo-700 border-indigo-200",
        CreditLedgerType.ADJUSTMENT => "bg-amber-50 text-amber-700 border-amber-200",
        CreditLedgerType.SPEND => "bg-gray-100 text-gray-600 border-gray-200",
        CreditLedgerType.REFUND => "bg-purple-50 text-purple-700 border-purple-200",
        CreditLedgerType.EXPIRED => "bg-red-50 text-red-700 border-red-200",
        _ => "bg-gray-100 text-gray-600 border-gray-200"
    };

    string PurchaseStatusLabel(CreditPurchaseStatus status) => status switch
    {
        CreditPurchaseStatus.PENDING => "Đang chờ",
        CreditPurchaseStatus.COMPLETED => "Hoàn tất",
        CreditPurchaseStatus.FAILED => "Thất bại",
        CreditPurchaseStatus.CANCELLED => "Đã hủy",
        CreditPurchaseStatus.REFUNDED => "Đã hoàn",
        _ => status.ToString()
    };
    
    string PurchaseStatusColor(CreditPurchaseStatus status) => status switch
    {
        CreditPurchaseStatus.PENDING => "bg-amber-50 text-amber-700 border-amber-200",
        CreditPurchaseStatus.COMPLETED => "bg-green-50 text-green-700 border-green-200",
        CreditPurchaseStatus.FAILED => "bg-red-50 text-red-700 border-red-200",
        CreditPurchaseStatus.CANCELLED => "bg-gray-100 text-gray-600 border-gray-200",
        CreditPurchaseStatus.REFUNDED => "bg-purple-50 text-purple-700 border-purple-200",
        _ => "bg-gray-100 text-gray-600 border-gray-200"
    };

    string PackageLabel(CreditPurchaseDto purchase) =>
        purchase.PackageId.HasValue && packagesById.TryGetValue(purchase.PackageId.Value, out var package)
            ? PackageDisplayName(package)
            : "Nạp thủ công";

    string PackageDisplayName(CreditPackageDto package) => package.Name switch
    {
        "Study Lite" => "Gói học cơ bản",
        "Study Plus" => "Gói nâng cao",
        "Exam Boost" => "Gói ôn thi",
        "Final Sprint" => "Gói nước rút",
        _ => package.Name
    };

    string UserLabel(Guid? userId) =>
        userId.HasValue && Model.UserNames.TryGetValue(userId.Value, out var userName)
            ? userName
            : "Hệ thống";

    int TotalBalanceBefore(CreditLedgerDto entry) =>
        entry.BalanceAfterFree + entry.BalanceAfterPaid
        - entry.FreeCreditsAdded - entry.PaidCreditsAdded
        + entry.FreeCreditsUsed + entry.PaidCreditsUsed;

    string LedgerNote(CreditLedgerDto entry) =>
        entry.Type == CreditLedgerType.DAILY_RESET && string.Equals(entry.Note, "Initial daily free credit reset.", StringComparison.Ordinal)
            ? "Credit miễn phí đặt lại hằng ngày"
            : entry.Note ?? "-";
}

<div class="space-y-6" data-admin-page>
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white/60 backdrop-blur-xl border border-white shadow-sm p-6 rounded-2xl">
        <div>
            <p class="text-xs font-bold text-accent-strong tracking-wider uppercase mb-1">Quản trị</p>
            <h1 class="text-2xl font-grotesk font-extrabold text-ink tracking-tight">Quản lý Credit</h1>
            <p class="text-sm text-gray-500 mt-1">Theo dõi số dư sinh viên và ghi nhận nạp, tặng hoặc điều chỉnh Credit thủ công.</p>
        </div>
    </div>

    <!-- Tabs -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-2">
        <partial name="_AdminTabs" />
    </div>

    <!-- Alerts -->
    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="p-4 rounded-xl bg-green-50 border border-green-100 flex items-start gap-3 relative">
            <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <div class="flex-1"><p class="text-sm font-medium text-green-800">@Model.SuccessMessage</p></div>
            <button type="button" class="absolute top-4 right-4 text-green-400 hover:text-green-600" onclick="this.parentElement.remove();"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="p-4 rounded-xl bg-red-50 border border-red-100 flex items-start gap-3 relative">
            <svg class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            <div class="flex-1"><p class="text-sm font-medium text-red-800">@Model.ErrorMessage</p></div>
            <button type="button" class="absolute top-4 right-4 text-red-400 hover:text-red-600" onclick="this.parentElement.remove();"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>
    }

    <!-- Student Selection -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
            <svg class="w-24 h-24 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
        </div>
        
        <div class="mb-5 relative z-10">
            <p class="text-xs font-bold text-gray-400 tracking-wider uppercase">Sinh viên</p>
            <h2 class="text-lg font-bold text-ink mt-1">Chọn sinh viên</h2>
            <p class="text-sm text-gray-500 mt-1">Tìm theo họ tên hoặc email, sau đó xem và điều chỉnh số dư.</p>
        </div>

        @if (Model.Students.Any())
        {
            <form method="get" class="flex flex-col md:flex-row items-end gap-4 relative z-10">
                <div class="w-full md:w-1/3">
                    <label for="studentSearch" class="block text-sm font-bold text-gray-700 mb-1.5">Tìm kiếm</label>
                    <input id="studentSearch" type="search" placeholder="Nhập họ tên hoặc email..." autocomplete="off" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-2.5 border" />
                </div>
                <div class="w-full md:w-1/2">
                    <label for="studentSelect" class="block text-sm font-bold text-gray-700 mb-1.5">Sinh viên</label>
                    <select id="studentSelect" name="userId" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-2.5 border bg-gray-50">
                        @foreach (var student in Model.Students)
                        {
                            <option value="@student.UserId" selected="@(Model.SelectedUserId == student.UserId)">@student.FullName (@student.Email)</option>
                        }
                    </select>
                </div>
                <button type="submit" class="w-full md:w-auto inline-flex justify-center items-center px-6 py-2.5 border border-transparent text-sm font-bold rounded-xl text-white bg-accent-strong hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors shadow-sm">
                    Xem số dư
                </button>
            </form>
        }
        else
        {
            <div class="border border-dashed border-gray-300 rounded-xl p-8 text-center relative z-10">
                <strong class="text-ink">Chưa có sinh viên để quản lý</strong>
                <p class="text-sm text-gray-500 mt-1">Danh sách sinh viên sẽ xuất hiện tại đây khi tài khoản sinh viên được tạo.</p>
            </div>
        }
    </div>

    @if (Model.SelectedBalance != null)
    {
        <!-- Balances Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="bg-gradient-to-br from-indigo-600 to-indigo-800 rounded-2xl shadow-sm p-6 text-white relative overflow-hidden group">
                <div class="absolute -right-4 -top-4 w-24 h-24 bg-white/10 rounded-full blur-xl group-hover:bg-white/20 transition-colors"></div>
                <p class="text-sm font-medium text-indigo-100 mb-1 relative z-10">Tổng số dư</p>
                <p class="text-3xl font-bold relative z-10">@Model.SelectedBalance.TotalCredits.ToString("N0", vietnameseCulture)</p>
                <p class="text-xs text-indigo-200 mt-2 relative z-10">Credit hiện có thể sử dụng</p>
            </div>
            
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 hover:-translate-y-1 transition-transform">
                <p class="text-sm font-bold text-gray-500 mb-1">Credit miễn phí</p>
                <p class="text-2xl font-bold text-ink">@Model.SelectedBalance.FreeCredits.ToString("N0", vietnameseCulture)</p>
                <p class="text-xs text-gray-400 mt-1">Được ưu tiên sử dụng trước</p>
            </div>

            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 hover:-translate-y-1 transition-transform">
                <p class="text-sm font-bold text-gray-500 mb-1">Credit đã mua</p>
                <p class="text-2xl font-bold text-ink">@Model.SelectedBalance.PaidCredits.ToString("N0", vietnameseCulture)</p>
                <p class="text-xs text-gray-400 mt-1">Được ghi nhận từ nạp thủ công</p>
            </div>

            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 hover:-translate-y-1 transition-transform">
                <p class="text-sm font-bold text-gray-500 mb-1">Credit miễn phí mỗi ngày</p>
                <p class="text-2xl font-bold text-ink">@Model.SelectedBalance.Settings.DailyFreeCredits.ToString("N0", vietnameseCulture)</p>
                <p class="text-xs text-gray-400 mt-1">Đặt lại theo ngày Việt Nam</p>
            </div>
        </div>

        <!-- Action Forms -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- TopUp Paid Credits -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden flex flex-col">
                <div class="px-6 py-5 border-b border-gray-50 bg-gradient-to-r from-teal-50/50 to-white">
                    <h2 class="text-lg font-bold text-ink flex items-center gap-2">
                        <span class="w-8 h-8 rounded-lg bg-teal-50 text-teal-600 flex items-center justify-center">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
                        </span>
                        Nạp Credit đã mua
                    </h2>
                    <p class="text-xs text-gray-500 mt-1 ml-10">Ghi nhận nạp thủ công, không xử lý thanh toán trực tuyến.</p>
                </div>
                <div class="p-6 flex-1">
                    <form method="post" asp-page-handler="TopUp" class="flex flex-col gap-4 h-full">
                        <input type="hidden" asp-for="Input.UserId" value="@Model.SelectedBalance.UserId" />
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label asp-for="Input.PaidCredits" class="block text-sm font-bold text-gray-700 mb-1">Credit đã mua <span class="text-red-500">*</span></label>
                                <input asp-for="Input.PaidCredits" type="number" min="1" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-2 border" />
                            </div>
                            <div>
                                <label asp-for="Input.Amount" class="block text-sm font-bold text-gray-700 mb-1">Số tiền (VND) <span class="text-red-500">*</span></label>
                                <input asp-for="Input.Amount" type="number" min="0" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-2 border" />
                            </div>
                        </div>
                        <div class="flex-1">
                            <label asp-for="Input.Note" class="block text-sm font-bold text-gray-700 mb-1">Lý do nạp <span class="text-red-500">*</span></label>
                            <input asp-for="Input.Note" required maxlength="500" placeholder="Ví dụ: Nạp tiền mặt" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-2 border" />
                        </div>
                        <button type="submit" class="w-full inline-flex justify-center items-center px-4 py-2.5 border border-transparent text-sm font-bold rounded-xl text-white bg-teal-600 hover:bg-teal-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500 transition-colors shadow-sm mt-auto">
                            Cộng Credit đã mua
                        </button>
                    </form>
                </div>
            </div>

            <!-- Grant Free Credits -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden flex flex-col">
                <div class="px-6 py-5 border-b border-gray-50 bg-gradient-to-r from-blue-50/50 to-white">
                    <h2 class="text-lg font-bold text-ink flex items-center gap-2">
                        <span class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"></path></svg>
                        </span>
                        Tặng Credit miễn phí
                    </h2>
                    <p class="text-xs text-gray-500 mt-1 ml-10">Thao tác này luôn được ghi vào lịch sử giao dịch.</p>
                </div>
                <div class="p-6 flex-1">
                    <form method="post" asp-page-handler="GrantFree" class="flex flex-col gap-4 h-full">
                        <input type="hidden" asp-for="Input.UserId" value="@Model.SelectedBalance.UserId" />
                        <div>
                            <label asp-for="Input.FreeCredits" class="block text-sm font-bold text-gray-700 mb-1">Số lượng tặng <span class="text-red-500">*</span></label>
                            <input asp-for="Input.FreeCredits" type="number" min="1" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-2 border" />
                        </div>
                        <div class="flex-1">
                            <label asp-for="Input.Note" class="block text-sm font-bold text-gray-700 mb-1">Lý do tặng <span class="text-red-500">*</span></label>
                            <input asp-for="Input.Note" required maxlength="500" placeholder="Ví dụ: Thưởng thành tích" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-2 border" />
                        </div>
                        <button type="submit" class="w-full inline-flex justify-center items-center px-4 py-2.5 border border-indigo-200 text-sm font-bold rounded-xl text-indigo-700 bg-indigo-50 hover:bg-indigo-100 hover:border-indigo-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors shadow-sm mt-auto">
                            Tặng Credit miễn phí
                        </button>
                    </form>
                </div>
            </div>

            <!-- Adjust Credits -->
            <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden flex flex-col">
                <div class="px-6 py-5 border-b border-gray-50 bg-gradient-to-r from-amber-50/50 to-white">
                    <h2 class="text-lg font-bold text-ink flex items-center gap-2">
                        <span class="w-8 h-8 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        </span>
                        Điều chỉnh số dư
                    </h2>
                    <p class="text-xs text-gray-500 mt-1 ml-10">Nhập số âm để giảm Credit. Hệ thống yêu cầu xác nhận trước khi giảm.</p>
                </div>
                <div class="p-6">
                    <form method="post" asp-page-handler="Adjust" class="flex flex-col md:flex-row gap-4" data-credit-adjustment-form>
                        <input type="hidden" asp-for="Input.UserId" value="@Model.SelectedBalance.UserId" />
                        <div class="w-full md:w-1/4">
                            <label asp-for="Input.FreeCreditsDelta" class="block text-sm font-bold text-gray-700 mb-1">Miễn phí (±)</label>
                            <input asp-for="Input.FreeCreditsDelta" type="number" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-amber-500 focus:ring-amber-500 sm:text-sm px-4 py-2 border" />
                        </div>
                        <div class="w-full md:w-1/4">
                            <label asp-for="Input.PaidCreditsDelta" class="block text-sm font-bold text-gray-700 mb-1">Đã mua (±)</label>
                            <input asp-for="Input.PaidCreditsDelta" type="number" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-amber-500 focus:ring-amber-500 sm:text-sm px-4 py-2 border" />
                        </div>
                        <div class="w-full md:w-1/3">
                            <label asp-for="Input.Note" class="block text-sm font-bold text-gray-700 mb-1">Lý do <span class="text-red-500">*</span></label>
                            <input asp-for="Input.Note" required maxlength="500" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-amber-500 focus:ring-amber-500 sm:text-sm px-4 py-2 border" />
                        </div>
                        <div class="w-full md:w-auto flex items-end">
                            <button type="submit" class="w-full md:w-auto inline-flex justify-center items-center px-4 py-2.5 border border-amber-200 text-sm font-bold rounded-xl text-amber-700 bg-amber-50 hover:bg-amber-100 hover:border-amber-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500 transition-colors shadow-sm whitespace-nowrap">
                                Áp dụng
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- History Section -->
        <section class="mt-8" aria-label="Lịch sử hoạt động">
            <div class="mb-4">
                <p class="text-xs font-bold text-gray-400 tracking-wider uppercase">Lịch sử hoạt động</p>
                <h2 class="text-xl font-bold text-ink mt-1">Chi tiết biến động và đơn hàng</h2>
                <p class="text-sm text-gray-500 mt-1">Theo dõi sự thay đổi của số dư Credit và trạng thái các đơn nạp tiền của sinh viên.</p>
            </div>

            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="flex border-b border-gray-100 bg-gray-50/50 px-2 pt-2">
                    <button id="tab-ledger" class="px-6 py-3 text-sm font-bold text-accent-strong border-b-2 border-accent-strong bg-white rounded-t-lg transition-colors focus:outline-none" onclick="switchTab('ledger')">Biến động số dư</button>
                    <button id="tab-purchase" class="px-6 py-3 text-sm font-bold text-gray-500 border-b-2 border-transparent hover:text-ink hover:bg-gray-100 rounded-t-lg transition-colors focus:outline-none" onclick="switchTab('purchase')">Đơn hàng nạp</button>
                </div>

                <!-- Ledger Tab Content -->
                <div id="content-ledger" class="block">
                    @if (Model.Ledger.Any())
                    {
                        <div class="overflow-x-auto h-[430px] custom-scrollbar">
                            <table class="w-full text-left border-collapse">
                                <thead class="sticky top-0 bg-white shadow-sm z-10">
                                    <tr class="border-b border-gray-100">
                                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider whitespace-nowrap">Thời gian</th>
                                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Loại giao dịch</th>
                                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Đã cộng</th>
                                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Đã dùng</th>
                                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider text-center">Trước / Sau</th>
                                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider w-1/3">Ghi chú</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    @foreach (var entry in Model.Ledger)
                                    {
                                        <tr class="hover:bg-gray-50/50">
                                            <td class="py-3 px-6 text-sm text-gray-500 whitespace-nowrap">@entry.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="py-3 px-6">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-bold border whitespace-nowrap @LedgerTypeColor(entry.Type)">
                                                    @LedgerTypeLabel(entry.Type)
                                                </span>
                                            </td>
                                            <td class="py-3 px-6 text-sm font-medium text-teal-600 text-right">@((entry.FreeCreditsAdded + entry.PaidCreditsAdded).ToString("N0", vietnameseCulture))</td>
                                            <td class="py-3 px-6 text-sm font-medium text-rose-600 text-right">@((entry.FreeCreditsUsed + entry.PaidCreditsUsed).ToString("N0", vietnameseCulture))</td>
                                            <td class="py-3 px-6 text-sm text-center whitespace-nowrap">
                                                <span class="text-gray-400">@TotalBalanceBefore(entry).ToString("N0", vietnameseCulture)</span>
                                                <span class="mx-1 text-gray-300">→</span>
                                                <strong class="text-ink">@((entry.BalanceAfterFree + entry.BalanceAfterPaid).ToString("N0", vietnameseCulture))</strong>
                                            </td>
                                            <td class="py-3 px-6 text-sm text-gray-500">
                                                <div class="truncate max-w-[250px]" title="@LedgerNote(entry)">@LedgerNote(entry)</div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-12 text-center">
                            <strong class="text-ink text-lg">Chưa có biến động số dư</strong>
                            <p class="text-sm text-gray-500 mt-1">Các lần đặt lại, nạp, cấp hoặc sử dụng Credit sẽ được ghi nhận tại đây.</p>
                        </div>
                    }
                </div>

                <!-- Purchase Tab Content -->
                <div id="content-purchase" class="hidden">
                    @if (Model.Purchases.Any())
                    {
                        <div class="overflow-x-auto h-[430px] custom-scrollbar">
                            <table class="w-full text-left border-collapse">
                                <thead class="sticky top-0 bg-white shadow-sm z-10">
                                    <tr class="border-b border-gray-100">
                                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider whitespace-nowrap">Thời gian</th>
                                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Gói Credit</th>
                                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Tổng cộng</th>
                                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Giá</th>
                                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Trạng thái</th>
                                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Người thực hiện</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    @foreach (var purchase in Model.Purchases)
                                    {
                                        <tr class="hover:bg-gray-50/50">
                                            <td class="py-3 px-6 text-sm text-gray-500 whitespace-nowrap">@purchase.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="py-3 px-6 text-sm font-medium text-ink">@PackageLabel(purchase)</td>
                                            <td class="py-3 px-6 text-sm font-bold text-teal-600 text-right">@purchase.TotalCredits.ToString("N0", vietnameseCulture)</td>
                                            <td class="py-3 px-6 text-sm text-gray-700 text-right whitespace-nowrap">@FormatCurrency(purchase.Amount, purchase.Currency)</td>
                                            <td class="py-3 px-6">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-bold border whitespace-nowrap @PurchaseStatusColor(purchase.Status)">
                                                    @PurchaseStatusLabel(purchase.Status)
                                                </span>
                                            </td>
                                            <td class="py-3 px-6 text-sm text-gray-500 truncate max-w-[150px]" title="@UserLabel(purchase.CreatedByUserId)">@UserLabel(purchase.CreatedByUserId)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-12 text-center">
                            <strong class="text-ink text-lg">Chưa có lịch sử nạp Credit</strong>
                            <p class="text-sm text-gray-500 mt-1">Các lần nạp Credit thủ công hoặc trực tuyến sẽ xuất hiện tại đây.</p>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
</div>

@section Scripts {
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
    <script>
        function switchTab(tabId) {
            // Update tabs UI
            document.getElementById('tab-ledger').className = "px-6 py-3 text-sm font-bold text-gray-500 border-b-2 border-transparent hover:text-ink hover:bg-gray-100 rounded-t-lg transition-colors focus:outline-none";
            document.getElementById('tab-purchase').className = "px-6 py-3 text-sm font-bold text-gray-500 border-b-2 border-transparent hover:text-ink hover:bg-gray-100 rounded-t-lg transition-colors focus:outline-none";
            
            const activeTab = document.getElementById('tab-' + tabId);
            activeTab.className = "px-6 py-3 text-sm font-bold text-accent-strong border-b-2 border-accent-strong bg-white rounded-t-lg transition-colors focus:outline-none";

            // Update content visibility
            document.getElementById('content-ledger').classList.add('hidden');
            document.getElementById('content-ledger').classList.remove('block');
            document.getElementById('content-purchase').classList.add('hidden');
            document.getElementById('content-purchase').classList.remove('block');

            document.getElementById('content-' + tabId).classList.remove('hidden');
            document.getElementById('content-' + tabId).classList.add('block');
        }

        (() => {
            const searchInput = document.getElementById('studentSearch');
            const studentSelect = document.getElementById('studentSelect');

            searchInput?.addEventListener('input', () => {
                const query = searchInput.value.trim().toLocaleLowerCase('vi-VN');
                Array.from(studentSelect.options).forEach((option) => {
                    option.hidden = query.length > 0 && !option.text.toLocaleLowerCase('vi-VN').includes(query);
                });
            });

            document.querySelectorAll('[data-credit-adjustment-form]').forEach((form) => {
                form.addEventListener('submit', (event) => {
                    const freeDelta = Number(form.querySelector('[name="Input.FreeCreditsDelta"]')?.value || 0);
                    const paidDelta = Number(form.querySelector('[name="Input.PaidCreditsDelta"]')?.value || 0);
                    if ((freeDelta < 0 || paidDelta < 0) && !window.confirm('Bạn đang giảm Credit của sinh viên. Bạn có muốn tiếp tục?')) {
                        event.preventDefault();
                    }
                });
            });
        })();
    </script>
}
