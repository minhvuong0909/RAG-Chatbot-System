@page "{id:Guid}"
@model RagChatbotSystem.Presentation.Pages.Admin.PermissionsModel
@{
    ViewData["Title"] = "Quản lý quyền môn học";
}

<div class="container py-4">
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title fw-bold text-dark">Quản Lý Quyền Môn Học</h2>
            <p class="text-muted m-0 mt-1">Cấp hoặc thu hồi quyền truy cập cho môn học: <strong class="text-primary">@Model.Dataset.Name</strong></p>
        </div>
        <a asp-page="/Admin/Index" class="btn btn-outline-secondary">
            Quay lại Dashboard
        </a>
    </div>

    <div class="row g-4">
        <!-- Cấp quyền truy cập -->
        <div class="col-md-5">
            <div class="card border-0 h-100 shadow-sm" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold m-0" style="color: var(--ink);">Cấp Quyền Mới</h5>
                    <p class="text-muted small m-0 mt-1">Chọn sinh viên để cấp quyền truy vấn tài liệu trong môn học này.</p>
                </div>
                <div class="card-body px-4 pb-4">
                    @if (Model.Dataset.IsPublic)
                    {
                        <div class="alert alert-warning mb-3" style="border-radius: var(--radius-sm); font-size: 0.85rem;">
                            <strong>Lưu ý:</strong> Môn học này đang được đặt ở chế độ <strong>Công khai</strong>. Tất cả tài khoản được duyệt đều có quyền truy vấn mà không cần cấp quyền thủ công.
                        </div>
                    }

                    <form method="post" asp-page-handler="GrantPermission" class="mt-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="datasetId" value="@Model.Dataset.DatasetId" />

                        <div class="mb-4">
                            <label for="userId" class="form-label mb-2 fw-semibold text-secondary" style="font-size: 0.85rem;">Chọn người dùng</label>
                            <select id="userId" name="userId" required class="form-select" @(Model.Dataset.IsPublic || !Model.AvailableUsers.Any() ? "disabled" : "") style="border-radius: var(--radius-sm);">
                                @if (!Model.AvailableUsers.Any())
                                {
                                    <option value="">Không có người dùng nào khác</option>
                                }
                                else
                                {
                                    <option value="">-- Chọn sinh viên/giảng viên --</option>
                                    foreach (var u in Model.AvailableUsers)
                                    {
                                        <option value="@u.UserId">@u.FullName (@u.Email) - @u.Role</option>
                                    }
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-bold" @(Model.Dataset.IsPublic || !Model.AvailableUsers.Any() ? "disabled" : "") style="border-radius: var(--radius-sm);">
                            Cấp Quyền Truy Cập
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Danh sách những người có quyền truy cập -->
        <div class="col-md-7">
            <div class="card border-0 h-100 shadow-sm" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold m-0" style="color: var(--ink);">Danh Sách Được Cấp Quyền</h5>
                    <p class="text-muted small m-0 mt-1">Dưới đây là các tài khoản đang có quyền truy vấn môn học riêng tư này.</p>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle" style="color: var(--ink);">
                            <thead>
                                <tr class="text-secondary small fw-bold" style="border-bottom: 2px solid var(--line);">
                                    <th>Người dùng</th>
                                    <th>Vai trò</th>
                                    <th class="text-end">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.PermittedUsers.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted py-4">Chưa có ai được cấp quyền truy cập riêng lẻ.</td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var u in Model.PermittedUsers)
                                    {
                                        <tr style="border-bottom: 1px solid var(--line);">
                                            <td>
                                                <div class="fw-bold text-dark">@u.FullName</div>
                                                <div class="text-muted small" style="font-size: 0.8rem;">@u.Email</div>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border">@u.Role</span>
                                            </td>
                                            <td class="text-end">
                                                <form method="post" asp-page-handler="RevokePermission" style="display:inline;" class="m-0">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="datasetId" value="@Model.Dataset.DatasetId" />
                                                    <input type="hidden" name="userId" value="@u.UserId" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm px-3 fw-bold" onclick="return confirm('Bạn có chắc chắn muốn thu hồi quyền truy cập này?')">
                                                        Thu hồi
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
