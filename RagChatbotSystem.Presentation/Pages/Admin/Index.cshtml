@page
@model RagChatbotSystem.Presentation.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Tổng quan quản trị";
}

<div class="space-y-6" data-admin-page>
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white/60 backdrop-blur-xl border border-white shadow-sm p-6 rounded-2xl">
        <div>
            <p class="text-xs font-bold text-accent-strong tracking-wider uppercase mb-1">Quản trị</p>
            <h1 class="text-2xl font-grotesk font-extrabold text-ink tracking-tight">Tổng quan hệ thống</h1>
            <p class="text-sm text-gray-500 mt-1">Quản lý người dùng, phân công giảng viên và truy cập môn học.</p>
        </div>
    </div>

    <!-- Tabs -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-2">
        <partial name="_AdminTabs" />
    </div>

    <!-- Alerts -->
    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="p-4 rounded-xl bg-green-50 border border-green-100 flex items-start gap-3 relative">
            <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <div class="flex-1"><p class="text-sm font-medium text-green-800">@Model.SuccessMessage</p></div>
            <button type="button" class="absolute top-4 right-4 text-green-400 hover:text-green-600" onclick="this.parentElement.remove();"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="p-4 rounded-xl bg-red-50 border border-red-100 flex items-start gap-3 relative">
            <svg class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            <div class="flex-1"><p class="text-sm font-medium text-red-800">@Model.ErrorMessage</p></div>
            <button type="button" class="absolute top-4 right-4 text-red-400 hover:text-red-600" onclick="this.parentElement.remove();"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ImportErrors))
    {
        <div class="p-4 rounded-xl bg-amber-50 border border-amber-200 flex items-start gap-3 relative shadow-sm">
            <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            <div class="flex-1">
                <p class="text-sm font-bold text-amber-800">Lỗi Import</p>
                <p class="text-sm text-amber-700 mt-1 whitespace-pre-wrap">@Model.ImportErrors</p>
            </div>
            <button type="button" class="absolute top-4 right-4 text-amber-400 hover:text-amber-600" onclick="this.parentElement.remove();"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>
    }

    <div id="realtimeAdminStatus" class="p-3 rounded-lg bg-blue-50 border border-blue-100 text-blue-800 text-sm font-medium transition-all" hidden></div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 sm:p-6 transition-transform hover:-translate-y-1">
            <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Người dùng</p>
            <p class="text-3xl font-bold text-ink">@Model.Users.Count</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 sm:p-6 transition-transform hover:-translate-y-1">
            <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Giảng viên</p>
            <p class="text-3xl font-bold text-ink">@Model.ApprovedTeachers.Count</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 sm:p-6 transition-transform hover:-translate-y-1">
            <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Phân công</p>
            <p class="text-3xl font-bold text-ink">@Model.Assignments.Count</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 sm:p-6 transition-transform hover:-translate-y-1">
            <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Môn chờ phân công</p>
            <p class="text-3xl font-bold text-accent-strong">@Model.UnassignedDatasets.Count</p>
        </div>
    </div>

    <!-- Management Forms Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Import Students -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden flex flex-col">
            <div class="px-6 py-5 border-b border-gray-50 bg-gradient-to-r from-gray-50/50 to-white">
                <h2 class="text-lg font-bold text-ink flex items-center gap-2">
                    <span class="w-8 h-8 rounded-lg bg-indigo-50 text-accent-strong flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                    </span>
                    Import sinh viên
                </h2>
                <p class="text-xs text-gray-500 mt-2 ml-10">Tệp XLSX cần có cột Email; cột họ tên là tùy chọn. Hệ thống sẽ tự động gửi email thông báo tài khoản.</p>
            </div>
            <div class="p-6 flex-1 flex flex-col">
                <form method="post" asp-page-handler="ImportStudents" enctype="multipart/form-data" class="admin-processing-form flex-1 flex flex-col justify-between">
                    <div class="mb-6">
                        <label asp-for="StudentsFile" class="block text-sm font-bold text-gray-700 mb-2">Tải file Excel lên <span class="text-red-500">*</span></label>
                        <input asp-for="StudentsFile" type="file" accept=".xlsx" required class="block w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-accent-strong hover:file:bg-indigo-100 border border-gray-200 rounded-xl cursor-pointer" />
                    </div>
                    <button type="submit" class="w-full inline-flex justify-center items-center px-4 py-3 border border-transparent text-sm font-bold rounded-xl text-white bg-accent-strong hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors shadow-sm">
                        Import và gửi Email
                    </button>
                </form>
            </div>
        </div>

        <!-- Create Teacher -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden flex flex-col">
            <div class="px-6 py-5 border-b border-gray-50 bg-gradient-to-r from-gray-50/50 to-white">
                <h2 class="text-lg font-bold text-ink flex items-center gap-2">
                    <span class="w-8 h-8 rounded-lg bg-green-50 text-green-600 flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
                    </span>
                    Tạo giảng viên
                </h2>
                <p class="text-xs text-gray-500 mt-2 ml-10">Tạo tài khoản và phân công các môn học ban đầu.</p>
            </div>
            <div class="p-6 flex-1 flex flex-col">
                <form method="post" asp-page-handler="CreateTeacher" class="admin-processing-form flex-1 flex flex-col">
                    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4 bg-red-50 p-3 rounded-lg"></div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label asp-for="TeacherInput.FullName" class="block text-sm font-bold text-gray-700 mb-1.5">Họ và tên <span class="text-red-500">*</span></label>
                            <input asp-for="TeacherInput.FullName" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-2.5 border" placeholder="Nguyễn Văn A" required />
                            <span asp-validation-for="TeacherInput.FullName" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="TeacherInput.Email" class="block text-sm font-bold text-gray-700 mb-1.5">Email <span class="text-red-500">*</span></label>
                            <input asp-for="TeacherInput.Email" type="email" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-2.5 border" placeholder="email@fpt.edu.vn" required />
                            <span asp-validation-for="TeacherInput.Email" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                    </div>
                    
                    <div class="mb-6 flex-1">
                        <label asp-for="TeacherInput.DatasetIds" class="block text-sm font-bold text-gray-700 mb-1.5">Môn học ban đầu</label>
                        <select asp-for="TeacherInput.DatasetIds" multiple size="3" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border p-2 text-gray-700">
                            @foreach (var dataset in Model.UnassignedDatasets)
                            {
                                <option value="@dataset.DatasetId" class="p-2 hover:bg-gray-100 rounded-md cursor-pointer">@dataset.Name</option>
                            }
                        </select>
                        <p class="text-xs text-gray-400 mt-2">Nhấn giữ Ctrl (hoặc Cmd) để chọn nhiều môn học.</p>
                        <span asp-validation-for="TeacherInput.DatasetIds" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    
                    <button type="submit" disabled="@(Model.UnassignedDatasets.Count == 0)" class="w-full inline-flex justify-center items-center px-4 py-3 border border-transparent text-sm font-bold rounded-xl text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed mt-auto">
                        Tạo tài khoản Giảng viên
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Teacher Assignments -->
    <div id="assignments" class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden scroll-mt-24">
        <div class="px-6 py-5 border-b border-gray-50 bg-white flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
                <h2 class="text-lg font-bold text-ink flex items-center gap-2">
                    <span class="w-8 h-8 rounded-lg bg-amber-50 text-amber-500 flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
                    </span>
                    Phân công giảng viên
                </h2>
            </div>
            <span class="px-3 py-1 bg-gray-100 text-gray-600 text-xs font-bold rounded-full">@Model.Assignments.Count phân công</span>
        </div>
        
        <!-- Assignment Form -->
        <div class="p-6 border-b border-gray-50 bg-gray-50/30">
            <form method="post" asp-page-handler="AssignTeacher" asp-fragment="assignments" class="flex flex-col sm:flex-row gap-4 items-end">
                <div class="flex-1 w-full">
                    <label asp-for="AssignmentInput.TeacherId" class="block text-sm font-bold text-gray-700 mb-1.5">Giảng viên <span class="text-red-500">*</span></label>
                    <select asp-for="AssignmentInput.TeacherId" required class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border px-4 py-2.5">
                        <option value="">Chọn giảng viên</option>
                        @foreach (var teacher in Model.ApprovedTeachers)
                        {
                            <option value="@teacher.UserId">@teacher.FullName (@teacher.Email)</option>
                        }
                    </select>
                </div>
                <div class="flex-1 w-full">
                    <label asp-for="AssignmentInput.DatasetId" class="block text-sm font-bold text-gray-700 mb-1.5">Môn học chưa phân công <span class="text-red-500">*</span></label>
                    <select asp-for="AssignmentInput.DatasetId" required class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border px-4 py-2.5">
                        <option value="">Chọn môn học</option>
                        @foreach (var dataset in Model.UnassignedDatasets)
                        {
                            <option value="@dataset.DatasetId">@dataset.Name</option>
                        }
                    </select>
                </div>
                <button type="submit" disabled="@(Model.ApprovedTeachers.Count == 0 || Model.UnassignedDatasets.Count == 0)" class="w-full sm:w-auto inline-flex justify-center items-center px-6 py-2.5 border border-transparent text-sm font-bold rounded-xl text-white bg-accent-strong hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">
                    Phân công
                </button>
            </form>
        </div>

        <!-- Assignment Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50/50 border-b border-gray-100">
                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Giảng viên</th>
                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Môn học</th>
                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Thời gian phân công</th>
                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 bg-white">
                    @if (Model.Assignments.Count == 0)
                    {
                        <tr><td colspan="4" class="py-12 text-center text-sm text-gray-500">Chưa có phân công giảng viên.</td></tr>
                    }
                    @foreach (var assignment in Model.Assignments)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="py-3 px-6">
                                <div class="font-semibold text-ink text-sm">@assignment.TeacherName</div>
                                <div class="text-xs text-gray-500 mt-0.5">@assignment.TeacherEmail</div>
                            </td>
                            <td class="py-3 px-6">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[11px] font-bold border bg-gray-50 border-gray-200 text-gray-700">@assignment.DatasetName</span>
                            </td>
                            <td class="py-3 px-6 text-sm text-gray-500">@assignment.AssignedAt.ToLocalTime().ToString("g")</td>
                            <td class="py-3 px-6 text-right">
                                <form method="post" asp-page-handler="UnassignTeacher" asp-fragment="assignments" class="m-0 inline-block" onsubmit="return confirm('Bạn có chắc muốn gỡ phân công môn học này?');">
                                    <input type="hidden" name="datasetId" value="@assignment.DatasetId" />
                                    <button type="submit" class="inline-flex items-center justify-center px-3 py-1.5 border border-red-200 rounded-lg text-xs font-bold text-red-600 bg-red-50 hover:bg-red-100 hover:border-red-300 transition-colors">
                                        Gỡ phân công
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Users Table -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-50 bg-white flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <h2 class="text-lg font-bold text-ink flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                </span>
                Người dùng hệ thống
            </h2>
            <span class="px-3 py-1 bg-gray-100 text-gray-600 text-xs font-bold rounded-full">@Model.Users.Count người dùng</span>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50/50 border-b border-gray-100">
                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Người dùng</th>
                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Vai trò</th>
                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Thời gian tạo</th>
                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Trạng thái</th>
                        <th class="py-3 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 bg-white">
                    @foreach (var user in Model.Users)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="py-3 px-6">
                                <div class="font-semibold text-ink text-sm">@user.FullName</div>
                                <div class="text-xs text-gray-500 mt-0.5">@user.Email</div>
                            </td>
                            <td class="py-3 px-6">
                                @if (user.Role == "Admin")
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-bold border bg-purple-50 text-purple-700 border-purple-200">Quản trị viên</span>
                                }
                                else if (user.Role == "Teacher")
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-bold border bg-indigo-50 text-accent-strong border-indigo-200">Giảng viên</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-bold border bg-gray-100 text-gray-600 border-gray-200">Sinh viên</span>
                                }
                            </td>
                            <td class="py-3 px-6 text-sm text-gray-500">@user.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="py-3 px-6">
                                @if (user.IsApproved)
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[11px] font-bold border bg-green-50 text-green-700 border-green-200">
                                        <svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                                        Đang hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[11px] font-bold border bg-amber-50 text-amber-700 border-amber-200">
                                        <svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                        Đã khóa
                                    </span>
                                }
                            </td>
                            <td class="py-3 px-6 text-right">
                                @if (user.Role == "Teacher")
                                {
                                    <form method="post" asp-page-handler="ApproveUser" class="m-0 inline-block">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <input type="hidden" name="approve" value="@(user.IsApproved ? "false" : "true")" />
                                        <button type="submit" class="inline-flex items-center justify-center px-3 py-1.5 border rounded-lg text-xs font-bold transition-colors @(user.IsApproved ? "border-amber-200 text-amber-700 bg-amber-50 hover:bg-amber-100 hover:border-amber-300" : "border-green-200 text-green-700 bg-green-50 hover:bg-green-100 hover:border-green-300")">
                                            @(user.IsApproved ? "Khóa tài khoản" : "Kích hoạt")
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Processing Overlay -->
<div id="adminProcessingOverlay" class="fixed inset-0 z-[100] bg-gray-900/50 backdrop-blur-sm hidden flex-col items-center justify-center p-4" aria-live="polite">
    <div class="bg-white rounded-3xl shadow-2xl max-w-sm w-full p-8 text-center animate-bounce-in">
        <svg class="w-16 h-16 text-accent-strong animate-spin mx-auto mb-6" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
        <h2 class="text-xl font-bold text-ink mb-2">Đang xử lý</h2>
        <p class="text-sm text-gray-500">Vui lòng không đóng hoặc tải lại trang web này...</p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll(".admin-processing-form").forEach(function (form) {
            form.addEventListener("submit", function () {
                const overlay = document.getElementById("adminProcessingOverlay");
                if (overlay && form.checkValidity()) overlay.classList.remove("hidden"), overlay.classList.add("flex");
            });
        });

        window.addEventListener("rag:admin-changed", function (event) {
            const status = document.getElementById("realtimeAdminStatus");
            if (!status || !event.detail) return;
            status.hidden = false;
            status.textContent = `⚡ Cập nhật trực tiếp: ${event.detail.message}`;
            const overlay = document.getElementById("adminProcessingOverlay");
            if (overlay) overlay.classList.add("hidden"), overlay.classList.remove("flex");
            
            // Reload page smoothly after 1.5s to show updated lists
            setTimeout(() => window.location.reload(), 1500);
        });
    </script>
    <style>
        .animate-bounce-in { animation: bounceIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        @@keyframes bounceIn { 0% { transform: scale(0.9); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
    </style>
}
