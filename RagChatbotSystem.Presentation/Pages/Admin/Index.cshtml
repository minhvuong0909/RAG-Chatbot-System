@page
@model RagChatbotSystem.Presentation.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Tổng quan quản trị";
}

<section class="admin-page" data-admin-page>
    <header class="admin-page-header">
        <div>
            <p class="eyebrow">Quản trị</p>
            <h1>Tổng quan quản trị</h1>
            <p class="helper-text">Quản lý người dùng, phân công giảng viên và truy cập môn học.</p>
        </div>
    </header>

    <partial name="_AdminTabs" />

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ImportErrors))
    {
        <div class="alert alert-warning">@Model.ImportErrors</div>
    }

    <div id="realtimeAdminStatus" class="dataset-realtime-status" hidden></div>

    <div class="admin-summary" aria-label="System summary">
        <div><strong>@Model.Users.Count</strong><span>Người dùng</span></div>
        <div><strong>@Model.ApprovedTeachers.Count</strong><span>Giảng viên đang hoạt động</span></div>
        <div><strong>@Model.Assignments.Count</strong><span>Phân công</span></div>
        <div><strong>@Model.UnassignedDatasets.Count</strong><span>Môn học chưa phân công</span></div>
    </div>

    <section class="admin-dashboard-links" aria-label="Lối tắt quản trị">
        <a asp-page="/Admin/Datasets/Index"><strong>Môn học</strong><span>Quản lý môn học và phân quyền.</span></a>
        <a asp-page="/Datasets/Index"><strong>Tài liệu</strong><span>Chọn môn học để quản lý tài liệu.</span></a>
        <a asp-page="/Admin/Credits/Index"><strong>Credit</strong><span>Điều chỉnh số dư và xem giao dịch.</span></a>
        <a asp-page="/Admin/Reports"><strong>Báo cáo</strong><span>Theo dõi lượt hỏi, Token và Credit.</span></a>
        <a asp-page="/Admin/Settings"><strong>Cài đặt</strong><span>Thiết lập RAG và giới hạn Token.</span></a>
    </section>

    <section class="admin-section">
        <div class="section-title">
            <h2>Quản lý tài khoản</h2>
        </div>
        <div class="admin-form-grid">
            <form method="post" asp-page-handler="ImportStudents" enctype="multipart/form-data" class="admin-form admin-processing-form">
                <div>
                    <h3>Import sinh viên</h3>
                    <p class="helper-text">Tệp XLSX cần có cột Email; cột họ tên là tùy chọn.</p>
                </div>
                <div class="admin-field">
                    <label asp-for="StudentsFile">Tải file Excel lên</label>
                    <input asp-for="StudentsFile" type="file" accept=".xlsx" required />
                </div>
                <button type="submit">Import và gửi Email tài khoản</button>
            </form>

            <form method="post" asp-page-handler="CreateTeacher" class="admin-form admin-form-teacher admin-processing-form">
                <div>
                    <h3>Tạo giảng viên</h3>
                    <p class="helper-text">Tạo tài khoản và phân công các môn học ban đầu.</p>
                </div>
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="admin-field-grid">
                    <div class="admin-field">
                        <label asp-for="TeacherInput.FullName">Họ và tên</label>
                        <input asp-for="TeacherInput.FullName" />
                        <span asp-validation-for="TeacherInput.FullName" class="text-danger small"></span>
                    </div>
                    <div class="admin-field">
                        <label asp-for="TeacherInput.Email">Email</label>
                        <input asp-for="TeacherInput.Email" type="email" />
                        <span asp-validation-for="TeacherInput.Email" class="text-danger small"></span>
                    </div>
                </div>
                <div class="admin-field">
                    <label asp-for="TeacherInput.DatasetIds">Môn học ban đầu</label>
                    <select asp-for="TeacherInput.DatasetIds" multiple size="4">
                        @foreach (var dataset in Model.UnassignedDatasets)
                        {
                            <option value="@dataset.DatasetId">@dataset.Name</option>
                        }
                    </select>
                    <span asp-validation-for="TeacherInput.DatasetIds" class="text-danger small"></span>
                </div>
                <button type="submit" disabled="@(Model.UnassignedDatasets.Count == 0)">Tạo giảng viên</button>
            </form>
        </div>
    </section>

    <section class="admin-section">
        <div class="section-title">
            <h2>Phân công giảng viên</h2>
            <span>@Model.Assignments.Count</span>
        </div>

        <form method="post" asp-page-handler="AssignTeacher" class="admin-inline-form">
            <div>
                <label asp-for="AssignmentInput.TeacherId">Giảng viên</label>
                <select asp-for="AssignmentInput.TeacherId" required>
                    <option value="">Chọn giảng viên</option>
                    @foreach (var teacher in Model.ApprovedTeachers)
                    {
                        <option value="@teacher.UserId">@teacher.FullName (@teacher.Email)</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="AssignmentInput.DatasetId">Môn học chưa phân công</label>
                <select asp-for="AssignmentInput.DatasetId" required>
                    <option value="">Chọn môn học</option>
                    @foreach (var dataset in Model.UnassignedDatasets)
                    {
                        <option value="@dataset.DatasetId">@dataset.Name</option>
                    }
                </select>
            </div>
            <button type="submit" disabled="@(Model.ApprovedTeachers.Count == 0 || Model.UnassignedDatasets.Count == 0)">Phân công</button>
        </form>

        <div class="table-responsive">
            <table class="table align-middle admin-table">
                <thead><tr><th>Giảng viên</th><th>Môn học</th><th>Thời gian phân công</th><th class="text-end">Thao tác</th></tr></thead>
                <tbody>
                    @if (Model.Assignments.Count == 0)
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">Chưa có phân công giảng viên.</td></tr>
                    }
                    @foreach (var assignment in Model.Assignments)
                    {
                        <tr>
                            <td><strong>@assignment.TeacherName</strong><small>@assignment.TeacherEmail</small></td>
                            <td>@assignment.DatasetName</td>
                            <td>@assignment.AssignedAt.ToLocalTime().ToString("g")</td>
                            <td class="text-end">
                                <form method="post" asp-page-handler="UnassignTeacher">
                                    <input type="hidden" name="datasetId" value="@assignment.DatasetId" />
                                    <button type="submit" class="dataset-danger-button">Gỡ phân công</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="admin-section">
        <div class="section-title">
            <h2>Người dùng hệ thống</h2>
            <span>@Model.Users.Count</span>
        </div>
        <div class="table-responsive">
            <table class="table align-middle admin-table">
                <thead><tr><th>Người dùng</th><th>Vai trò</th><th>Thời gian tạo</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr></thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td><strong>@user.FullName</strong><small>@user.Email</small></td>
                            <td><span class="status-pill">@(user.Role == "Student" ? "Sinh viên" : user.Role == "Teacher" ? "Giảng viên" : user.Role == "Admin" ? "Quản trị viên" : user.Role)</span></td>
                            <td>@user.CreatedAt.ToLocalTime().ToString("g")</td>
                            <td>
                                <span class="status-pill @(user.IsApproved ? "dataset-approved-pill" : "processing")">
                                    @(user.IsApproved ? "Đang hoạt động" : "Đã khóa")
                                </span>
                            </td>
                            <td class="text-end">
                                @if (user.Role == "Teacher")
                                {
                                    <form method="post" asp-page-handler="ApproveUser">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <input type="hidden" name="approve" value="@(user.IsApproved ? "false" : "true")" />
                                        <button type="submit" class="@(user.IsApproved ? "dataset-danger-button" : "secondary-button")">
                                            @(user.IsApproved ? "Khóa tài khoản" : "Kích hoạt")
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</section>

<div id="adminProcessingOverlay" class="admin-processing-overlay" hidden>
    <div class="admin-processing-dialog" role="status" aria-live="polite">
        <span class="admin-spinner" aria-hidden="true"></span>
        <h2>Đang xử lý</h2>
        <p>Vui lòng giữ trang này mở.</p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll(".admin-processing-form").forEach(function (form) {
            form.addEventListener("submit", function () {
                const overlay = document.getElementById("adminProcessingOverlay");
                if (overlay && form.checkValidity()) overlay.hidden = false;
            });
        });

        window.addEventListener("rag:admin-changed", function (event) {
            const status = document.getElementById("realtimeAdminStatus");
            if (!status || !event.detail) return;
            status.hidden = false;
            status.textContent = `Cập nhật trực tiếp: ${event.detail.message}`;
            const overlay = document.getElementById("adminProcessingOverlay");
            if (overlay) overlay.hidden = true;
        });
    </script>
    <style>
        .admin-dashboard-links { display: grid; gap: 10px; grid-template-columns: repeat(5, minmax(0, 1fr)); }
        .admin-dashboard-links a { background: var(--surface); border: 1px solid var(--line); border-radius: 8px; color: inherit; display: grid; gap: 4px; min-height: 92px; padding: 14px; text-decoration: none; transition: border-color .2s ease, box-shadow .2s ease, transform .2s ease; }
        .admin-dashboard-links a:hover { border-color: var(--accent); box-shadow: var(--shadow-soft); color: inherit; transform: translateY(-1px); }
        .admin-dashboard-links strong { color: var(--ink); font-size: .9rem; }
        .admin-dashboard-links span { color: var(--muted); font-size: .78rem; line-height: 1.45; }
        @@media (max-width: 1050px) { .admin-dashboard-links { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
        @@media (max-width: 640px) { .admin-dashboard-links { grid-template-columns: 1fr 1fr; } }
    </style>
}
