@page
@using System.Globalization
@using System.Text.Json
@model RagChatbotSystem.Presentation.Pages.Admin.ReportsModel
@{
    ViewData["Title"] = "Báo cáo";
    var vietnameseCulture = CultureInfo.GetCultureInfo("vi-VN");
    var hasTokenUsage = Model.DailyUsage.Any(item => item.TokenCount > 0 || item.QueryCount > 0);
    var chartLabels = JsonSerializer.Serialize(Model.DailyUsage.Select(item => item.FormattedDate));
    var chartTokens = JsonSerializer.Serialize(Model.DailyUsage.Select(item => item.TokenCount));
    var chartQueries = JsonSerializer.Serialize(Model.DailyUsage.Select(item => item.QueryCount));

    string RoleLabel(string role) => role switch
    {
        "Admin" => "Quản trị viên",
        "Teacher" => "Giảng viên",
        "Student" => "Sinh viên",
        _ => role
    };
}

<section class="admin-page reports-page" data-reports-page>
    <header class="admin-page-header">
        <div>
            <p class="eyebrow">QUẢN TRỊ</p>
            <h1>Báo cáo</h1>
            <p class="helper-text">Theo dõi lượt hỏi, Token kỹ thuật, Credit thực tế và mức sử dụng theo từng đối tượng. Phạm vi: @Model.ReportScopeLabel.</p>
        </div>
    </header>

    <nav class="admin-tabs" aria-label="Khu vực báo cáo">
        @if (User.IsInRole("Admin"))
        {
            <a asp-page="/Admin/Index">Tổng quan</a>
            <a asp-page="/Admin/Datasets/Index">Môn học</a>
        }
        else
        {
            <a asp-page="/Index">Không gian học tập</a>
            <a asp-page="/Datasets/Index">Môn học</a>
        }
        <a class="active" asp-page="/Admin/Reports" aria-current="page">Báo cáo</a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-page="/Admin/Settings">Cài đặt</a>
        }
    </nav>

    <section class="report-section report-overview-section" aria-labelledby="overview-heading">
        <div class="report-section-heading">
            <div>
                <p class="eyebrow">TỔNG QUAN</p>
                <h2 id="overview-heading">Hoạt động hệ thống</h2>
                <p>Lượt hỏi và người dùng là chỉ số vận hành; Token được trình bày riêng như số liệu kỹ thuật.</p>
            </div>
        </div>
        <div class="report-metric-grid report-overview-grid">
            <article class="report-metric-card metric-queries">
                <span class="report-metric-label">Tổng lượt hỏi</span>
                <strong>@Model.Summary.TotalQueriesCount.ToString("N0", vietnameseCulture)</strong>
                <small>Lượt truy vấn đã được ghi nhận</small>
            </article>
            <article class="report-metric-card metric-users">
                <span class="report-metric-label">Người dùng hoạt động</span>
                <strong>@Model.Summary.ActiveUsersCount.ToString("N0", vietnameseCulture)</strong>
                <small>Người dùng có phát sinh lượt hỏi</small>
            </article>
            <article class="report-metric-card metric-tokens">
                <span class="report-metric-label">Tổng Token</span>
                <strong>@Model.Summary.TotalTokensUsed.ToString("N0", vietnameseCulture)</strong>
                <small>Chỉ số kỹ thuật của hệ thống AI</small>
            </article>
            <article class="report-metric-card metric-today">
                <span class="report-metric-label">Token hôm nay</span>
                <strong>@Model.Summary.TodayTokensUsed.ToString("N0", vietnameseCulture)</strong>
                <small>Sử dụng trong ngày Việt Nam hiện tại</small>
            </article>
        </div>
    </section>

    <section class="report-section" aria-labelledby="token-heading">
        <div class="report-section-heading">
            <div>
                <p class="eyebrow">CHỈ SỐ KỸ THUẬT</p>
                <h2 id="token-heading">Mức sử dụng Token</h2>
                <p>Xu hướng Token và lượt hỏi trong 7 ngày gần nhất.</p>
            </div>
        </div>
        @if (hasTokenUsage)
        {
            <div class="report-chart-frame">
                <canvas id="tokenUsageChart" aria-label="Biểu đồ mức sử dụng Token và lượt hỏi" role="img"></canvas>
            </div>
        }
        else
        {
            <div class="report-empty-state">
                <strong>Chưa có dữ liệu Token</strong>
                <p>Biểu đồ sẽ xuất hiện khi hệ thống ghi nhận lượt hỏi thành công.</p>
            </div>
        }
    </section>

    <section class="report-section" aria-labelledby="credit-heading">
        <div class="report-section-heading">
            <div>
                <p class="eyebrow">CHỈ SỐ NGHIỆP VỤ</p>
                <h2 id="credit-heading">Mức sử dụng Credit</h2>
                <p>Credit là chỉ số nghiệp vụ; số thực trừ chỉ phát sinh sau câu trả lời AI hợp lệ được lưu thành công.</p>
            </div>
        </div>
        <div class="report-metric-grid report-credit-grid">
            <article class="report-metric-card metric-credit-calculated">
                <span class="report-metric-label">Credit tính toán</span>
                <strong>@Model.CreditReport.Summary.TotalCalculatedCredits.ToString("N0", vietnameseCulture)</strong>
                <small>Chi phí ước tính từ lượt trả lời</small>
            </article>
            <article class="report-metric-card metric-credit-charged">
                <span class="report-metric-label">Credit thực trừ</span>
                <strong>@Model.CreditReport.Summary.TotalChargedCredits.ToString("N0", vietnameseCulture)</strong>
                <small>Đã trừ khỏi ví sau khi hoàn tất</small>
            </article>
            <article class="report-metric-card metric-credit-free">
                <span class="report-metric-label">Credit miễn phí đã dùng</span>
                <strong>@Model.CreditReport.Summary.FreeCreditsConsumed.ToString("N0", vietnameseCulture)</strong>
                <small>Phần Credit miễn phí đã tiêu thụ</small>
            </article>
            <article class="report-metric-card metric-credit-paid">
                <span class="report-metric-label">Credit đã mua đã dùng</span>
                <strong>@Model.CreditReport.Summary.PaidCreditsConsumed.ToString("N0", vietnameseCulture)</strong>
                <small>Phần Credit đã mua đã tiêu thụ</small>
            </article>
        </div>
    </section>

    <section class="report-section" aria-labelledby="blocked-heading">
        <div class="report-section-heading">
            <div>
                <p class="eyebrow">THEO DÕI SỰ CỐ</p>
                <h2 id="blocked-heading">Lỗi và lượt bị chặn</h2>
                <p>Các yêu cầu không đủ số dư hoặc bị chặn trước khi tạo câu trả lời.</p>
            </div>
        </div>
        <div class="report-metric-grid report-blocked-grid">
            <article class="report-metric-card metric-insufficient">
                <span class="report-metric-label">Không đủ số dư</span>
                <strong>@Model.CreditReport.Summary.InsufficientBalanceCount.ToString("N0", vietnameseCulture)</strong>
                <small>Lượt phát sinh yêu cầu nhưng không đủ Credit</small>
            </article>
            <article class="report-metric-card metric-blocked">
                <span class="report-metric-label">Lượt bị chặn do hết Credit</span>
                <strong>@Model.CreditReport.Summary.ZeroBalanceBlockedCount.ToString("N0", vietnameseCulture)</strong>
                <small>Đã bị chặn trước RAG và mô hình AI</small>
            </article>
        </div>
    </section>

    <section class="report-section" aria-labelledby="credit-breakdown-heading">
        <div class="report-section-heading">
            <div>
                <p class="eyebrow">Phân tích Credit</p>
                <h2 id="credit-breakdown-heading">Mức sử dụng theo đối tượng</h2>
                <p>So sánh mức sử dụng Credit theo sinh viên, môn học và mô hình AI.</p>
            </div>
        </div>
        <div class="report-data-grid">
            <article class="report-table-panel">
                <h3>Credit theo sinh viên</h3>
                @if (Model.CreditReport.TopStudents.Any())
                {
                    <div class="report-table-scroll">
                        <table class="report-table">
                            <thead><tr><th>Sinh viên</th><th class="text-end">Thực trừ</th><th class="text-end">Tính toán</th></tr></thead>
                            <tbody>
                                @foreach (var student in Model.CreditReport.TopStudents)
                                {
                                    <tr>
                                        <td><span class="table-primary-text" title="@student.FullName">@student.FullName</span><small title="@student.Email">@student.Email</small></td>
                                        <td class="text-end">@student.ChargedCredits.ToString("N0", vietnameseCulture)</td>
                                        <td class="text-end">@student.CalculatedCredits.ToString("N0", vietnameseCulture)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="report-empty-state compact"><strong>Chưa có dữ liệu</strong><p>Chưa có Credit được ghi nhận theo sinh viên.</p></div>
                }
            </article>

            <article class="report-table-panel">
                <h3>Credit theo môn học</h3>
                @if (Model.CreditReport.TopDatasets.Any())
                {
                    <div class="report-table-scroll">
                        <table class="report-table">
                            <thead><tr><th>Môn học</th><th class="text-end">Thực trừ</th><th class="text-end">Tính toán</th></tr></thead>
                            <tbody>
                                @foreach (var dataset in Model.CreditReport.TopDatasets)
                                {
                                    <tr>
                                        <td><span class="table-primary-text" title="@dataset.DatasetName">@dataset.DatasetName</span></td>
                                        <td class="text-end">@dataset.ChargedCredits.ToString("N0", vietnameseCulture)</td>
                                        <td class="text-end">@dataset.CalculatedCredits.ToString("N0", vietnameseCulture)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="report-empty-state compact"><strong>Chưa có dữ liệu</strong><p>Chưa có Credit được ghi nhận theo môn học.</p></div>
                }
            </article>

            <article class="report-table-panel">
                <h3>Credit theo mô hình AI</h3>
                @if (Model.CreditReport.TopModels.Any())
                {
                    <div class="report-table-scroll">
                        <table class="report-table">
                            <thead><tr><th>Mô hình AI</th><th class="text-end">Thực trừ</th><th class="text-end">Tính toán</th></tr></thead>
                            <tbody>
                                @foreach (var aiModel in Model.CreditReport.TopModels)
                                {
                                    <tr>
                                        <td><span class="table-primary-text" title="@aiModel.ModelName">@aiModel.ModelName</span></td>
                                        <td class="text-end">@aiModel.ChargedCredits.ToString("N0", vietnameseCulture)</td>
                                        <td class="text-end">@aiModel.CalculatedCredits.ToString("N0", vietnameseCulture)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="report-empty-state compact"><strong>Chưa có dữ liệu</strong><p>Chưa có Credit được ghi nhận theo mô hình AI.</p></div>
                }
            </article>
        </div>
    </section>

    <section class="report-section" aria-labelledby="engagement-heading">
        <div class="report-section-heading">
            <div>
                <p class="eyebrow">LƯỢT HỎI VÀ TRÍCH DẪN</p>
                <h2 id="engagement-heading">Người dùng và tài liệu sử dụng nhiều</h2>
                <p>Dữ liệu Token kỹ thuật được hiển thị riêng với tần suất trích dẫn tài liệu.</p>
            </div>
        </div>
        <div class="report-engagement-grid">
            <article class="report-table-panel report-leaderboard-panel">
                <h3>Người dùng sử dụng nhiều nhất</h3>
                @if (Model.Leaderboard.Any())
                {
                    <div class="report-table-scroll">
                        <table class="report-table report-leaderboard-table">
                            <thead><tr><th>Hạng</th><th>Người dùng</th><th>Vai trò</th><th class="text-end">Lượt hỏi</th><th class="text-end">Token</th></tr></thead>
                            <tbody>
                                @{ var rank = 1; }
                                @foreach (var user in Model.Leaderboard)
                                {
                                    <tr>
                                        <td><span class="rank-number">@rank</span></td>
                                        <td><span class="table-primary-text" title="@user.FullName">@user.FullName</span><small title="@user.Email">@user.Email</small></td>
                                        <td><span class="report-role">@RoleLabel(user.Role)</span></td>
                                        <td class="text-end">@user.TotalQueriesCount.ToString("N0", vietnameseCulture)</td>
                                        <td class="text-end">@user.TotalTokensUsed.ToString("N0", vietnameseCulture)</td>
                                    </tr>
                                    rank++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="report-empty-state compact"><strong>Chưa có dữ liệu</strong><p>Chưa có người dùng phát sinh lượt hỏi.</p></div>
                }
            </article>

            <article class="report-table-panel report-documents-panel">
                <h3>Tài liệu được trích dẫn nhiều nhất</h3>
                @if (Model.TopDocuments.Any())
                {
                    var maxCitations = Model.TopDocuments.First().CitationCount;
                    <div class="report-document-list">
                        @foreach (var document in Model.TopDocuments)
                        {
                            var percentage = maxCitations > 0 ? (double)document.CitationCount / maxCitations * 100 : 0;
                            <div class="report-document-item">
                                <div class="report-document-title">
                                    <span title="@document.DocumentName">@document.DocumentName</span>
                                    <small title="@document.DatasetName">@document.DatasetName</small>
                                </div>
                                <div class="report-document-meter">
                                    <span class="report-document-track"><span style="width: @percentage.ToString(CultureInfo.InvariantCulture)%"></span></span>
                                    <strong>@document.CitationCount.ToString("N0", vietnameseCulture) lượt</strong>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="report-empty-state compact"><strong>Chưa có dữ liệu</strong><p>Chưa có tài liệu nào được trích dẫn.</p></div>
                }
            </article>
        </div>
    </section>
</section>

@section Scripts {
    <style>
        .reports-page { gap: 1.35rem; }
        .report-section { display: grid; gap: 1rem; padding: 1.4rem 0; border-top: 1px solid #dbe4ee; }
        .report-overview-section { border-top: 0; padding-top: 0; }
        .report-section-heading h2, .report-table-panel h3 { margin: 0; color: #0f172a; }
        .report-section-heading h2 { font-size: 1.25rem; }
        .report-section-heading p { max-width: 760px; margin: .35rem 0 0; color: #64748b; font-size: .92rem; }
        .report-metric-grid { display: grid; gap: .9rem; }
        .report-overview-grid, .report-credit-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
        .report-blocked-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); max-width: 700px; }
        .report-metric-card { display: flex; min-width: 0; min-height: 138px; flex-direction: column; gap: .35rem; border: 1px solid #dbe4ee; border-top: 3px solid #94a3b8; border-radius: 8px; background: #fff; padding: 1rem; }
        .report-metric-label { color: #475569; font-size: .86rem; font-weight: 650; }
        .report-metric-card strong { color: #0f172a; font-size: 1.8rem; line-height: 1.1; }
        .report-metric-card small { color: #64748b; font-size: .8rem; line-height: 1.35; }
        .metric-queries { border-top-color: #0f766e; }
        .metric-users { border-top-color: #2563eb; }
        .metric-tokens { border-top-color: #7c3aed; }
        .metric-today { border-top-color: #0891b2; }
        .metric-credit-calculated { border-top-color: #2563eb; }
        .metric-credit-charged { border-top-color: #0f766e; }
        .metric-credit-free { border-top-color: #d97706; }
        .metric-credit-paid { border-top-color: #c2410c; }
        .metric-insufficient { border-top-color: #be123c; }
        .metric-blocked { border-top-color: #a16207; }
        .report-chart-frame { position: relative; height: 330px; border: 1px solid #dbe4ee; border-radius: 8px; background: #fff; padding: .75rem; }
        .report-empty-state { display: grid; min-height: 190px; place-content: center; border: 1px dashed #cbd5e1; border-radius: 8px; color: #475569; text-align: center; padding: 1.25rem; }
        .report-empty-state strong { color: #0f172a; }
        .report-empty-state p { margin: .35rem 0 0; }
        .report-empty-state.compact { min-height: 130px; font-size: .9rem; }
        .report-data-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; }
        .report-engagement-grid { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(0, .9fr); gap: 1rem; }
        .report-table-panel { display: grid; min-width: 0; gap: .85rem; border: 1px solid #dbe4ee; border-radius: 8px; background: #fff; padding: 1rem; }
        .report-table-panel h3 { font-size: 1rem; }
        .report-table-scroll { max-height: 365px; overflow: auto; border: 1px solid #e2e8f0; border-radius: 6px; }
        .report-table { width: 100%; min-width: 410px; border-collapse: collapse; font-size: .88rem; }
        .report-table th { position: sticky; top: 0; z-index: 1; background: #f8fafc; color: #475569; font-size: .75rem; font-weight: 750; text-align: left; white-space: nowrap; padding: .7rem; }
        .report-table td { border-top: 1px solid #e2e8f0; color: #334155; padding: .7rem; vertical-align: middle; }
        .report-table td.text-end, .report-table th.text-end { text-align: right; }
        .table-primary-text, .report-document-title > span { display: block; max-width: 205px; overflow: hidden; color: #0f172a; font-weight: 650; text-overflow: ellipsis; white-space: nowrap; }
        .report-table small, .report-document-title small { display: block; max-width: 205px; overflow: hidden; margin-top: .15rem; color: #64748b; font-size: .77rem; text-overflow: ellipsis; white-space: nowrap; }
        .rank-number { display: inline-grid; width: 25px; height: 25px; place-items: center; border-radius: 50%; background: #f1f5f9; color: #334155; font-weight: 700; }
        .report-role { display: inline-flex; border: 1px solid #cbd5e1; border-radius: 999px; background: #f8fafc; color: #475569; font-size: .75rem; font-weight: 700; padding: .25rem .5rem; white-space: nowrap; }
        .report-document-list { display: grid; gap: .9rem; }
        .report-document-item { display: grid; gap: .45rem; }
        .report-document-title { min-width: 0; }
        .report-document-meter { display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: center; gap: .65rem; }
        .report-document-track { display: block; height: 8px; overflow: hidden; border-radius: 4px; background: #e2e8f0; }
        .report-document-track > span { display: block; height: 100%; border-radius: inherit; background: #0f766e; }
        .report-document-meter strong { color: #334155; font-size: .8rem; white-space: nowrap; }
        @@media (max-width: 1100px) { .report-overview-grid, .report-credit-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } .report-data-grid { grid-template-columns: 1fr; } .report-engagement-grid { grid-template-columns: 1fr; } }
        @@media (max-width: 620px) {
            .report-overview-grid, .report-credit-grid, .report-blocked-grid { grid-template-columns: 1fr; }
            .report-chart-frame { height: 280px; padding: .5rem; }
            .report-table-panel { padding: .85rem; }
            .report-table-scroll { margin-inline: -.15rem; }
            .report-table { min-width: 470px; }
            .report-metric-card { min-height: 122px; }
        }
    </style>

    @if (hasTokenUsage)
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                const canvas = document.getElementById("tokenUsageChart");
                if (!canvas || typeof Chart === "undefined") {
                    return;
                }

                new Chart(canvas, {
                    type: "line",
                    data: {
                        labels: @Html.Raw(chartLabels),
                        datasets: [
                            {
                                label: "Token đã dùng",
                                data: @Html.Raw(chartTokens),
                                borderColor: "#2563eb",
                                borderWidth: 2,
                                backgroundColor: "rgba(37, 99, 235, .10)",
                                fill: true,
                                tension: .3,
                                pointBackgroundColor: "#2563eb",
                                pointRadius: 3,
                                yAxisID: "tokens"
                            },
                            {
                                label: "Lượt hỏi",
                                data: @Html.Raw(chartQueries),
                                borderColor: "#0f766e",
                                borderWidth: 2,
                                borderDash: [5, 4],
                                fill: false,
                                tension: .3,
                                pointBackgroundColor: "#0f766e",
                                pointRadius: 3,
                                yAxisID: "queries"
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        locale: "vi-VN",
                        interaction: { mode: "index", intersect: false },
                        plugins: {
                            legend: { position: "top", labels: { boxWidth: 12, usePointStyle: true } },
                            tooltip: { padding: 10, cornerRadius: 6 }
                        },
                        scales: {
                            x: { grid: { display: false } },
                            tokens: {
                                type: "linear",
                                position: "left",
                                title: { display: true, text: "Token" },
                                grid: { color: "rgba(148, 163, 184, .22)" }
                            },
                            queries: {
                                type: "linear",
                                position: "right",
                                title: { display: true, text: "Lượt hỏi" },
                                grid: { drawOnChartArea: false }
                            }
                        }
                    }
                });
            });
        </script>
    }
}
