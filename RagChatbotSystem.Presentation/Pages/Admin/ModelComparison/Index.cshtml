@page
@model RagChatbotSystem.Presentation.Pages.Admin.ModelComparison.IndexModel
@{
    ViewData["Title"] = "So sánh mô hình AI";

    string ProviderLabel(string key) => key switch
    {
        "Groq" => "Groq (Llama 3.3 70B)",
        "Qwen" => "Groq (Qwen 32B)",
        "Gemini" => "Google Gemini",
        _ => key
    };
}

<section class="admin-page" data-admin-page>
    <header class="admin-page-header">
        <div>
            <p class="eyebrow">Quản trị</p>
            <h1>So sánh mô hình AI</h1>
            <p class="helper-text">Chạy thử cùng một câu hỏi trên nhiều mô hình AI khác nhau để so sánh chất lượng câu trả lời, thời gian phản hồi và số Token sử dụng.</p>
        </div>
    </header>

    <partial name="_AdminTabs" />

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    <!-- Khối tiến trình chạy ngầm Batch Benchmark -->
    <div id="batchProgressSection" class="admin-section" style="display: @(Model.BatchStatus.IsRunning ? "block" : "none"); margin-bottom: 20px;">
        <div class="section-title">
            <h2>Tiến trình Benchmark hàng loạt</h2>
        </div>
        <div class="batch-progress-card">
            <div class="batch-progress-info">
                <span id="batchProgressText">Đang xử lý: @Model.BatchStatus.ProcessedQuestions / @Model.BatchStatus.TotalQuestions câu hỏi</span>
                <span id="batchFailedText" class="text-danger small">Lỗi: @Model.BatchStatus.FailedQuestions</span>
            </div>
            <div class="progress-bar-container">
                <div id="batchProgressBar" class="progress-bar" style="width: @(Model.BatchStatus.TotalQuestions > 0 ? (Model.BatchStatus.ProcessedQuestions * 100 / Model.BatchStatus.TotalQuestions) : 0)%;"></div>
            </div>
            <div id="batchCurrentQuestion" class="batch-current-question">
                <strong>Đang chạy:</strong> <span id="batchCurrentQuestionText">@Model.BatchStatus.CurrentQuestion</span>
            </div>
        </div>
    </div>

    <section class="admin-section">
        <div class="section-title">
            <h2>Chạy thử nghiệm</h2>
        </div>

        <form method="post" class="admin-form model-comparison-form" id="comparisonForm">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

            <div class="form-group">
                <label asp-for="Input.DatasetId">Môn học</label>
                <select asp-for="Input.DatasetId">
                    <option value="">Chọn môn học</option>
                    @foreach (var dataset in Model.Datasets)
                    {
                        <option value="@dataset.DatasetId">@dataset.Name</option>
                    }
                </select>
                <span asp-validation-for="Input.DatasetId" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Question">Câu hỏi thử nghiệm</label>
                <textarea asp-for="Input.Question" rows="4" placeholder="Nhập câu hỏi để thử nghiệm. Để chạy benchmark hàng loạt, hãy nhập mỗi câu hỏi trên một dòng..."></textarea>
                <span class="helper-text">Mỗi dòng là 1 câu hỏi. Chế độ chạy hàng loạt tối đa @IndexModel.MaxBatchQuestions câu mỗi lần.</span>
                <span asp-validation-for="Input.Question" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label>Chọn mô hình để thử nghiệm</label>
                <div class="model-comparison-providers">
                    @foreach (var provider in Model.AvailableProviders)
                    {
                        <label class="model-comparison-provider-check">
                            <input type="checkbox" name="Input.Providers" value="@provider" checked />
                            @ProviderLabel(provider)
                        </label>
                    }
                </div>
                <span asp-validation-for="Input.Providers" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary" id="submitBtn" @(Model.BatchStatus.IsRunning ? "disabled" : "")>Chạy thử nghiệm</button>
        </form>
    </section>

    @if (Model.Result != null)
    {
        <section class="admin-section">
            <div class="section-title">
                <h2>Kết quả so sánh</h2>
                <span>@Model.Result.RetrievedChunkCount đoạn ngữ cảnh · Retrieval @Model.Result.RetrievalLatencyMs ms</span>
            </div>

            <p class="helper-text"><strong>Câu hỏi:</strong> @Model.Result.Question</p>

            <div class="model-comparison-results">
                @foreach (var result in Model.Result.Results)
                {
                    <div class="model-comparison-card @(result.IsSuccess ? "" : "model-comparison-card-error")">
                        <div class="model-comparison-card-header">
                            <strong>@ProviderLabel(result.ProviderKey)</strong>
                            <span class="status-pill @(result.IsSuccess ? "dataset-approved-pill" : "processing")">
                                @(result.IsSuccess ? "Thành công" : "Lỗi")
                            </span>
                        </div>
                        <div class="model-comparison-card-meta">
                            <span><strong>Model:</strong> @result.ModelName</span>
                            <span><strong>Thời gian:</strong> @result.LatencyMs ms</span>
                            <span><strong>Token:</strong> @result.InputTokens vào / @result.OutputTokens ra / @result.TotalTokens tổng</span>
                            @if (result.QualityScore.HasValue)
                            {
                                <span><strong>Điểm chất lượng (AI chấm):</strong> @result.QualityScore/10</span>
                            }
                            @if (result.Faithfulness.HasValue)
                            {
                                <span><strong>Độ bám tài liệu:</strong> @result.Faithfulness.Value.ToString("0.00")</span>
                            }
                            @if (result.Relevance.HasValue)
                            {
                                <span><strong>Độ liên quan:</strong> @result.Relevance.Value.ToString("0.00")</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(result.QualityReasoning))
                        {
                            <div class="model-comparison-card-judge">@result.QualityReasoning</div>
                        }
                        @if (result.IsSuccess)
                        {
                            <div class="model-comparison-card-answer">@result.Answer</div>
                        }
                        else
                        {
                            <div class="model-comparison-card-answer model-comparison-card-answer-error">@result.ErrorMessage</div>
                        }
                    </div>
                }
            </div>
        </section>
    }
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <style>
        .model-comparison-form .form-group { margin-bottom: 16px; }
        .model-comparison-providers { display: flex; flex-wrap: wrap; gap: 12px; }
        .model-comparison-provider-check { align-items: center; display: flex; gap: 6px; font-weight: 400; }
        .model-comparison-results { display: grid; gap: 14px; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
        .model-comparison-card { align-content: start; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; display: grid; gap: 10px; padding: 14px; }
        .model-comparison-card-error { border-color: #e0554f; }
        .model-comparison-card-header { align-items: center; display: flex; justify-content: space-between; }
        .model-comparison-card-meta { color: var(--muted); display: grid; font-size: .78rem; gap: 3px; }
        .model-comparison-card-answer { border-top: 1px solid var(--line); font-size: .88rem; line-height: 1.5; padding-top: 10px; white-space: pre-wrap; }
        .model-comparison-card-answer-error { color: #e0554f; }
        .model-comparison-card-judge { background: var(--surface-muted); border-radius: 6px; color: var(--muted); font-size: .78rem; font-style: italic; padding: 8px 10px; }

        /* Batch Progress Styles */
        .batch-progress-card { background: var(--surface); border: 1px solid var(--line); border-radius: 8px; padding: 16px; display: grid; gap: 10px; }
        .batch-progress-info { display: flex; justify-content: space-between; font-size: 0.88rem; }
        .progress-bar-container { background: var(--surface-muted); border-radius: 4px; height: 10px; overflow: hidden; width: 100%; }
        .progress-bar { background: var(--primary); height: 100%; transition: width 0.3s ease; }
        .batch-current-question { color: var(--muted); font-size: 0.78rem; text-overflow: ellipsis; white-space: nowrap; overflow: hidden; }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var isRunning = @(Model.BatchStatus.IsRunning ? "true" : "false");
            var pollInterval = null;

            if (isRunning) {
                startPolling();
            }

            function startPolling() {
                pollInterval = setInterval(checkBatchStatus, 2000);
            }

            function checkBatchStatus() {
                fetch('/Admin/ModelComparison/Index?handler=Status')
                    .then(response => response.json())
                    .then(data => {
                        if (data.isRunning) {
                            document.getElementById("batchProgressSection").style.display = "block";
                            document.getElementById("batchProgressText").innerText = "Đang xử lý: " + data.processedQuestions + " / " + data.totalQuestions + " câu hỏi";
                            document.getElementById("batchFailedText").innerText = "Lỗi: " + data.failedQuestions;
                            
                            var percent = data.totalQuestions > 0 ? (data.processedQuestions * 100 / data.totalQuestions) : 0;
                            document.getElementById("batchProgressBar").style.width = percent + "%";
                            document.getElementById("batchCurrentQuestionText").innerText = data.currentQuestion;
                            document.getElementById("submitBtn").disabled = true;
                        } else {
                            clearInterval(pollInterval);
                            document.getElementById("batchProgressSection").style.display = "none";
                            document.getElementById("submitBtn").disabled = false;
                            
                            // Notify user of completion and reload to clear state or show fresh history
                            alert("Chạy benchmark hàng loạt hoàn thành! Bạn có thể xem lịch sử để biết chi tiết.");
                            window.location.reload();
                        }
                    })
                    .catch(error => {
                        console.error("Lỗi khi kiểm tra tiến trình benchmark:", error);
                    });
            }
        });
    </script>
}
