@page
@model RagChatbotSystem.Presentation.Pages.Admin.ModelComparison.IndexModel
@{
    ViewData["Title"] = "So sánh mô hình AI";

    string ProviderLabel(string key) => key switch
    {
        "Groq" => "Groq (Llama 3.3 70B)",
        "Qwen" => "Groq (Qwen 32B)",
        "Gemini" => "Google Gemini",
        _ => key
    };
}

<div class="space-y-6" data-admin-page>
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white/60 backdrop-blur-xl border border-white shadow-sm p-6 rounded-2xl">
        <div>
            <p class="text-xs font-bold text-accent-strong tracking-wider uppercase mb-1">Quản trị</p>
            <h1 class="text-2xl font-grotesk font-extrabold text-ink tracking-tight">So sánh mô hình AI</h1>
            <p class="text-sm text-gray-500 mt-1">Chạy thử cùng một câu hỏi trên nhiều mô hình AI khác nhau để so sánh chất lượng câu trả lời, thời gian phản hồi và số Token sử dụng.</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-page="/Admin/ModelComparison/History" class="inline-flex items-center justify-center px-4 py-2 border border-gray-200 rounded-xl text-sm font-bold text-gray-700 bg-white hover:bg-gray-50 transition-colors shadow-sm whitespace-nowrap">
                Lịch sử & Báo cáo
            </a>
        </div>
    </div>

    <!-- Tabs -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-2">
        <partial name="_AdminTabs" />
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="p-4 rounded-xl bg-red-50 border border-red-100 flex items-start gap-3 relative">
            <svg class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            <div class="flex-1"><p class="text-sm font-medium text-red-800">@Model.ErrorMessage</p></div>
            <button type="button" class="absolute top-4 right-4 text-red-400 hover:text-red-600" onclick="this.parentElement.remove();"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="p-4 rounded-xl bg-emerald-50 border border-emerald-100 flex items-start gap-3">
            <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <p class="text-sm font-medium text-emerald-800">@Model.SuccessMessage</p>
        </div>
    }

    <!-- Khối tiến trình chạy ngầm Batch Benchmark -->
    <div id="batchProgressSection" class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6" style="display: @(Model.BatchStatus.IsRunning ? "block" : "none");">
        <h2 class="text-lg font-bold text-ink mb-4">Tiến trình Benchmark hàng loạt</h2>
        <div class="flex flex-col gap-3">
            <div class="flex justify-between text-sm">
                <span id="batchProgressText" class="font-medium text-gray-700">Đang xử lý: @Model.BatchStatus.ProcessedQuestions / @Model.BatchStatus.TotalQuestions câu hỏi</span>
                <span id="batchFailedText" class="text-red-500 font-medium">Lỗi: @Model.BatchStatus.FailedQuestions</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
                <div id="batchProgressBar" class="bg-accent-strong h-full transition-all duration-300" style="width: @(Model.BatchStatus.TotalQuestions > 0 ? (Model.BatchStatus.ProcessedQuestions * 100 / Model.BatchStatus.TotalQuestions) : 0)%;"></div>
            </div>
            <div class="text-xs text-gray-500 truncate">
                <strong>Đang chạy:</strong> <span id="batchCurrentQuestionText">@Model.BatchStatus.CurrentQuestion</span>
            </div>
        </div>
    </div>

    <!-- Run Test Section -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden relative group">
        <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
            <svg class="w-32 h-32 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
        </div>

        <div class="px-6 py-5 border-b border-gray-50 bg-gradient-to-r from-indigo-50/50 to-white relative z-10">
            <h2 class="text-lg font-bold text-ink flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-indigo-50 text-accent-strong flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </span>
                Chạy thử nghiệm
            </h2>
        </div>
        <div class="p-6 relative z-10">
            <form method="post" class="admin-processing-form flex flex-col gap-5">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm bg-red-50 p-4 rounded-xl border border-red-100 hidden empty:hidden"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Dataset Selection -->
                    <div>
                        <label asp-for="Input.DatasetId" class="block text-sm font-bold text-gray-700 mb-1.5">Môn học <span class="text-red-500">*</span></label>
                        <select asp-for="Input.DatasetId" class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-2.5 border bg-white">
                            <option value="">Chọn môn học</option>
                            @foreach (var dataset in Model.Datasets)
                            {
                                <option value="@dataset.DatasetId">@dataset.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Input.DatasetId" class="text-red-500 text-xs mt-1.5 block"></span>
                    </div>

                    <!-- Question Input -->
                    <div>
                        <label asp-for="Input.Question" class="block text-sm font-bold text-gray-700 mb-1.5">Câu hỏi thử nghiệm <span class="text-red-500">*</span></label>
                        <textarea asp-for="Input.Question" rows="4" placeholder="Nhập câu hỏi để thử nghiệm. Để chạy benchmark hàng loạt, hãy nhập mỗi câu hỏi trên một dòng..." class="block w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-2.5 border resize-none"></textarea>
                        <p class="text-xs text-gray-500 mt-1.5">Mỗi dòng là 1 câu hỏi. Chế độ chạy hàng loạt tối đa @IndexModel.MaxBatchQuestions câu mỗi lần.</p>
                        <span asp-validation-for="Input.Question" class="text-red-500 text-xs mt-1.5 block"></span>
                    </div>
                </div>

                <!-- Provider Selection -->
                <div class="bg-gray-50/50 rounded-2xl p-5 border border-gray-100">
                    <label class="block text-sm font-bold text-gray-700 mb-3">Chọn mô hình để thử nghiệm</label>
                    <div class="flex flex-wrap gap-3">
                        @foreach (var provider in Model.AvailableProviders)
                        {
                            <label class="inline-flex items-center gap-2.5 px-4 py-2.5 rounded-xl border border-gray-200 bg-white cursor-pointer hover:border-indigo-300 hover:bg-indigo-50/30 transition-colors shadow-sm select-none has-[:checked]:border-indigo-500 has-[:checked]:ring-1 has-[:checked]:ring-indigo-500 has-[:checked]:bg-indigo-50/50">
                                <input type="checkbox" name="Input.Providers" value="@provider" checked class="w-4 h-4 text-accent-strong border-gray-300 rounded focus:ring-indigo-500" />
                                <span class="text-sm font-bold text-gray-700">@ProviderLabel(provider)</span>
                            </label>
                        }
                    </div>
                    <span asp-validation-for="Input.Providers" class="text-red-500 text-xs mt-2 block"></span>
                </div>

                <div class="flex justify-end mt-2">
                    <button type="submit" id="submitBtn" @(Model.BatchStatus.IsRunning ? "disabled" : "") class="inline-flex justify-center items-center px-6 py-3 border border-transparent text-sm font-bold rounded-xl text-white bg-accent-strong hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">
                        Chạy thử nghiệm
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Results Section -->
    @if (Model.Result != null)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden mt-6">
            <div class="px-6 py-5 border-b border-gray-50 bg-gradient-to-r from-teal-50/50 to-white flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <h2 class="text-lg font-bold text-ink flex items-center gap-2">
                    <span class="w-8 h-8 rounded-lg bg-teal-50 text-teal-600 flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
                    </span>
                    Kết quả so sánh
                </h2>
                <div class="flex gap-2">
                    <span class="px-3 py-1 bg-blue-50 text-blue-700 text-xs font-bold rounded-lg border border-blue-100">@Model.Result.RetrievedChunkCount đoạn ngữ cảnh</span>
                    <span class="px-3 py-1 bg-amber-50 text-amber-700 text-xs font-bold rounded-lg border border-amber-100">Retrieval @Model.Result.RetrievalLatencyMs ms</span>
                </div>
            </div>

            <div class="p-6 bg-gray-50/50 border-b border-gray-100">
                <p class="text-sm">
                    <strong class="text-gray-700 font-bold uppercase tracking-wider text-xs mr-2">Câu hỏi:</strong>
                    <span class="text-ink font-medium">@Model.Result.Question</span>
                </p>
            </div>

            <div class="p-6">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    @foreach (var result in Model.Result.Results)
                    {
                        <div class="bg-white rounded-2xl border @(result.IsSuccess ? "border-gray-200" : "border-red-300") shadow-sm overflow-hidden flex flex-col transition-shadow hover:shadow-md h-full relative">
                            @if(!result.IsSuccess)
                            {
                                <div class="absolute top-0 left-0 w-1 h-full bg-red-500"></div>
                            }
                            else
                            {
                                <div class="absolute top-0 left-0 w-1 h-full bg-teal-500"></div>
                            }

                            <div class="px-5 py-4 border-b border-gray-50 flex items-center justify-between pl-6 bg-gray-50/30">
                                <strong class="text-ink font-bold text-base">@ProviderLabel(result.ProviderKey)</strong>
                                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[11px] font-bold border @(result.IsSuccess ? "bg-teal-50 text-teal-700 border-teal-200" : "bg-red-50 text-red-700 border-red-200")">
                                    @(result.IsSuccess ? "Thành công" : "Lỗi")
                                </span>
                            </div>

                            <div class="p-5 flex-1 flex flex-col gap-4 pl-6">
                                <div class="grid grid-cols-2 gap-3 mb-2">
                                    <div class="bg-gray-50 rounded-xl p-3 border border-gray-100">
                                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Model</p>
                                        <p class="text-sm font-semibold text-ink truncate" title="@result.ModelName">@result.ModelName</p>
                                    </div>
                                    <div class="bg-gray-50 rounded-xl p-3 border border-gray-100">
                                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Thời gian</p>
                                        <p class="text-sm font-semibold text-ink">@result.LatencyMs <span class="text-xs text-gray-500 font-normal">ms</span></p>
                                    </div>
                                    <div class="bg-gray-50 rounded-xl p-3 border border-gray-100 col-span-2 flex justify-between items-center">
                                        <div>
                                            <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Token (Vào / Ra)</p>
                                            <p class="text-sm font-semibold text-ink">@result.InputTokens <span class="text-gray-400 font-normal">/</span> @result.OutputTokens</p>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Tổng</p>
                                            <p class="text-sm font-bold text-indigo-600">@result.TotalTokens</p>
                                        </div>
                                    </div>
                                    @if (result.QualityScore.HasValue)
                                    {
                                        <div class="bg-emerald-50 rounded-xl p-3 border border-emerald-100 col-span-2 flex justify-between items-center">
                                            <p class="text-xs font-bold text-emerald-800 uppercase tracking-wider">Điểm chất lượng (AI chấm)</p>
                                            <div class="flex items-center gap-1">
                                                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                                                <p class="text-sm font-bold text-emerald-700">@result.QualityScore<span class="text-emerald-600/50">/10</span></p>
                                            </div>
                                        </div>
                                    }
                                    @if (result.Faithfulness.HasValue)
                                    {
                                        <div class="bg-gray-50 rounded-xl p-3 border border-gray-100">
                                            <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Độ bám tài liệu</p>
                                            <p class="text-sm font-semibold text-ink">@result.Faithfulness.Value.ToString("0.00")</p>
                                        </div>
                                    }
                                    @if (result.Relevance.HasValue)
                                    {
                                        <div class="bg-gray-50 rounded-xl p-3 border border-gray-100">
                                            <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Độ liên quan</p>
                                            <p class="text-sm font-semibold text-ink">@result.Relevance.Value.ToString("0.00")</p>
                                        </div>
                                    }
                                </div>

                                @if (!string.IsNullOrWhiteSpace(result.QualityReasoning))
                                {
                                    <div class="bg-gray-50 rounded-xl p-4 border border-gray-100 text-xs text-gray-600 italic leading-relaxed relative">
                                        <div class="absolute -top-2 left-4 px-2 bg-gray-50 text-[10px] font-bold text-gray-400 uppercase tracking-wider">Lý do chấm điểm</div>
                                        <div class="mt-1">@result.QualityReasoning</div>
                                    </div>
                                }

                                <div class="mt-auto pt-4 border-t border-gray-100">
                                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Câu trả lời</p>
                                    @if (result.IsSuccess)
                                    {
                                        <div class="text-sm text-gray-700 leading-relaxed whitespace-pre-wrap font-medium">@result.Answer</div>
                                    }
                                    else
                                    {
                                        <div class="text-sm text-red-600 bg-red-50 p-4 rounded-xl border border-red-100 font-medium">@result.ErrorMessage</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Processing Overlay -->
<div id="adminProcessingOverlay" class="fixed inset-0 z-[100] bg-gray-900/50 backdrop-blur-sm hidden flex-col items-center justify-center p-4" aria-live="polite">
    <div class="bg-white rounded-3xl shadow-2xl max-w-sm w-full p-8 text-center animate-bounce-in">
        <svg class="w-16 h-16 text-accent-strong animate-spin mx-auto mb-6" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
        <h2 class="text-xl font-bold text-ink mb-2">Đang chạy thử nghiệm</h2>
        <p class="text-sm text-gray-500">Quá trình này có thể mất một lúc tùy thuộc vào số lượng mô hình được chọn. Vui lòng không đóng trang...</p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll(".admin-processing-form").forEach(function (form) {
            form.addEventListener("submit", function () {
                const overlay = document.getElementById("adminProcessingOverlay");
                if (overlay && form.checkValidity()) overlay.classList.remove("hidden"), overlay.classList.add("flex");
            });
        });
    </script>
    <style>
        .animate-bounce-in { animation: bounceIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        @@keyframes bounceIn { 0% { transform: scale(0.9); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var isRunning = @(Model.BatchStatus.IsRunning ? "true" : "false");
            var pollInterval = null;

            if (isRunning) {
                startPolling();
            }

            function startPolling() {
                pollInterval = setInterval(checkBatchStatus, 2000);
            }

            function checkBatchStatus() {
                fetch('/Admin/ModelComparison/Index?handler=Status')
                    .then(response => response.json())
                    .then(data => {
                        if (data.isRunning) {
                            document.getElementById("batchProgressSection").style.display = "block";
                            document.getElementById("batchProgressText").innerText = "Đang xử lý: " + data.processedQuestions + " / " + data.totalQuestions + " câu hỏi";
                            document.getElementById("batchFailedText").innerText = "Lỗi: " + data.failedQuestions;

                            var percent = data.totalQuestions > 0 ? (data.processedQuestions * 100 / data.totalQuestions) : 0;
                            document.getElementById("batchProgressBar").style.width = percent + "%";
                            document.getElementById("batchCurrentQuestionText").innerText = data.currentQuestion;
                            var submitBtn = document.getElementById("submitBtn");
                            if (submitBtn) submitBtn.disabled = true;
                        } else {
                            clearInterval(pollInterval);
                            document.getElementById("batchProgressSection").style.display = "none";
                            var submitBtn = document.getElementById("submitBtn");
                            if (submitBtn) submitBtn.disabled = false;

                            // Notify user of completion and reload to clear state or show fresh history
                            alert("Chạy benchmark hàng loạt hoàn thành! Bạn có thể xem lịch sử để biết chi tiết.");
                            window.location.reload();
                        }
                    })
                    .catch(error => {
                        console.error("Lỗi khi kiểm tra tiến trình benchmark:", error);
                    });
            }
        });
    </script>
}
