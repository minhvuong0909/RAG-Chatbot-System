@page
@using System.Text.Json
@model RagChatbotSystem.Presentation.Pages.Admin.ModelComparison.HistoryModel
@{
    ViewData["Title"] = "Lịch sử & Báo cáo so sánh mô hình";

    string ProviderLabel(string key) => key switch
    {
        "Groq" => "Groq (Llama 3.3 70B)",
        "Qwen" => "Groq (Qwen 32B)",
        "Gemini" => "Google Gemini",
        _ => key
    };

    var hasStats = Model.Stats.ProviderStats.Count > 0;
    var statLabels = JsonSerializer.Serialize(Model.Stats.ProviderStats.Select(s => ProviderLabel(s.ProviderKey)));
    var statLatency = JsonSerializer.Serialize(Model.Stats.ProviderStats.Select(s => Math.Round(s.AvgLatencyMs, 0)));
    var statScore = JsonSerializer.Serialize(Model.Stats.ProviderStats.Select(s => s.AvgQualityScore.HasValue ? Math.Round(s.AvgQualityScore.Value, 1) : (double?)null));
    var statTokens = JsonSerializer.Serialize(Model.Stats.ProviderStats.Select(s => Math.Round(s.AvgTotalTokens, 0)));
    var statFaithfulness = JsonSerializer.Serialize(Model.Stats.ProviderStats.Select(s => s.AvgFaithfulness.HasValue ? Math.Round(s.AvgFaithfulness.Value, 3) : (double?)null));
    var statRelevance = JsonSerializer.Serialize(Model.Stats.ProviderStats.Select(s => s.AvgRelevance.HasValue ? Math.Round(s.AvgRelevance.Value, 3) : (double?)null));
}

<section class="admin-page" data-admin-page>
    <header class="admin-page-header">
        <div>
            <p class="eyebrow">Quản trị</p>
            <h1>Lịch sử &amp; Báo cáo so sánh mô hình</h1>
            <p class="helper-text">Tổng hợp các lần chạy so sánh model trước đây — độ trễ trung bình và điểm chất lượng do AI chấm.</p>
        </div>
    </header>

    <partial name="_AdminTabs" />

    <section class="admin-section">
        <div class="section-title">
            <h2>Tổng hợp theo model</h2>
        </div>
        @if (hasStats)
        {
            <div class="mc-history-chart-grid">
                <div class="mc-history-chart-frame"><canvas id="tokensChart"></canvas></div>
                <div class="mc-history-chart-frame"><canvas id="latencyChart"></canvas></div>
                <div class="mc-history-chart-frame"><canvas id="scoreChart"></canvas></div>
                <div class="mc-history-chart-frame"><canvas id="ragasChart"></canvas></div>
            </div>
        }
        else
        {
            <div class="mc-history-empty">Chưa có dữ liệu lịch sử để tổng hợp.</div>
        }
    </section>

    <section class="admin-section">
        <div class="section-title">
            <h2>Lịch sử chạy gần đây</h2>
            <span>@Model.Runs.Count lần chạy</span>
        </div>

        @if (Model.Runs.Count == 0)
        {
            <div class="mc-history-empty">Chưa có lần chạy nào được lưu.</div>
        }
        else
        {
            <div class="mc-history-table-scroll">
                <table class="mc-history-table">
                    <thead>
                        <tr>
                            <th>Thời gian</th>
                            <th>Môn học</th>
                            <th>Câu hỏi</th>
                            <th>Model</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thời gian (ms)</th>
                            <th class="text-end">Token</th>
                            <th class="text-end">Điểm</th>
                            <th class="text-end">Bám TL</th>
                            <th class="text-end">Liên quan</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var run in Model.Runs)
                        {
                            @foreach (var result in run.Results)
                            {
                                <tr>
                                    <td>@RagChatbotSystem.Presentation.Pages.Admin.ModelComparison.HistoryModel.FormatVietnamTime(run.CreatedAt)</td>
                                    <td>@run.DatasetName</td>
                                    <td><span title="@run.Question">@run.Question</span></td>
                                    <td>@ProviderLabel(result.ProviderKey)</td>
                                    <td>
                                        <span class="status-pill @(result.IsSuccess ? "dataset-approved-pill" : "processing")">
                                            @(result.IsSuccess ? "Thành công" : "Lỗi")
                                        </span>
                                    </td>
                                    <td class="text-end">@result.LatencyMs</td>
                                    <td class="text-end">@result.TotalTokens</td>
                                    <td class="text-end">@(result.QualityScore.HasValue ? $"{result.QualityScore}/10" : "-")</td>
                                    <td class="text-end">@(result.Faithfulness.HasValue ? result.Faithfulness.Value.ToString("0.00") : "-")</td>
                                    <td class="text-end">@(result.Relevance.HasValue ? result.Relevance.Value.ToString("0.00") : "-")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</section>

@section Scripts {
    <style>
        .mc-history-chart-grid { display: grid; gap: 14px; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
        .mc-history-chart-frame { position: relative; height: 280px; border: 1px solid var(--line); border-radius: 8px; background: var(--surface); padding: 12px; }
        .mc-history-empty { border: 1px dashed var(--line); border-radius: 8px; color: var(--muted); padding: 24px; text-align: center; }
        .mc-history-table-scroll { max-height: 420px; overflow: auto; border: 1px solid var(--line); border-radius: 8px; }
        .mc-history-table { width: 100%; min-width: 720px; border-collapse: collapse; font-size: .85rem; }
        .mc-history-table th { position: sticky; top: 0; background: var(--surface-muted); text-align: left; padding: 8px 10px; white-space: nowrap; }
        .mc-history-table td { border-top: 1px solid var(--line); padding: 8px 10px; vertical-align: top; }
        .mc-history-table td span[title] { display: block; max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .text-end { text-align: right; }
    </style>

    @if (hasStats)
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                const labels = @Html.Raw(statLabels);

                const tokensCanvas = document.getElementById("tokensChart");
                if (tokensCanvas && typeof Chart !== "undefined") {
                    new Chart(tokensCanvas, {
                        type: "bar",
                        data: {
                            labels: labels,
                            datasets: [{
                                label: "Token trung bình / lần trả lời",
                                data: @Html.Raw(statTokens),
                                backgroundColor: "#d97706"
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { title: { display: true, text: "Token trung bình theo model (chi phí)" } }
                        }
                    });
                }

                const latencyCanvas = document.getElementById("latencyChart");
                if (latencyCanvas && typeof Chart !== "undefined") {
                    new Chart(latencyCanvas, {
                        type: "bar",
                        data: {
                            labels: labels,
                            datasets: [{
                                label: "Độ trễ trung bình (ms)",
                                data: @Html.Raw(statLatency),
                                backgroundColor: "#2563eb"
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { title: { display: true, text: "Độ trễ trung bình theo model" } }
                        }
                    });
                }

                const scoreCanvas = document.getElementById("scoreChart");
                if (scoreCanvas && typeof Chart !== "undefined") {
                    new Chart(scoreCanvas, {
                        type: "bar",
                        data: {
                            labels: labels,
                            datasets: [{
                                label: "Điểm chất lượng trung bình (/10)",
                                data: @Html.Raw(statScore),
                                backgroundColor: "#0f766e"
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: { y: { min: 0, max: 10 } },
                            plugins: { title: { display: true, text: "Điểm chất lượng trung bình theo model" } }
                        }
                    });
                }

                const ragasCanvas = document.getElementById("ragasChart");
                if (ragasCanvas && typeof Chart !== "undefined") {
                    new Chart(ragasCanvas, {
                        type: "bar",
                        data: {
                            labels: labels,
                            datasets: [
                                { label: "Độ bám tài liệu", data: @Html.Raw(statFaithfulness), backgroundColor: "#7c3aed" },
                                { label: "Độ liên quan", data: @Html.Raw(statRelevance), backgroundColor: "#c026d3" }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: { y: { min: 0, max: 1 } },
                            plugins: { title: { display: true, text: "Chỉ số khách quan RAGAS (embedding, 0–1)" } }
                        }
                    });
                }
            });
        </script>
    }
}
