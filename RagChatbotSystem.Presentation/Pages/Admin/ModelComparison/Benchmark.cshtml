@page
@model RagChatbotSystem.Presentation.Pages.Admin.ModelComparison.BenchmarkModel
@{
    ViewData["Title"] = "Đánh giá RAG theo batch";
}

<main class="space-y-6" data-admin-page>
    <header class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <p class="text-xs font-bold text-accent-strong tracking-wider uppercase">RBL · External benchmark</p>
        <h1 class="mt-1 text-2xl font-grotesk font-extrabold text-ink">Đánh giá RAG theo batch</h1>
        <p class="mt-2 text-sm leading-6 text-gray-600">Nhập JSON do batch runner tạo. Context Precision/Recall dùng gold chunk ID; metric RAGAS để trống khi chưa chấm, không suy diễn số liệu.</p>
    </header>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-2"><partial name="_AdminTabs" /></div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div role="status" class="rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm font-medium text-emerald-800">@Model.StatusMessage</div>
    }

    <section class="grid gap-6 lg:grid-cols-3">
        <div class="lg:col-span-2 rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-bold text-ink">Nhập kết quả runner</h2>
            <form method="post" enctype="multipart/form-data" asp-page-handler="Import" class="mt-5 grid gap-4 md:grid-cols-2">
                <div>
                    <label asp-for="DatasetId" class="mb-1.5 block text-sm font-bold text-gray-700">Dataset</label>
                    <select asp-for="DatasetId" class="min-h-11 w-full rounded-xl border border-gray-300 bg-white px-3 text-sm focus:border-indigo-500 focus:ring-indigo-500">
                        <option value="">Chọn dataset</option>
                        @foreach (var dataset in Model.Datasets) { <option value="@dataset.DatasetId">@dataset.Name</option> }
                    </select>
                </div>
                <div>
                    <label asp-for="RunnerReport" class="mb-1.5 block text-sm font-bold text-gray-700">Runner report (.json)</label>
                    <input asp-for="RunnerReport" accept="application/json,.json" class="block min-h-11 w-full rounded-xl border border-gray-300 bg-white px-3 py-2 text-sm" />
                    <span asp-validation-for="RunnerReport" class="mt-1 block text-xs text-red-600"></span>
                </div>
                <div class="md:col-span-2 flex flex-wrap items-center gap-3">
                    <button type="submit" class="min-h-11 rounded-xl bg-accent-strong px-5 py-2 text-sm font-bold text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">Nhập kết quả</button>
                    @if (Model.DatasetId.HasValue) { <a asp-page-handler="Export" asp-route-datasetId="@Model.DatasetId" class="min-h-11 rounded-xl border border-gray-300 px-5 py-2 text-sm font-bold text-gray-700 hover:bg-gray-50">Xuất CSV</a> }
                </div>
            </form>
        </div>
        <aside class="rounded-2xl border border-blue-100 bg-blue-50 p-6">
            <h2 class="font-bold text-blue-950">Quy trình tiết kiệm chi phí</h2>
            <ol class="mt-3 list-decimal space-y-2 pl-5 text-sm leading-5 text-blue-900">
                <li>Chạy <code>--retrieval-only</code> cho mọi profile.</li>
                <li>Chọn profile tốt theo Context P/R.</li>
                <li>Chạy generation/RAGAS cho vòng cuối.</li>
            </ol>
        </aside>
    </section>

    <section class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-ink">Profile đã biết</h2>
        @if (Model.Profiles.Count == 0) { <p class="mt-3 text-sm text-gray-600">Chưa có profile được nhập từ runner.</p> }
        else { <div class="mt-4 overflow-x-auto"><table class="w-full min-w-[640px] text-left text-sm"><thead class="border-b text-xs uppercase tracking-wide text-gray-500"><tr><th class="pb-3">Profile</th><th class="pb-3">Embedding</th><th class="pb-3">Chunking</th><th class="pb-3">Top-k</th></tr></thead><tbody>@foreach (var profile in Model.Profiles) { <tr class="border-b border-gray-100"><td class="py-3 font-semibold text-ink">@profile.Name</td><td class="py-3 text-gray-700">@profile.EmbeddingModel</td><td class="py-3 text-gray-700">@profile.ChunkingStrategy</td><td class="py-3 tabular-nums text-gray-700">@profile.TopK</td></tr> }</tbody></table></div> }
    </section>

    <section class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-ink">Lịch sử batch</h2>
        @if (!Model.DatasetId.HasValue) { <p class="mt-3 text-sm text-gray-600">Chọn dataset để xem lịch sử.</p> }
        else if (Model.Runs.Count == 0) { <p class="mt-3 text-sm text-gray-600">Chưa có kết quả đã nhập cho dataset này.</p> }
        else { <div class="mt-4 overflow-x-auto"><table class="w-full min-w-[920px] text-left text-sm"><thead class="border-b text-xs uppercase tracking-wide text-gray-500"><tr><th class="pb-3">Thời điểm</th><th class="pb-3">Profile / Model</th><th class="pb-3">Trạng thái</th><th class="pb-3">Hoàn thành</th><th class="pb-3">Context P</th><th class="pb-3">Context R</th><th class="pb-3">Faithfulness</th><th class="pb-3">Relevancy</th></tr></thead><tbody>@foreach (var run in Model.Runs) { <tr class="border-b border-gray-100"><td class="py-3"><a asp-page="./RunDetail" asp-route-datasetId="@Model.DatasetId" asp-route-runId="@run.Id" class="font-medium text-blue-600 hover:underline">@run.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</a></td><td class="py-3"><p class="font-semibold text-ink">@run.ProfileName</p><p class="text-xs text-gray-500">@run.ModelName</p></td><td class="py-3"><span class="rounded-full bg-gray-100 px-2 py-1 text-xs font-bold text-gray-700">@run.Status</span></td><td class="py-3 tabular-nums">@run.CompletedQuestions/@run.TotalQuestions</td><td class="py-3 tabular-nums">@(run.ContextPrecision?.ToString("0.000") ?? "—")</td><td class="py-3 tabular-nums">@(run.ContextRecall?.ToString("0.000") ?? "—")</td><td class="py-3 tabular-nums">@(run.Faithfulness?.ToString("0.000") ?? "—")</td><td class="py-3 tabular-nums">@(run.AnswerRelevancy?.ToString("0.000") ?? "—")</td></tr> }</tbody></table></div> }
    </section>
</main>
