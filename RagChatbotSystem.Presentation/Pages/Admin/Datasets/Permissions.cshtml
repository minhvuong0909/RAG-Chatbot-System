@page "{id:guid}"
@model RagChatbotSystem.Presentation.Pages.Admin.Datasets.PermissionsModel
@{
    ViewData["Title"] = "Subject Permissions";
}

<section class="admin-page permission-page">
    <header class="admin-page-header">
        <div>
            <p class="eyebrow">Admin / Subjects / Permissions</p>
            <h1>@Model.Dataset.Name</h1>
            <p class="helper-text">Grant or revoke explicit student access to this subject.</p>
        </div>
    </header>

    <nav class="admin-tabs" aria-label="Admin sections">
        <a asp-page="/Admin/Index">Overview</a>
        <a class="active" asp-page="/Admin/Datasets/Index" aria-current="page">Subjects</a>
        <a asp-page="/Admin/Reports">Reports</a>
        <span>@Model.Dataset.Name / Permissions</span>
    </nav>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.Dataset.IsPublic)
    {
        <div class="alert alert-info">This subject is public, so approved users already have access without an explicit permission.</div>
    }

    <div class="permission-grid">
        <section class="admin-section">
            <div class="section-title"><h2>Grant access</h2></div>
            <form method="post" asp-page-handler="Grant" asp-route-id="@Model.Dataset.DatasetId" class="admin-form">
                <label for="userId">Student</label>
                <select id="userId" name="userId" required disabled="@(Model.Dataset.IsPublic || Model.AvailableStudents.Count == 0)">
                    <option value="">Select student</option>
                    @foreach (var student in Model.AvailableStudents)
                    {
                        <option value="@student.UserId">@student.FullName (@student.Email)</option>
                    }
                </select>
                <button type="submit" disabled="@(Model.Dataset.IsPublic || Model.AvailableStudents.Count == 0)">Grant permission</button>
            </form>
        </section>

        <section class="admin-section">
            <div class="section-title"><h2>Users with explicit access</h2><span>@Model.PermittedUsers.Count</span></div>
            <div class="table-responsive">
                <table class="table align-middle admin-table">
                    <thead><tr><th>User</th><th>Role</th><th class="text-end">Action</th></tr></thead>
                    <tbody>
                        @if (Model.PermittedUsers.Count == 0)
                        {
                            <tr><td colspan="3" class="text-center text-muted py-4">No explicit permissions granted.</td></tr>
                        }
                        @foreach (var user in Model.PermittedUsers)
                        {
                            <tr>
                                <td><strong>@user.FullName</strong><small>@user.Email</small></td>
                                <td><span class="status-pill">@user.Role</span></td>
                                <td class="text-end">
                                    <form method="post" asp-page-handler="Revoke" asp-route-id="@Model.Dataset.DatasetId" onsubmit="return confirm('Revoke this permission?');">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <button type="submit" class="dataset-danger-button">Revoke</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</section>
