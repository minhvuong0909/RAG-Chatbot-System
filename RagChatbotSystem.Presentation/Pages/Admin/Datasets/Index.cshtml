@page
@model RagChatbotSystem.Presentation.Pages.Admin.Datasets.IndexModel
@{
    ViewData["Title"] = "Quản lý môn học";
}

<section class="dataset-page" data-datasets-page>
    <header class="dataset-page-header">
        <div>
            <p class="eyebrow">Quản trị / Môn học</p>
            <h1>Quản lý môn học</h1>
            <p class="helper-text">Tạo môn học, kiểm soát phạm vi truy cập, cập nhật nội dung và phân quyền sinh viên.</p>
        </div>
    </header>

    <nav class="admin-tabs" aria-label="Khu vực quản trị">
        <a asp-page="/Admin/Index">Tổng quan</a>
        <a class="active" asp-page="/Admin/Datasets/Index" aria-current="page">Môn học</a>
        <a asp-page="/Admin/Reports">Báo cáo</a>
        <a asp-page="/Admin/Credits/Index">Credit</a>
        <a asp-page="/Admin/ModelComparison/Index">So sánh mô hình</a>
        <a asp-page="/Admin/Settings">Cài đặt</a>
    </nav>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div id="realtimeDatasetStatus" class="dataset-realtime-status" hidden></div>

    <div class="dataset-grid">
        <section class="dataset-create-panel">
            <div class="section-title"><h2>Tạo môn học</h2></div>
            <form method="post" asp-page-handler="Create" class="create-form">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <label asp-for="CreateInput.Name">Tên môn học</label>
                <input asp-for="CreateInput.Name" placeholder="PRN222" />
                <span asp-validation-for="CreateInput.Name" class="text-danger small"></span>
                <label asp-for="CreateInput.Description">Mô tả</label>
                <textarea asp-for="CreateInput.Description" rows="4" placeholder="Mô tả ngắn về môn học"></textarea>
                <span asp-validation-for="CreateInput.Description" class="text-danger small"></span>
                <div class="form-check dataset-check-row">
                    <input asp-for="CreateInput.IsPublic" class="form-check-input" />
                    <label asp-for="CreateInput.IsPublic" class="form-check-label">Công khai cho người dùng đã được duyệt</label>
                </div>
                <button type="submit">Tạo môn học</button>
            </form>
        </section>

        <section class="dataset-list-panel">
            <div class="section-title"><h2>Môn học</h2><span>@Model.Datasets.Count</span></div>
            @if (Model.Datasets.Count == 0)
            {
                <p class="helper-text">Chưa có môn học nào trong hệ thống.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle dataset-table">
                        <thead><tr><th>Môn học</th><th>Phạm vi truy cập</th><th>Tài liệu</th><th>Giảng viên</th><th class="text-end">Thao tác</th></tr></thead>
                        <tbody>
                            @foreach (var dataset in Model.Datasets)
                            {
                                <tr data-dataset-row="@dataset.DatasetId">
                                    <td>
                                        <form id="edit-@dataset.DatasetId" method="post" asp-page-handler="Edit" class="dataset-edit-form">
                                            <input type="hidden" name="EditInput.DatasetId" value="@dataset.DatasetId" />
                                            <input name="EditInput.Name" value="@dataset.Name" aria-label="Tên môn học" required maxlength="120" />
                                            @if (dataset.IsArchived)
                                            {
                                                <span class="status-pill processing">Đã lưu trữ</span>
                                            }
                                            <textarea name="EditInput.Description" rows="2" aria-label="Mô tả môn học" maxlength="500">@(dataset.Description ?? string.Empty)</textarea>
                                            <div class="form-check dataset-check-row">
                                                <input type="checkbox" name="EditInput.IsPublic" value="true" class="form-check-input" checked="@dataset.IsPublic" id="public-@dataset.DatasetId" />
                                                <input type="hidden" name="EditInput.IsPublic" value="false" />
                                                <label class="form-check-label" for="public-@dataset.DatasetId">Công khai</label>
                                            </div>
                                        </form>
                                    </td>
                                    <td><span class="status-pill @(dataset.IsPublic ? string.Empty : "dataset-private-pill")">@(dataset.IsPublic ? "Công khai" : "Riêng tư")</span></td>
                                    <td>@dataset.DocumentCount</td>
                                    <td title="@(dataset.AssignedTeacherName ?? "Chưa phân công")">@(dataset.AssignedTeacherName ?? "Chưa phân công")</td>
                                    <td>
                                        <div class="dataset-actions">
                                            @if (dataset.IsArchived)
                                            {
                                                <form method="post" asp-page-handler="Restore">
                                                    <input type="hidden" name="id" value="@dataset.DatasetId" />
                                                    <button type="submit" class="secondary-button">Khôi phục</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <button type="submit" form="edit-@dataset.DatasetId" class="secondary-button">Lưu</button>
                                                <a asp-page="/Admin/Datasets/Permissions" asp-route-id="@dataset.DatasetId" class="secondary-button">Phân quyền</a>
                                                <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Lưu trữ môn học này? Người dùng sẽ không thể tiếp tục thao tác, nhưng tài liệu, lịch sử trò chuyện và trích dẫn vẫn được giữ lại.');">
                                                    <input type="hidden" name="id" value="@dataset.DatasetId" />
                                                    <button type="submit" class="dataset-danger-button">Lưu trữ</button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.addEventListener("rag:dataset-changed", function (event) {
            const status = document.getElementById("realtimeDatasetStatus");
            if (!status || !event.detail) return;
            const payload = event.detail;
            status.hidden = false;
            status.textContent = `Cập nhật trực tiếp: môn học ${payload.name} đã được ${datasetActionLabel(payload.action)}.`;
            syncDatasetRow(payload);
        });

        function syncDatasetRow(payload) {
            if (!payload || !payload.datasetId) return;

            const tableBody = document.querySelector(".dataset-table tbody");
            if (!tableBody) return;

            const row = tableBody.querySelector(`[data-dataset-row="${payload.datasetId}"]`);
            if (payload.action === "deleted") {
                if (row) row.remove();
                updateDatasetCount();
                return;
            }

            if (row) {
                updateDatasetRow(row, payload);
            } else {
                tableBody.prepend(createDatasetRow(payload));
            }

            updateDatasetCount();
        }

        function updateDatasetRow(row, payload) {
            const nameInput = row.querySelector('input[name="EditInput.Name"]');
            const descriptionInput = row.querySelector('textarea[name="EditInput.Description"]');
            const publicInput = row.querySelector('input[type="checkbox"][name="EditInput.IsPublic"]');
            const cells = row.querySelectorAll("td");

            if (nameInput) nameInput.value = payload.name || "";
            if (descriptionInput) descriptionInput.value = payload.description || "";
            if (publicInput) publicInput.checked = payload.isPublic === true;
            if (cells[1]) cells[1].innerHTML = visibilityPill(payload);
            if (cells[2]) cells[2].textContent = String(payload.documentCount || 0);
            if (cells[3]) cells[3].textContent = payload.assignedTeacherName || "Chưa phân công";
        }

        function createDatasetRow(payload) {
            const row = document.createElement("tr");
            row.dataset.datasetRow = payload.datasetId;
            row.innerHTML = `
                <td>
                    <form id="edit-${payload.datasetId}" method="post" action="?handler=Edit" class="dataset-edit-form">
                        ${antiForgeryInput()}
                        <input type="hidden" name="EditInput.DatasetId" value="${escapeHtml(payload.datasetId)}" />
                        <input name="EditInput.Name" value="${escapeHtml(payload.name || "")}" aria-label="Tên môn học" required maxlength="120" />
                        <textarea name="EditInput.Description" rows="2" aria-label="Mô tả môn học" maxlength="500">${escapeHtml(payload.description || "")}</textarea>
                        <div class="form-check dataset-check-row">
                            <input type="checkbox" name="EditInput.IsPublic" value="true" class="form-check-input" ${payload.isPublic ? "checked" : ""} id="public-${escapeHtml(payload.datasetId)}" />
                            <input type="hidden" name="EditInput.IsPublic" value="false" />
                            <label class="form-check-label" for="public-${escapeHtml(payload.datasetId)}">Công khai</label>
                        </div>
                    </form>
                </td>
                <td>${visibilityPill(payload)}</td>
                <td>${payload.documentCount || 0}</td>
                <td title="${escapeHtml(payload.assignedTeacherName || "Chưa phân công")}">${escapeHtml(payload.assignedTeacherName || "Chưa phân công")}</td>
                <td>
                    <div class="dataset-actions">
                        <button type="submit" form="edit-${escapeHtml(payload.datasetId)}" class="secondary-button">Lưu</button>
                        <a href="/Admin/Datasets/Permissions?id=${encodeURIComponent(payload.datasetId)}" class="secondary-button">Phân quyền</a>
                        <form method="post" action="?handler=Delete" onsubmit="return confirm('Lưu trữ môn học này? Người dùng sẽ không thể tiếp tục thao tác, nhưng tài liệu, lịch sử trò chuyện và trích dẫn vẫn được giữ lại.');">
                            ${antiForgeryInput()}
                            <input type="hidden" name="id" value="${escapeHtml(payload.datasetId)}" />
                            <button type="submit" class="dataset-danger-button">Lưu trữ</button>
                        </form>
                    </div>
                </td>
            `;
            return row;
        }

        function visibilityPill(payload) {
            return `<span class="status-pill ${payload.isPublic ? "" : "dataset-private-pill"}">${payload.isPublic ? "Công khai" : "Riêng tư"}</span>`;
        }

        function datasetActionLabel(action) {
            return ({ created: "tạo", updated: "cập nhật", archived: "lưu trữ", restored: "khôi phục" })[action] || "cập nhật";
        }

        function antiForgeryInput() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            return token ? `<input name="__RequestVerificationToken" type="hidden" value="${escapeHtml(token.value)}" />` : "";
        }

        function updateDatasetCount() {
            const count = document.querySelector(".dataset-list-panel .section-title span");
            const rows = document.querySelectorAll(".dataset-table tbody tr[data-dataset-row]");
            if (count) count.textContent = String(rows.length);
        }

        function escapeHtml(value) {
            return String(value || "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }
    </script>
}
