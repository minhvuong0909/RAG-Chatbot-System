@page
@model RagChatbotSystem.Presentation.Pages.Admin.Datasets.IndexModel
@{
    ViewData["Title"] = "Subject Management";
}

<section class="dataset-page" data-datasets-page>
    <header class="dataset-page-header">
        <div>
            <p class="eyebrow">Admin / Subjects</p>
            <h1>Subject Management</h1>
            <p class="helper-text">Create subjects, control visibility, approve availability, and manage access.</p>
        </div>
    </header>

    <nav class="admin-tabs" aria-label="Admin sections">
        <a asp-page="/Admin/Index">Overview</a>
        <a class="active" asp-page="/Admin/Datasets/Index" aria-current="page">Subjects</a>
    </nav>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div id="realtimeDatasetStatus" class="dataset-realtime-status" hidden></div>

    <div class="dataset-grid">
        <section class="dataset-create-panel">
            <div class="section-title"><h2>Create subject</h2></div>
            <form method="post" asp-page-handler="Create" class="create-form">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <label asp-for="CreateInput.Name">Subject name</label>
                <input asp-for="CreateInput.Name" placeholder="PRN222" />
                <span asp-validation-for="CreateInput.Name" class="text-danger small"></span>
                <label asp-for="CreateInput.Description">Description</label>
                <textarea asp-for="CreateInput.Description" rows="4" placeholder="Short subject description"></textarea>
                <span asp-validation-for="CreateInput.Description" class="text-danger small"></span>
                <div class="form-check dataset-check-row">
                    <input asp-for="CreateInput.IsPublic" class="form-check-input" />
                    <label asp-for="CreateInput.IsPublic" class="form-check-label">Public for approved users</label>
                </div>
                <button type="submit">Create subject</button>
            </form>
        </section>

        <section class="dataset-list-panel">
            <div class="section-title"><h2>Subjects</h2><span>@Model.Datasets.Count</span></div>
            @if (Model.Datasets.Count == 0)
            {
                <p class="helper-text">No subjects available in the system.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle dataset-table">
                        <thead><tr><th>Subject</th><th>Visibility</th><th>Status</th><th>Documents</th><th>Teacher</th><th class="text-end">Actions</th></tr></thead>
                        <tbody>
                            @foreach (var dataset in Model.Datasets)
                            {
                                <tr data-dataset-row="@dataset.DatasetId">
                                    <td>
                                        <form id="edit-@dataset.DatasetId" method="post" asp-page-handler="Edit" class="dataset-edit-form">
                                            <input type="hidden" name="EditInput.DatasetId" value="@dataset.DatasetId" />
                                            <input name="EditInput.Name" value="@dataset.Name" aria-label="Subject name" required maxlength="120" />
                                            <textarea name="EditInput.Description" rows="2" aria-label="Subject description" maxlength="500">@(dataset.Description ?? string.Empty)</textarea>
                                            <div class="form-check dataset-check-row">
                                                <input type="checkbox" name="EditInput.IsPublic" value="true" class="form-check-input" checked="@dataset.IsPublic" id="public-@dataset.DatasetId" />
                                                <input type="hidden" name="EditInput.IsPublic" value="false" />
                                                <label class="form-check-label" for="public-@dataset.DatasetId">Public</label>
                                            </div>
                                        </form>
                                    </td>
                                    <td><span class="status-pill @(dataset.IsPublic ? string.Empty : "dataset-private-pill")">@(dataset.IsPublic ? "Public" : "Private")</span></td>
                                    <td><span class="status-pill @(dataset.IsApproved ? "dataset-approved-pill" : "processing")">@(dataset.IsApproved ? "Approved" : "Pending")</span></td>
                                    <td>@dataset.DocumentCount</td>
                                    <td>@(dataset.AssignedTeacherName ?? "Unassigned")</td>
                                    <td>
                                        <div class="dataset-actions">
                                            <button type="submit" form="edit-@dataset.DatasetId" class="secondary-button">Save</button>
                                            <a asp-page="/Admin/Datasets/Permissions" asp-route-id="@dataset.DatasetId" class="secondary-button">Permissions</a>
                                            <form method="post" asp-page-handler="Approve">
                                                <input type="hidden" name="id" value="@dataset.DatasetId" />
                                                <input type="hidden" name="approve" value="@(!dataset.IsApproved)" />
                                                <button type="submit" class="secondary-button">@(dataset.IsApproved ? "Unapprove" : "Approve")</button>
                                            </form>
                                            <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Delete this subject and all documents inside it?');">
                                                <input type="hidden" name="id" value="@dataset.DatasetId" />
                                                <button type="submit" class="dataset-danger-button">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.addEventListener("rag:dataset-changed", function (event) {
            const status = document.getElementById("realtimeDatasetStatus");
            if (!status || !event.detail) return;
            status.hidden = false;
            status.textContent = `Realtime: ${event.detail.name} was ${event.detail.action}.`;
            window.setTimeout(function () { window.location.reload(); }, 700);
        });
    </script>
}
