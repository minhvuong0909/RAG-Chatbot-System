@page
@model RagChatbotSystem.Presentation.Pages.Datasets.IndexModel
@{
    ViewData["Title"] = "Manage Subjects";
}

<div class="container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="eyebrow" style="color: var(--muted); text-transform: uppercase; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px;">Workspace Settings</p>
            <h2 class="fw-bold m-0" style="color: var(--ink);">Subjects Management</h2>
        </div>
        <a asp-page="/Index" class="btn btn-outline-secondary" style="border-radius: 8px; font-weight: 600; border-color: var(--line);">Back to Workspace</a>
    </div>

    <!-- Alert Messages -->
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 8px;">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 8px;">
            @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Create Subject Form (Admin Only) -->
        @if (User.IsInRole("Admin"))
        {
            <div class="col-lg-4">
                <div class="card border-0 shadow-soft" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important;">
                    <div class="card-header bg-transparent border-0 pt-4 px-4">
                        <h4 class="fw-bold m-0" style="color: var(--ink);">Create Subject</h4>
                        <p class="text-muted small m-0 mt-1">Add a new dataset for document grounding.</p>
                    </div>
                    <div class="card-body px-4 pb-4 pt-2">
                        <form method="post" asp-page-handler="CreateDataset">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label small fw-bold" style="color: var(--ink-soft);">Subject Name</label>
                                <input name="name" type="text" class="form-control" placeholder="e.g. PRN222 C# programming" required style="border-radius: 8px; border-color: var(--line);" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold" style="color: var(--ink-soft);">Description</label>
                                <textarea name="description" rows="3" class="form-control" placeholder="Brief explanation of subject content..." style="border-radius: 8px; border-color: var(--line);"></textarea>
                            </div>
                            <div class="mb-4 d-flex align-items-center gap-2">
                                <input type="checkbox" name="isPublic" id="isPublic" value="true" checked class="form-check-input" style="cursor: pointer;" />
                                <label for="isPublic" class="form-check-label small text-muted" style="cursor: pointer; user-select: none;">Make subject public to all students</label>
                            </div>
                            <button type="submit" class="btn btn-primary w-100" style="border-radius: 8px; font-weight: 600; background: var(--accent); border: none;">Create Subject</button>
                        </form>
                    </div>
                </div>
            </div>
        }

        <!-- Subjects List -->
        <div class="@(User.IsInRole("Admin") ? "col-lg-8" : "col-12")">
            <div class="card border-0 shadow-soft" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important;">
                <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="fw-bold m-0" style="color: var(--ink);">Subjects List</h4>
                        <p class="text-muted small m-0 mt-1">Available subjects for AI document retrieving.</p>
                    </div>
                    <span class="badge bg-secondary" style="border-radius: 20px; padding: 6px 12px; font-weight: 600; background: var(--bg-elevated) !important; color: var(--ink-soft) !important;">
                        @Model.Datasets.Count subject(s)
                    </span>
                </div>
                <div class="card-body px-4 pb-4 pt-2">
                    @if (Model.Datasets.Count == 0)
                    {
                        <div class="text-center py-5">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted mb-3"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path><path d="M6 6h10"></path><path d="M6 10h10"></path></svg>
                            <p class="text-muted">No subjects assigned or created yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle" style="margin: 0;">
                                <thead>
                                    <tr style="border-bottom: 2px solid var(--line);">
                                        <th scope="col" class="pb-3 text-muted small text-uppercase" style="font-weight: 700;">Subject Info</th>
                                        <th scope="col" class="pb-3 text-muted small text-uppercase" style="font-weight: 700;">Visibility</th>
                                        <th scope="col" class="pb-3 text-muted small text-uppercase" style="font-weight: 700;">Status</th>
                                        <th scope="col" class="pb-3 text-muted small text-uppercase" style="font-weight: 700;">Documents</th>
                                        <th scope="col" class="pb-3 text-muted small text-uppercase text-end" style="font-weight: 700;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ds in Model.Datasets)
                                    {
                                        <tr style="border-bottom: 1px solid var(--line);">
                                            <td class="py-3">
                                                <div class="fw-bold" style="color: var(--ink);">@ds.Name</div>
                                                @if (!string.IsNullOrWhiteSpace(ds.Description))
                                                {
                                                    <div class="text-muted small text-truncate" style="max-width: 250px;" title="@ds.Description">@ds.Description</div>
                                                }
                                                <div class="text-muted small" style="font-size: 0.75rem;">Created: @ds.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                            </td>
                                            <td class="py-3">
                                                @if (ds.IsPublic)
                                                {
                                                    <span class="badge" style="background: var(--success-soft); color: var(--success); font-weight: 600; border-radius: 4px; padding: 4px 8px;">Public</span>
                                                }
                                                else
                                                {
                                                    <span class="badge" style="background: var(--bg-elevated); color: var(--muted); font-weight: 600; border-radius: 4px; padding: 4px 8px;">Private</span>
                                                }
                                            </td>
                                            <td class="py-3">
                                                @if (ds.IsApproved)
                                                {
                                                    <span class="badge" style="background: var(--info-soft); color: var(--info); font-weight: 600; border-radius: 4px; padding: 4px 8px;">Approved</span>
                                                }
                                                else
                                                {
                                                    <span class="badge" style="background: var(--warning-soft); color: var(--warning); font-weight: 600; border-radius: 4px; padding: 4px 8px;">Pending</span>
                                                }
                                            </td>
                                            <td class="py-3">
                                                <span class="fw-semibold" style="color: var(--ink-soft);">@ds.DocumentCount</span>
                                            </td>
                                            <td class="py-3 text-end">
                                                <div class="d-flex justify-content-end gap-2">
                                                    <a asp-page="/Index" asp-route-datasetId="@ds.DatasetId" class="btn btn-sm btn-outline-primary" style="border-radius: 6px; font-weight: 600; border-color: var(--accent); color: var(--accent);">
                                                        Chat
                                                    </a>
                                                    <a asp-page="/Documents/Index" asp-route-datasetId="@ds.DatasetId" class="btn btn-sm btn-outline-secondary" style="border-radius: 6px; font-weight: 600; border-color: var(--line); color: var(--ink-soft);">
                                                        Documents
                                                    </a>
                                                    @if (User.IsInRole("Admin") || ds.CreatedBy == Guid.Parse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? ""))
                                                    {
                                                        <form method="post" asp-page-handler="DeleteDataset" class="d-inline" onsubmit="return confirm('Delete this subject and all documents inside it?');">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@ds.DatasetId" />
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius: 6px; font-weight: 600; border-color: rgba(220, 53, 69, 0.2);">
                                                                Delete
                                                            </button>
                                                        </form>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
