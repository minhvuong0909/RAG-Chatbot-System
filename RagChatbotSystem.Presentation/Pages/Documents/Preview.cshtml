@page
@model RagChatbotSystem.Presentation.Pages.Documents.PreviewModel
@{
    ViewData["Title"] = "Xem trước tài liệu";
}

@functions {
    private static string StatusLabel(string? status) => status?.ToLowerInvariant() switch
    {
        "uploaded" or "pending" => "Đang chờ",
        "processing" => "Đang xử lý",
        "completed" => "Đã xử lý",
        "failed" => "Xử lý thất bại",
        "deleted" => "Đã xóa",
        _ => "Đang chờ"
    };

    private static string StatusClass(string? status) => status?.ToLowerInvariant() switch
    {
        "uploaded" or "pending" => "bg-gray-100 text-gray-600 border-gray-200",
        "processing" => "bg-blue-50 text-blue-700 border-blue-200",
        "completed" => "bg-green-50 text-green-700 border-green-200",
        "failed" => "bg-red-50 text-red-700 border-red-200",
        "deleted" => "bg-gray-100 text-gray-500 border-gray-200 line-through",
        _ => "bg-gray-100 text-gray-600 border-gray-200"
    };
}

<div class="space-y-6 max-w-[1080px] mx-auto">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 bg-white/60 backdrop-blur-xl border border-white shadow-sm p-6 rounded-2xl">
        <div class="min-w-0">
            <p class="text-xs font-bold text-accent-strong tracking-wider uppercase mb-1">Xem trước tài liệu</p>
            <h1 class="text-2xl font-grotesk font-extrabold text-ink tracking-tight truncate" title="@Model.FileName">@Model.FileName</h1>
            <div class="text-sm text-gray-500 mt-2 flex items-center gap-2 flex-wrap">
                <span class="font-medium">@Model.DatasetName</span>
                <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                <span class="uppercase tracking-wider font-bold">@Model.FileType</span>
                <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                <span>@Math.Ceiling(Model.FileSize / 1024.0) KB</span>
                <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-bold border @StatusClass(Model.Status)">
                    @StatusLabel(Model.Status)
                </span>
            </div>
        </div>
        <a asp-page="/Documents/Index" asp-route-datasetId="@Model.DatasetId" class="shrink-0 inline-flex items-center px-4 py-2 border border-gray-200 rounded-xl shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Quay lại tài liệu
        </a>
    </div>

    @if (Model.Preview.IsDeleted)
    {
        <div class="p-4 rounded-xl bg-gray-50 border border-gray-200 flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <p class="text-sm text-gray-600">Tài liệu này đã bị xóa khỏi danh sách sử dụng của chatbot và chỉ được giữ lại để truy vết.</p>
        </div>
    }

    @if (!Model.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase))
    {
        <div class="p-4 rounded-xl bg-amber-50 border border-amber-200 flex items-start gap-3">
            <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            <p class="text-sm font-medium text-amber-800">Tài liệu chưa xử lý hoàn tất. Trạng thái hiện tại: <strong class="font-bold">@StatusLabel(Model.Status)</strong>.</p>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Preview.ProcessError))
    {
        <div class="p-4 rounded-xl bg-red-50 border border-red-200 flex items-start gap-3">
            <svg class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            <p class="text-sm font-medium text-red-800">Không thể xử lý tài liệu này. Vui lòng thử lại hoặc tải lên tệp khác.</p>
        </div>
    }

    <!-- Content Card -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-50 bg-white">
            <h2 class="text-lg font-bold text-ink flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-indigo-50 text-accent-strong flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                </span>
                Các chunk đã lập chỉ mục
            </h2>
            <p class="text-sm text-gray-500 mt-2 ml-10">@Model.Chunks.Count chunk được trích xuất từ tài liệu này.</p>
        </div>

        <div class="p-6">
            @if (Model.Chunks.Count == 0)
            {
                <div class="text-center py-12">
                    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-50 text-gray-400 mb-4">
                        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path></svg>
                    </div>
                    <p class="text-sm text-gray-500">Chưa có chunk nào để xem trước.</p>
                </div>
            }
            else
            {
                <div class="space-y-4">
                    @foreach (var chunk in Model.Chunks)
                    {
                        <article class="bg-gray-50 border border-gray-100 rounded-xl p-5" id="chunk-@chunk.ChunkId" data-chunk-id="@chunk.ChunkId" data-chunk-index="@chunk.ChunkIndex">
                            <div class="flex items-center justify-between mb-3">
                                <strong class="text-sm font-bold text-ink bg-white px-2.5 py-1 rounded-md shadow-sm border border-gray-100">Chunk #@chunk.ChunkIndex</strong>
                                <span class="text-xs font-medium text-gray-400">Trang @chunk.PageNumber</span>
                            </div>
                            <pre class="text-sm text-gray-700 whitespace-pre-wrap break-words font-sans leading-relaxed">@chunk.Content</pre>
                            
                            @if (!string.IsNullOrWhiteSpace(chunk.MetadataJson))
                            {
                                <details class="mt-4 group">
                                    <summary class="text-xs font-bold text-gray-400 uppercase tracking-wider cursor-pointer hover:text-accent-strong transition-colors list-none flex items-center gap-1">
                                        <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
                                        Siêu dữ liệu
                                    </summary>
                                    <div class="mt-2 p-3 bg-gray-900 rounded-lg overflow-x-auto">
                                        <code class="text-xs text-green-400 font-mono whitespace-pre-wrap break-all">@chunk.MetadataJson</code>
                                    </div>
                                </details>
                            }
                        </article>
                    }
                </div>
            }
        </div>
    </div>
</div>
