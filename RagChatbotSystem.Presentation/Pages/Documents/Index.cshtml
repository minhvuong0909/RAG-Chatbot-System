@page
@using System.Text.Encodings.Web
@model RagChatbotSystem.Presentation.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Quản lý tài liệu";
    var hasCompletedDocument = Model.Documents.Any(document => document.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase));
}

@functions {
    private static string StatusLabel(string? status) => status?.ToLowerInvariant() switch
    {
        "uploaded" or "pending" => "Đang chờ",
        "processing" => "Đang xử lý",
        "completed" => "Đã xử lý",
        "failed" => "Xử lý thất bại",
        "deleted" => "Đã xóa",
        _ => "Đang chờ"
    };

    private static string StatusClass(string? status) => status?.ToLowerInvariant() switch
    {
        "uploaded" or "pending" => "pending",
        "processing" => "processing",
        "completed" => "completed",
        "failed" => "failed",
        "deleted" => "deleted",
        _ => "pending"
    };
}

<div id="documents-workspace" data-rag-app data-selected-dataset-id="@Model.DatasetId" class="container py-4 document-workspace">
    <header class="document-page-header">
        <div>
            <p class="eyebrow"><a asp-page="/Datasets/Index">Môn học</a> <span aria-hidden="true">/</span> <span title="@Model.Dataset.Name">@Model.Dataset.Name</span></p>
            <h1>Quản lý tài liệu</h1>
            <p class="helper-text">Tài liệu đã xử lý sẽ được dùng làm nguồn tham khảo khi chatbot trả lời cho môn học này.</p>
        </div>
        <div class="document-header-actions">
            <a asp-page="/Datasets/Index" class="btn btn-outline-secondary">Danh sách môn học</a>
            <a asp-page="/Index" asp-route-datasetId="@Model.DatasetId" class="btn btn-primary">Mở trò chuyện</a>
        </div>
    </header>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    @if (!hasCompletedDocument)
    {
        <div class="document-readiness-notice" role="status">
            Chatbot chưa thể trả lời dựa trên môn học này vì chưa có tài liệu đã xử lý.
        </div>
    }

    <div class="row g-4 align-items-start">
        <div class="col-lg-4">
            <section class="card border-0 shadow-soft document-upload-card">
                <div class="card-body p-4">
                    <h2 class="h4 fw-bold mb-1">Tải tài liệu lên</h2>
                    <p class="text-muted small mb-3">Tải từng tệp để hệ thống trích xuất nội dung, tạo chunk và lập chỉ mục RAG.</p>

                    <form method="post" asp-page-handler="Upload" enctype="multipart/form-data" id="upload-doc-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="datasetId" value="@Model.DatasetId" />
                        <input type="hidden" id="overwrite-existing-file-name" name="overwriteExistingFileName" value="false" />

                        <div id="upload-dropzone" class="upload-dropzone" role="button" tabindex="0" aria-describedby="upload-support-text" onclick="if (!this.dataset.uploading) document.getElementById('file-upload').click();">
                            <div id="upload-idle-state">
                                <div class="upload-icon" aria-hidden="true">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                                </div>
                                <span class="upload-primary">Kéo và thả tệp vào đây</span>
                                <span class="upload-secondary">hoặc bấm để chọn tệp</span>
                            </div>
                            <div id="upload-loading-state" class="upload-loading-state" aria-live="polite">
                                <div class="spinner-border text-primary mb-3" role="status"></div>
                                <span class="upload-primary">Đang tải lên và xử lý...</span>
                                <span class="upload-secondary">Hệ thống đang trích xuất nội dung và lập chỉ mục RAG.</span>
                            </div>
                            <input id="file-upload" name="file" type="file" accept=".pdf,.txt,.docx" required hidden onchange="triggerUpload();" />
                        </div>
                        <p id="upload-support-text" class="upload-support-text mb-0">Hỗ trợ PDF, DOCX, TXT. Dung lượng tối đa 50 MB.</p>
                    </form>
                </div>
            </section>
        </div>

        <div class="col-lg-8">
            <section class="card border-0 shadow-soft document-list-card">
                <div class="card-body p-4">
                    <div class="document-list-heading">
                        <div>
                            <h2 class="h4 fw-bold mb-1">Tài liệu của môn học</h2>
                            <p class="text-muted small mb-0">Chỉ các tài liệu đã xử lý mới được chatbot sử dụng để trả lời.</p>
                        </div>
                        <span class="document-count" data-document-count>@Model.Documents.Count tệp</span>
                    </div>

                    <div id="document-list" class="document-list" data-document-list>
                        @if (Model.Documents.Count == 0)
                        {
                            <div class="document-empty-state" id="documents-empty-state">
                                <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
                                <p>Chưa có tài liệu nào trong môn học này.</p>
                                <span>Tải lên một tệp để chatbot có nguồn tham khảo.</span>
                            </div>
                        }
                        else
                        {
                            @foreach (var doc in Model.Documents)
                            {
                                <article class="document-item" data-document-id="@doc.DocumentId">
                                    <div class="document-item-main">
                                        <div class="document-file-icon" aria-hidden="true">@doc.FileType.ToUpperInvariant()</div>
                                        <div class="document-file-details">
                                            <strong class="document-file-name" title="@doc.FileName">@doc.FileName</strong>
                                            <span>@Math.Ceiling(doc.FileSize / 1024.0) KB <span aria-hidden="true">·</span> Tải lên @doc.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                        </div>
                                    </div>
                                    <div class="document-item-status">
                                        <span class="status-badge @StatusClass(doc.Status)" data-document-status>@StatusLabel(doc.Status)</span>
                                        <div class="progress" aria-label="Tiến độ xử lý tài liệu">
                                            <div class="progress-bar" data-document-progress role="progressbar" style="width: @(doc.Status.Equals("Processing", StringComparison.OrdinalIgnoreCase) ? "55%" : doc.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase) ? "100%" : "0%")" aria-valuenow="@(doc.Status.Equals("Processing", StringComparison.OrdinalIgnoreCase) ? "55" : doc.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase) ? "100" : "0")" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(doc.ProcessError))
                                    {
                                        <p class="document-processing-error mb-0">Không thể xử lý tài liệu này. Vui lòng thử lại hoặc tải lên tệp khác.</p>
                                    }
                                    <div class="document-item-actions">
                                        <a asp-page="/Documents/Preview" asp-route-documentId="@doc.DocumentId" class="btn btn-sm btn-outline-secondary">Xem chunk</a>
                                        <form method="post" asp-page-handler="DeleteDocument" class="d-inline" data-delete-document data-file-name="@doc.FileName">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="datasetId" value="@Model.DatasetId" />
                                            <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    </div>
                                </article>
                            }
                        }
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

<div id="documentProcessingOverlay" class="document-processing-overlay" hidden aria-live="polite">
    <div class="document-processing-panel">
        <div class="spinner-border text-primary" role="status"></div>
        <h2>Đang xử lý tài liệu</h2>
        <p>Hệ thống đang trích xuất nội dung, tạo chunk và lập chỉ mục RAG. Vui lòng giữ trang này mở cho đến khi hoàn tất.</p>
    </div>
</div>

<div id="overwriteDocumentModal" class="document-modal" hidden role="dialog" aria-modal="true" aria-labelledby="overwriteDocumentTitle">
    <div class="document-modal-backdrop" data-modal-dismiss></div>
    <div class="document-modal-panel" role="document">
        <h2 id="overwriteDocumentTitle">Tài liệu trùng lặp</h2>
        <p>Hệ thống phát hiện một tài liệu có tên tệp trùng với tệp bạn vừa chọn.</p>
        <p class="text-muted small mb-0">Sau khi tệp mới được xử lý thành công, tài liệu hiện tại sẽ không còn được chatbot dùng để trả lời. Dữ liệu cũ vẫn được giữ để truy vết.</p>
        <div class="document-modal-actions">
            <button type="button" class="btn btn-outline-secondary" data-modal-dismiss>Giữ tài liệu hiện tại</button>
            <button type="button" class="btn btn-primary" id="confirm-overwrite-document">Thay thế bằng tệp mới</button>
        </div>
    </div>
</div>

<div id="deleteDocumentModal" class="document-modal" hidden role="dialog" aria-modal="true" aria-labelledby="deleteDocumentTitle">
    <div class="document-modal-backdrop" data-modal-dismiss></div>
    <div class="document-modal-panel" role="document">
        <h2 id="deleteDocumentTitle">Xóa tài liệu</h2>
        <p>Bạn có chắc muốn xóa <strong id="delete-document-file-name"></strong>?</p>
        <p class="text-muted small mb-0">Tài liệu sẽ không còn được chatbot sử dụng để trả lời. Bản ghi được giữ lại để truy vết.</p>
        <div class="document-modal-actions">
            <button type="button" class="btn btn-outline-secondary" data-modal-dismiss>Hủy</button>
            <button type="button" class="btn btn-outline-danger" id="confirm-delete-document">Xóa tài liệu</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const uploadDocForm = document.getElementById("upload-doc-form");
        const fileUploadInput = document.getElementById("file-upload");
        const overwriteExistingFileNameInput = document.getElementById("overwrite-existing-file-name");
        const dropzone = document.getElementById("upload-dropzone");
        const processingOverlay = document.getElementById("documentProcessingOverlay");
        const overwriteModal = document.getElementById("overwriteDocumentModal");
        const deleteModal = document.getElementById("deleteDocumentModal");
        const deleteFileName = document.getElementById("delete-document-file-name");
        let pendingDeleteForm = null;
        const existingDocumentNames = new Set([
            @foreach (var doc in Model.Documents)
            {
                @: "@JavaScriptEncoder.Default.Encode(doc.FileName.ToLowerInvariant())",
            }
        ]);

        function statusInfo(status) {
            const normalized = String(status || "Uploaded").toLowerCase();
            const labels = {
                uploaded: "Đang chờ", pending: "Đang chờ", processing: "Đang xử lý",
                completed: "Đã xử lý", failed: "Xử lý thất bại", deleted: "Đã xóa"
            };
            const classes = { uploaded: "pending", pending: "pending", processing: "processing", completed: "completed", failed: "failed", deleted: "deleted" };
            return { label: labels[normalized] || "Đang chờ", cssClass: classes[normalized] || "pending" };
        }

        function showModal(modal) {
            if (!modal) return;
            modal.hidden = false;
            modal.querySelector("button")?.focus();
        }

        function hideModal(modal) {
            if (modal) modal.hidden = true;
        }

        function showProcessing() {
            document.getElementById("upload-idle-state").style.display = "none";
            document.getElementById("upload-loading-state").style.display = "flex";
            dropzone.dataset.uploading = "true";
            processingOverlay.hidden = false;
        }

        function submitUpload(overwrite) {
            if (overwriteExistingFileNameInput) overwriteExistingFileNameInput.value = overwrite ? "true" : "false";
            hideModal(overwriteModal);
            showProcessing();
            uploadDocForm.submit();
        }

        function triggerUpload() {
            if (!fileUploadInput.files.length || !uploadDocForm) return;
            const selectedFileName = fileUploadInput.files[0].name.toLowerCase();
            if (existingDocumentNames.has(selectedFileName)) {
                showModal(overwriteModal);
                return;
            }
            submitUpload(false);
        }

        document.getElementById("confirm-overwrite-document")?.addEventListener("click", () => submitUpload(true));
        document.getElementById("confirm-delete-document")?.addEventListener("click", () => {
            if (pendingDeleteForm) {
                pendingDeleteForm.dataset.confirmed = "true";
                pendingDeleteForm.requestSubmit();
            }
        });
        document.querySelectorAll("[data-modal-dismiss]").forEach(button => button.addEventListener("click", () => {
            hideModal(overwriteModal);
            hideModal(deleteModal);
            if (fileUploadInput && overwriteModal?.hidden) fileUploadInput.value = "";
            pendingDeleteForm = null;
        }));

        document.addEventListener("submit", event => {
            const form = event.target;
            if (!(form instanceof HTMLFormElement) || !form.matches("[data-delete-document]")) return;
            if (form.dataset.confirmed === "true") {
                form.dataset.confirmed = "false";
                return;
            }
            event.preventDefault();
            pendingDeleteForm = form;
            deleteFileName.textContent = form.dataset.fileName || "tài liệu này";
            showModal(deleteModal);
        });

        if (uploadDocForm && processingOverlay) {
            uploadDocForm.addEventListener("submit", () => {
                if (!dropzone.dataset.uploading) showProcessing();
            });
        }

        if (dropzone) {
            dropzone.addEventListener("keydown", event => {
                if ((event.key === "Enter" || event.key === " ") && !dropzone.dataset.uploading) {
                    event.preventDefault();
                    fileUploadInput.click();
                }
            });
            ["dragenter", "dragover"].forEach(eventName => dropzone.addEventListener(eventName, event => {
                event.preventDefault();
                if (!dropzone.dataset.uploading) dropzone.classList.add("is-dragging");
            }));
            ["dragleave", "drop"].forEach(eventName => dropzone.addEventListener(eventName, event => {
                event.preventDefault();
                dropzone.classList.remove("is-dragging");
            }));
            dropzone.addEventListener("drop", event => {
                if (dropzone.dataset.uploading || !event.dataTransfer.files.length) return;
                fileUploadInput.files = event.dataTransfer.files;
                triggerUpload();
            });
        }

        function escapeHtml(value) {
            return String(value || "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
        }

        function antiForgeryInput() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            return token ? `<input name="__RequestVerificationToken" type="hidden" value="${escapeHtml(token.value)}" />` : "";
        }

        function createDocumentRow(payload) {
            const item = document.createElement("article");
            item.className = "document-item";
            item.dataset.documentId = payload.documentId;
            const status = statusInfo(payload.status || payload.action);
            const percent = Math.max(0, Math.min(100, payload.percentComplete || 0));
            const sizeKb = Math.ceil((payload.fileSize || 0) / 1024);
            const dateStr = new Date().toLocaleString("vi-VN", { dateStyle: "short", timeStyle: "short" });
            item.innerHTML = `
                <div class="document-item-main"><div class="document-file-icon" aria-hidden="true">${escapeHtml(String(payload.fileType || "").toUpperCase())}</div><div class="document-file-details"><strong class="document-file-name" title="${escapeHtml(payload.fileName)}">${escapeHtml(payload.fileName)}</strong><span>${sizeKb} KB <span aria-hidden="true">·</span> Tải lên ${dateStr}</span></div></div>
                <div class="document-item-status"><span class="status-badge ${status.cssClass}" data-document-status>${status.label}</span><div class="progress" aria-label="Tiến độ xử lý tài liệu"><div class="progress-bar" data-document-progress role="progressbar" style="width:${percent}%" aria-valuenow="${percent}" aria-valuemin="0" aria-valuemax="100"></div></div></div>
                <div class="document-item-actions"><a href="/Documents/Preview?documentId=${encodeURIComponent(payload.documentId)}" class="btn btn-sm btn-outline-secondary">Xem chunk</a><form method="post" action="?handler=DeleteDocument" class="d-inline" data-delete-document data-file-name="${escapeHtml(payload.fileName)}">${antiForgeryInput()}<input type="hidden" name="datasetId" value="${escapeHtml(payload.datasetId)}" /><input type="hidden" name="documentId" value="${escapeHtml(payload.documentId)}" /><button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button></form></div>`;
            return item;
        }

        function showEmptyState(docList) {
            docList.innerHTML = `<div class="document-empty-state" id="documents-empty-state"><svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg><p>Chưa có tài liệu nào trong môn học này.</p><span>Tải lên một tệp để chatbot có nguồn tham khảo.</span></div>`;
        }

        function updateDocumentCount() {
            const count = document.querySelector("[data-document-count]");
            const rows = document.querySelectorAll("[data-document-id]");
            if (count) count.textContent = `${rows.length} tệp`;
        }

        window.addEventListener("rag:document-progress", event => {
            const payload = event.detail;
            if (!payload || !payload.documentId || (payload.datasetId && String(payload.datasetId) !== "@Model.DatasetId")) return;
            const docList = document.getElementById("document-list");
            const documentRow = document.querySelector(`[data-document-id="${payload.documentId}"]`);
            if (payload.action === "deleted") {
                documentRow?.remove();
                if (docList && !docList.querySelector("[data-document-id]")) showEmptyState(docList);
                updateDocumentCount();
                return;
            }
            if (!documentRow) {
                if (docList && ["completed", "uploaded", "processing", "failed"].includes(payload.action)) {
                    document.getElementById("documents-empty-state")?.remove();
                    docList.prepend(createDocumentRow(payload));
                    updateDocumentCount();
                }
                return;
            }
            const status = statusInfo(payload.status || payload.action);
            const statusBadge = documentRow.querySelector("[data-document-status]");
            if (statusBadge) {
                statusBadge.textContent = status.label;
                statusBadge.className = `status-badge ${status.cssClass}`;
            }
            const progressBar = documentRow.querySelector("[data-document-progress]");
            if (progressBar) {
                const percent = Math.max(0, Math.min(100, payload.percentComplete || 0));
                progressBar.style.width = `${percent}%`;
                progressBar.setAttribute("aria-valuenow", String(percent));
            }
        });
    </script>
    <style>
        .document-workspace { max-width: 1280px; }
        .document-page-header, .document-list-heading, .document-item, .document-item-main, .document-header-actions, .document-modal-actions { display: flex; gap: 1rem; }
        .document-page-header, .document-list-heading, .document-item { justify-content: space-between; }
        .document-page-header { align-items: flex-start; margin-bottom: 1.5rem; }
        .document-page-header .eyebrow a { color: inherit; text-decoration: none; }
        .document-page-header h1 { color: var(--ink); font-size: 1.65rem; font-weight: 700; margin: 0; }
        .document-page-header .helper-text { margin: .35rem 0 0; }
        .document-header-actions { flex-wrap: wrap; }
        .document-readiness-notice { background: var(--warning-soft); border: 1px solid color-mix(in srgb, var(--warning) 28%, transparent); border-radius: 8px; color: var(--ink-soft); margin-bottom: 1.5rem; padding: .8rem 1rem; }
        .document-upload-card, .document-list-card { border: 1px solid var(--line) !important; border-radius: 8px; background: var(--surface); }
        .upload-dropzone { align-items: center; background: var(--surface-muted); border: 2px dashed var(--line); border-radius: 8px; cursor: pointer; display: flex; justify-content: center; min-height: 220px; padding: 1.5rem; text-align: center; transition: border-color .2s, background .2s; }
        .upload-dropzone.is-dragging { background: var(--accent-soft); border-color: var(--accent); }
        .upload-icon { align-items: center; background: var(--surface); border: 1px solid var(--line); border-radius: 50%; color: var(--accent); display: inline-flex; height: 48px; justify-content: center; margin-bottom: .75rem; width: 48px; }
        .upload-primary, .upload-secondary { display: block; }
        .upload-primary { color: var(--ink); font-weight: 700; }
        .upload-secondary, .upload-support-text { color: var(--muted); font-size: .8rem; margin-top: .35rem; }
        .upload-loading-state { align-items: center; display: none; flex-direction: column; }
        .upload-loading-state .spinner-border { height: 2rem; width: 2rem; }
        .upload-support-text { line-height: 1.5; margin-top: .75rem; }
        .document-list-heading { align-items: flex-start; margin-bottom: 1rem; }
        .document-count { background: var(--bg-elevated); border-radius: 999px; color: var(--ink-soft); font-size: .825rem; font-weight: 600; padding: .35rem .7rem; white-space: nowrap; }
        .document-list { display: grid; gap: .75rem; }
        .document-item { align-items: center; background: var(--surface-muted); border: 1px solid var(--line); border-radius: 8px; flex-wrap: wrap; padding: 1rem; }
        .document-item-main { align-items: center; flex: 1 1 280px; min-width: 0; }
        .document-file-icon { align-items: center; background: var(--accent-soft); border-radius: 6px; color: var(--accent); display: flex; flex: 0 0 auto; font-size: .65rem; font-weight: 800; height: 34px; justify-content: center; width: 42px; }
        .document-file-details { min-width: 0; }
        .document-file-name { color: var(--ink); display: block; max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .document-file-details span { color: var(--muted); display: block; font-size: .75rem; margin-top: .2rem; }
        .document-item-status { flex: 0 1 150px; min-width: 130px; }
        .status-badge { border-radius: 999px; display: inline-block; font-size: .75rem; font-weight: 700; margin-bottom: .45rem; padding: .3rem .55rem; }
        .status-badge.pending { background: var(--bg-elevated); color: var(--ink-soft); }
        .status-badge.processing { background: var(--warning-soft); color: var(--warning); }
        .status-badge.completed { background: var(--success-soft); color: var(--success); }
        .status-badge.failed { background: var(--danger-soft); color: var(--danger); }
