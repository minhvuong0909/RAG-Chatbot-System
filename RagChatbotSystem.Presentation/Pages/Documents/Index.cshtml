@page
@using System.Text.Encodings.Web
@model RagChatbotSystem.Presentation.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Quản lý tài liệu";
    var hasCompletedDocument = Model.Documents.Any(document => document.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase));
}

@functions {
    private static string StatusLabel(string? status) => status?.ToLowerInvariant() switch
    {
        "uploaded" or "pending" => "Đang chờ",
        "processing" => "Đang xử lý",
        "completed" => "Đã xử lý",
        "failed" => "Xử lý thất bại",
        "deleted" => "Đã xóa",
        _ => "Đang chờ"
    };

    private static string StatusClass(string? status) => status?.ToLowerInvariant() switch
    {
        "uploaded" or "pending" => "bg-gray-100 text-gray-600 border-gray-200",
        "processing" => "bg-blue-50 text-blue-700 border-blue-200",
        "completed" => "bg-green-50 text-green-700 border-green-200",
        "failed" => "bg-red-50 text-red-700 border-red-200",
        "deleted" => "bg-gray-100 text-gray-500 border-gray-200 line-through",
        _ => "bg-gray-100 text-gray-600 border-gray-200"
    };
}

<div id="documents-workspace" data-rag-app data-selected-dataset-id="@Model.DatasetId" class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white/60 backdrop-blur-xl border border-white shadow-sm p-6 rounded-2xl">
        <div>
            <p class="text-xs font-bold text-gray-500 tracking-wider uppercase mb-1 flex items-center gap-2">
                <a asp-page="/Datasets/Index" class="hover:text-accent-strong transition-colors">Môn học</a>
                <span>/</span>
                <span title="@Model.Dataset.Name" class="text-accent-strong">@Model.Dataset.Name</span>
            </p>
            <h1 class="text-2xl font-grotesk font-extrabold text-ink tracking-tight">Quản lý tài liệu</h1>
            <p class="text-sm text-gray-500 mt-1">Tài liệu đã xử lý sẽ được dùng làm nguồn tham khảo cho chatbot.</p>
        </div>
        <div class="flex gap-3">
            <a asp-page="/Datasets/Index" class="inline-flex items-center px-4 py-2 border border-gray-200 rounded-xl shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                Danh sách môn học
            </a>
            <a asp-page="/Index" asp-route-datasetId="@Model.DatasetId" class="inline-flex items-center px-4 py-2 border border-transparent rounded-xl shadow-sm text-sm font-medium text-white bg-accent-strong hover:bg-indigo-700 transition-colors">
                Mở trò chuyện
            </a>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="p-4 rounded-xl bg-red-50 border border-red-100 flex items-start gap-3 relative">
            <svg class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            <div class="flex-1">
                <p class="text-sm font-medium text-red-800">@Model.ErrorMessage</p>
            </div>
            <button type="button" class="absolute top-4 right-4 text-red-400 hover:text-red-600" onclick="this.parentElement.remove();"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="p-4 rounded-xl bg-green-50 border border-green-100 flex items-start gap-3 relative">
            <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <div class="flex-1">
                <p class="text-sm font-medium text-green-800">@Model.SuccessMessage</p>
            </div>
            <button type="button" class="absolute top-4 right-4 text-green-400 hover:text-green-600" onclick="this.parentElement.remove();"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></button>
        </div>
    }

    @if (!hasCompletedDocument)
    {
        <div class="p-4 rounded-xl bg-amber-50 border border-amber-200 flex items-start gap-3 shadow-sm">
            <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            <div class="flex-1">
                <p class="text-sm font-bold text-amber-800">Chatbot chưa sẵn sàng</p>
                <p class="text-sm text-amber-700 mt-1">Chưa thể trả lời dựa trên môn học này vì chưa có tài liệu nào được xử lý hoàn tất.</p>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
        <!-- Upload Card -->
        <div class="lg:col-span-4 sticky top-24">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-6 py-5 border-b border-gray-50 bg-gradient-to-r from-gray-50/50 to-white">
                    <h2 class="text-lg font-bold text-ink flex items-center gap-2">
                        <span class="w-8 h-8 rounded-lg bg-accent-strong/10 text-accent-strong flex items-center justify-center">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                        </span>
                        Tải tài liệu lên
                    </h2>
                    <p class="text-xs text-gray-500 mt-2 ml-10">Tải tệp để hệ thống trích xuất nội dung và lập chỉ mục RAG.</p>
                </div>
                <div class="p-6">
                    <form method="post" asp-page-handler="Upload" enctype="multipart/form-data" id="upload-doc-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="datasetId" value="@Model.DatasetId" />

                        <div id="upload-dropzone" class="relative group cursor-pointer border-2 border-dashed border-gray-300 rounded-2xl p-8 text-center hover:bg-indigo-50/50 hover:border-accent-strong transition-all" role="button" tabindex="0" onclick="if (!this.dataset.uploading) document.getElementById('file-upload').click();">
                            <div id="upload-idle-state" class="space-y-3">
                                <div class="w-14 h-14 bg-gray-50 rounded-full flex items-center justify-center mx-auto group-hover:bg-indigo-100 group-hover:text-accent-strong transition-colors text-gray-400">
                                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
                                </div>
                                <div>
                                    <span class="block text-sm font-bold text-ink">Kéo và thả tệp vào đây</span>
                                    <span class="block text-xs text-gray-500 mt-1">hoặc bấm để chọn tệp</span>
                                </div>
                            </div>
                            <div id="upload-loading-state" class="hidden space-y-4" aria-live="polite">
                                <svg class="w-10 h-10 text-accent-strong animate-spin mx-auto" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                <div>
                                    <span class="block text-sm font-bold text-accent-strong">Đang tải lên...</span>
                                    <span class="block text-xs text-gray-500 mt-1">Hệ thống đang trích xuất & lập chỉ mục</span>
                                </div>
                            </div>
                            <input id="file-upload" name="file" type="file" accept=".pdf,.txt,.docx" required hidden onchange="triggerUpload();" />
                        </div>
                        <p class="text-xs text-gray-400 text-center mt-4">Hỗ trợ PDF, DOCX, TXT. Tối đa 50MB.</p>
                    </form>
                </div>
            </div>
        </div>

        <!-- Document List -->
        <div class="lg:col-span-8">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-6 py-5 border-b border-gray-50 bg-white flex justify-between items-center">
                    <h2 class="text-lg font-bold text-ink flex items-center gap-2">
                        <span class="w-8 h-8 rounded-lg bg-gray-100 text-gray-500 flex items-center justify-center">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        </span>
                        Danh sách tài liệu
                    </h2>
                    <span class="px-3 py-1 bg-gray-100 text-gray-600 text-xs font-bold rounded-full" data-document-count>
                        @Model.Documents.Count tệp
                    </span>
                </div>

                <div class="p-0" id="document-list" data-document-list>
                    @if (Model.Documents.Count == 0)
                    {
                        <div class="text-center py-16 px-4" id="documents-empty-state">
                            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-50 text-gray-400 mb-4">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path></svg>
                            </div>
                            <h3 class="text-base font-bold text-ink mb-1">Chưa có tài liệu</h3>
                            <p class="text-sm text-gray-500">Tải lên một tệp để chatbot có nguồn tham khảo.</p>
                        </div>
                    }
                    else
                    {
                        <div class="divide-y divide-gray-100">
                            @foreach (var doc in Model.Documents)
                            {
                                <article class="p-5 hover:bg-gray-50/50 transition-colors group flex flex-col sm:flex-row sm:items-center justify-between gap-4" data-document-id="@doc.DocumentId">
                                    <div class="flex items-start gap-4">
                                        <div class="w-10 h-10 rounded-lg bg-indigo-50 text-accent-strong flex items-center justify-center font-bold text-xs shrink-0 uppercase tracking-wider">
                                            @doc.FileType
                                        </div>
                                        <div class="min-w-0">
                                            <h3 class="font-semibold text-ink text-sm truncate" title="@doc.FileName">@doc.FileName</h3>
                                            <div class="text-gray-400 text-xs mt-1 flex items-center gap-2 flex-wrap">
                                                <span>@Math.Ceiling(doc.FileSize / 1024.0) KB</span>
                                                <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                                                <span>@doc.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(doc.ProcessError))
                                            {
                                                <p class="text-xs text-red-500 mt-1 font-medium">Lỗi: Không thể xử lý tài liệu này.</p>
                                            }
                                        </div>
                                    </div>

                                    <div class="flex items-center gap-6 sm:justify-end shrink-0">
                                        <div class="w-32 text-right">
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[11px] font-bold border @StatusClass(doc.Status)" data-document-status>
                                                @StatusLabel(doc.Status)
                                            </span>
                                            <div class="w-full bg-gray-100 rounded-full h-1.5 mt-2 overflow-hidden">
                                                <div class="bg-accent-strong h-1.5 rounded-full transition-all duration-500" data-document-progress style="width: @(doc.Status.Equals("Processing", StringComparison.OrdinalIgnoreCase) ? "55%" : doc.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase) ? "100%" : "0%")"></div>
                                            </div>
                                        </div>

                                        <div class="flex gap-2">
                                            <a asp-page="/Documents/Preview" asp-route-documentId="@doc.DocumentId" class="inline-flex items-center justify-center p-2 text-gray-400 hover:text-accent-strong hover:bg-indigo-50 rounded-lg transition-colors" title="Xem chunk">
                                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path></svg>
                                            </a>
                                            <form method="post" asp-page-handler="DeleteDocument" class="m-0" data-delete-document data-file-name="@doc.FileName">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="datasetId" value="@Model.DatasetId" />
                                                <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                                <button type="submit" class="inline-flex items-center justify-center p-2 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors" title="Xóa tài liệu">
                                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"></path></svg>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Overlay for Processing -->
<div id="documentProcessingOverlay" class="fixed inset-0 z-[100] bg-gray-900/50 backdrop-blur-sm hidden flex-col items-center justify-center p-4" aria-live="polite">
    <div class="bg-white rounded-3xl shadow-2xl max-w-sm w-full p-8 text-center animate-bounce-in">
        <svg class="w-16 h-16 text-accent-strong animate-spin mx-auto mb-6" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
        <h2 class="text-xl font-bold text-ink mb-2">Đang xử lý tài liệu</h2>
        <p class="text-sm text-gray-500">Hệ thống đang trích xuất và lập chỉ mục RAG. Vui lòng không đóng trang web này...</p>
    </div>
</div>

<!-- Modal for Delete Confirmation -->
<div id="deleteDocumentModal" class="fixed inset-0 z-[100] bg-gray-900/50 backdrop-blur-sm hidden flex-col items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="deleteDocumentTitle">
    <div class="bg-white rounded-3xl shadow-2xl max-w-sm w-full p-8 animate-bounce-in" role="document">
        <div class="w-12 h-12 rounded-full bg-red-100 text-red-500 flex items-center justify-center mb-6 mx-auto">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
        </div>
        <h2 id="deleteDocumentTitle" class="text-xl font-bold text-center text-ink mb-4">Xóa tài liệu</h2>
        <p class="text-sm text-gray-600 text-center mb-6">Bạn có chắc muốn xóa <strong id="delete-document-file-name" class="text-ink"></strong>? Tài liệu này sẽ không còn được chatbot sử dụng.</p>
        <div class="flex gap-3">
            <button type="button" class="flex-1 px-4 py-2.5 bg-gray-100 text-gray-700 font-bold rounded-xl hover:bg-gray-200 transition-colors" data-modal-dismiss>Hủy</button>
            <button type="button" class="flex-1 px-4 py-2.5 bg-red-500 text-white font-bold rounded-xl shadow-sm hover:bg-red-600 transition-colors" id="confirm-delete-document">Xóa tài liệu</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const uploadDocForm = document.getElementById("upload-doc-form");
        const fileUploadInput = document.getElementById("file-upload");
        const dropzone = document.getElementById("upload-dropzone");
        const processingOverlay = document.getElementById("documentProcessingOverlay");
        const deleteModal = document.getElementById("deleteDocumentModal");
        const deleteFileName = document.getElementById("delete-document-file-name");
        let pendingDeleteForm = null;
        const existingDocumentNames = new Set([
            @foreach (var doc in Model.Documents)
            {
                @: "@JavaScriptEncoder.Default.Encode(doc.FileName.ToLowerInvariant())",
            }
        ]);

        function statusInfo(status) {
            const normalized = String(status || "Uploaded").toLowerCase();
            const labels = {
                uploaded: "Đang chờ", pending: "Đang chờ", processing: "Đang xử lý",
                completed: "Đã xử lý", failed: "Xử lý thất bại", deleted: "Đã xóa"
            };
            const classes = {
                uploaded: "bg-gray-100 text-gray-600 border-gray-200", 
                pending: "bg-gray-100 text-gray-600 border-gray-200", 
                processing: "bg-blue-50 text-blue-700 border-blue-200",
                completed: "bg-green-50 text-green-700 border-green-200", 
                failed: "bg-red-50 text-red-700 border-red-200", 
                deleted: "bg-gray-100 text-gray-500 border-gray-200 line-through"
            };
            return {
                label: labels[normalized] || "Đang chờ",
                cssClass: classes[normalized] || classes.pending
            };
        }

        function triggerUpload() {
            if (!fileUploadInput.files || fileUploadInput.files.length === 0) return;
            
            const file = fileUploadInput.files[0];
            const maxSizeBytes = 50 * 1024 * 1024; // 50MB
            
            if (file.size > maxSizeBytes) {
                alert("Tệp quá lớn. Kích thước tối đa là 50MB.");
                fileUploadInput.value = '';
                return;
            }
            
            const fileName = file.name.toLowerCase();
            if (existingDocumentNames.has(fileName)) {
                alert("Một tài liệu với tên này đã tồn tại trong môn học.");
                fileUploadInput.value = '';
                return;
            }
            
            const ext = fileName.split('.').pop();
            if (!['pdf', 'txt', 'docx'].includes(ext)) {
                alert("Định dạng không được hỗ trợ. Vui lòng chọn tệp PDF, TXT hoặc DOCX.");
                fileUploadInput.value = '';
                return;
            }
            
            dropzone.dataset.uploading = "true";
            document.getElementById("upload-idle-state").classList.add("hidden");
            document.getElementById("upload-loading-state").classList.remove("hidden");
            processingOverlay.classList.remove("hidden");
            processingOverlay.classList.add("flex");
            
            uploadDocForm.submit();
        }

        dropzone.addEventListener("dragover", (e) => {
            e.preventDefault();
            if (dropzone.dataset.uploading !== "true") {
                dropzone.classList.add("border-accent-strong", "bg-indigo-50/50");
            }
        });

        dropzone.addEventListener("dragleave", () => {
            dropzone.classList.remove("border-accent-strong", "bg-indigo-50/50");
        });

        dropzone.addEventListener("drop", (e) => {
            e.preventDefault();
            dropzone.classList.remove("border-accent-strong", "bg-indigo-50/50");
            
            if (dropzone.dataset.uploading !== "true" && e.dataTransfer.files.length > 0) {
                fileUploadInput.files = e.dataTransfer.files;
                triggerUpload();
            }
        });

        // Delete Modal Logic
        document.querySelectorAll("[data-delete-document]").forEach(form => {
            form.addEventListener("submit", (e) => {
                e.preventDefault();
                pendingDeleteForm = form;
                deleteFileName.textContent = form.dataset.fileName;
                deleteModal.classList.remove("hidden");
                deleteModal.classList.add("flex");
            });
        });

        document.querySelectorAll("[data-modal-dismiss]").forEach(el => {
            el.addEventListener("click", () => {
                deleteModal.classList.add("hidden");
                deleteModal.classList.remove("flex");
                pendingDeleteForm = null;
            });
        });

        document.getElementById("confirm-delete-document")?.addEventListener("click", () => {
            if (pendingDeleteForm) {
                pendingDeleteForm.submit();
            }
        });

        // Polling Logic
        const workspace = document.getElementById("documents-workspace");
        if (workspace) {
            const datasetId = workspace.dataset.selectedDatasetId;
            let pollInterval = null;

            function checkProcessingStatus() {
                const processingDocs = document.querySelectorAll("[data-document-status]");
                let needsPolling = false;
                
                processingDocs.forEach(el => {
                    if (el.textContent.includes("Đang chờ") || el.textContent.includes("Đang xử lý")) {
                        needsPolling = true;
                    }
                });

                if (needsPolling && !pollInterval) {
                    pollInterval = setInterval(async () => {
                        try {
                            const response = await fetch(`/api/status/dataset/${datasetId}`);
                            if (!response.ok) return;
                            
                            const data = await response.json();
                            let allDone = true;

                            data.documents.forEach(doc => {
                                const article = document.querySelector(`article[data-document-id="${doc.documentId}"]`);
                                if (article) {
                                    const statusEl = article.querySelector("[data-document-status]");
                                    const progressEl = article.querySelector("[data-document-progress]");
                                    
                                    if (statusEl && statusEl.textContent !== statusInfo(doc.status).label) {
                                        const info = statusInfo(doc.status);
                                        statusEl.textContent = info.label;
                                        statusEl.className = `inline-flex items-center px-2.5 py-1 rounded-md text-[11px] font-bold border ${info.cssClass}`;
                                        
                                        if (progressEl) {
                                            progressEl.style.width = doc.status.toLowerCase() === "completed" ? "100%" 
                                                : doc.status.toLowerCase() === "processing" ? "55%" : "0%";
                                        }
                                        
                                        if (doc.status.toLowerCase() === "completed" || doc.status.toLowerCase() === "failed") {
                                            setTimeout(() => window.location.reload(), 1500);
                                        }
                                    }
                                }
                                
                                if (doc.status.toLowerCase() === "uploaded" || doc.status.toLowerCase() === "pending" || doc.status.toLowerCase() === "processing") {
                                    allDone = false;
                                }
                            });

                            if (allDone && pollInterval) {
                                clearInterval(pollInterval);
                                pollInterval = null;
                            }
                        } catch (e) {
                            console.error("Status polling failed:", e);
                        }
                    }, 2000);
                } else if (!needsPolling && pollInterval) {
                    clearInterval(pollInterval);
                    pollInterval = null;
                }
            }

            checkProcessingStatus();
        }
    </script>
    <style>
        .animate-bounce-in {
            animation: bounceIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        @@keyframes bounceIn {
            0% { transform: scale(0.9); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>
}
