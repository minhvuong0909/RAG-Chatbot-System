@page
@model RagChatbotSystem.Presentation.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-container" style="min-height: calc(90vh - 104px);">
    <div class="auth-card" style="max-width: 480px;">
        <div class="auth-title">
            <span class="brand-mark mb-3" style="display: inline-grid; width: 54px; height: 54px; place-items: center; border-radius: 12px; font-size: 1.8rem; margin-bottom: 12px;">R</span>
            <h1>Initialize Profile</h1>
            <p>Register credentials to begin AI training and retrieval</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger border-0 mb-4" style="background-color: rgba(239, 68, 68, 0.1); color: var(--danger); border-radius: 8px; border: 1px solid rgba(239, 68, 68, 0.2) !important;">
                <div asp-validation-summary="All" class="small list-unstyled m-0 fw-bold"></div>
            </div>
        }

        <form method="post" style="display: grid; gap: 16px;">
            @Html.AntiForgeryToken()

            <div>
                <label for="fullName" class="form-label small fw-bold mb-2" style="color: var(--muted); letter-spacing: 0.05em;">FULL NAME</label>
                <input type="text" id="fullName" name="fullName" placeholder="Enter your full name" required style="min-height: 46px;" />
            </div>

            <div>
                <label for="email" class="form-label small fw-bold mb-2" style="color: var(--muted); letter-spacing: 0.05em;">EMAIL</label>
                <input type="email" id="email" name="email" placeholder="Enter your email" required style="min-height: 46px;" />
            </div>

            <div>
                <label for="password" class="form-label small fw-bold mb-2" style="color: var(--muted); letter-spacing: 0.05em;">PASSWORD</label>
                <input type="password" id="password" name="password" placeholder="Enter your password" required style="min-height: 46px;" />
            </div>

            <div>
                <label for="role" class="form-label small fw-bold mb-2" style="color: var(--muted); letter-spacing: 0.05em;">SYSTEM ROLE</label>
                <select id="role" name="role" required style="min-height: 46px; width: 100%; border: 1px solid var(--line); border-radius: 8px; background: rgba(10, 15, 30, 0.7); color: var(--ink); padding: 0 12px;">
                    <option value="Student">Student</option>
                    <option value="Teacher">Teacher</option>
                </select>
            </div>

            <div style="margin-top: 10px;">
                <button type="submit" style="width: 100%; min-height: 48px; border-radius: 8px; font-size: 0.9rem;">
                    Create Credentials
                </button>
            </div>

            <div class="text-center mt-2">
                <span class="text-muted small">Already registered? </span>
                <a asp-page="/Account/Login" class="small fw-bold" style="color: var(--accent-strong); text-shadow: 0 0 10px rgba(0, 242, 254, 0.4); text-decoration: none;">Connect profile</a>
            </div>
        </form>
    </div>
</div>
