@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var tabs = new[]
    {
        new { Page = "/Admin/Index", Label = "Tổng quan", IsActive = currentPage == "/Admin/Index" },
        new { Page = "/Admin/Datasets/Index", Label = "Môn học", IsActive = currentPage.StartsWith("/Admin/Datasets", StringComparison.Ordinal) || currentPage == "/Admin/Permissions" },
        new { Page = "/Admin/Reports", Label = "Báo cáo", IsActive = currentPage == "/Admin/Reports" },
        new { Page = "/Admin/Credits/Index", Label = "Credit", IsActive = currentPage.StartsWith("/Admin/Credits", StringComparison.Ordinal) },
        new { Page = "/Admin/ModelComparison/Index", Label = "So sánh mô hình", IsActive = currentPage == "/Admin/ModelComparison/Index" },
        new { Page = "/Admin/ModelComparison/Benchmark", Label = "Benchmark RAG", IsActive = currentPage == "/Admin/ModelComparison/Benchmark" },
        new { Page = "/Admin/ModelComparison/History", Label = "Lịch sử & Báo cáo", IsActive = currentPage == "/Admin/ModelComparison/History" },
        new { Page = "/Admin/Settings", Label = "Cài đặt", IsActive = currentPage == "/Admin/Settings" }
    };
}

<nav class="flex overflow-x-auto custom-scrollbar whitespace-nowrap gap-2" aria-label="Khu vực quản trị">
    @foreach (var tab in tabs)
    {
        <a class="px-4 py-2 text-sm font-bold rounded-xl transition-colors @(tab.IsActive ? "bg-accent-strong text-white shadow-sm" : "text-gray-500 hover:bg-gray-100 hover:text-ink")"
           asp-page="@tab.Page"
           aria-current="@(tab.IsActive ? "page" : null)">
            @tab.Label
        </a>
    }
</nav>

<style>
    .custom-scrollbar::-webkit-scrollbar { height: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 2px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
</style>
