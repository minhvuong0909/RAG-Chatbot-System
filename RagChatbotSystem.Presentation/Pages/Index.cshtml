    </style>
    <script>
        // Tá»± Ä‘á»™ng cuá»™n khung chat xuá»‘ng dÆ°á»›i cÃ¹ng khi cÃ³ tin nháº¯n má»›i hoáº·c táº£i trang
        if (document.querySelector(".workspace")) {
            window.scrollTo(0, 0);
        }

        const chatStream = document.getElementById("chatStream");
        if (chatStream) {
            chatStream.scrollTop = chatStream.scrollHeight;
        }
        const pendingAssistantMessages = new Map();
        const failedAssistantMessageIds = new Set();
        const friendlyAiUnavailableMessage = "Hiện chưa thể tạo câu trả lời từ AI. Vui lòng thử lại sau hoặc liên hệ quản trị viên.";

        function localizeDocumentStatus(status) {
            const normalized = String(status || "").trim().toLowerCase();
            const labels = {
                completed: "Đã xử lý",
                processing: "Đang xử lý",
                uploaded: "Đã tải lên",
                failed: "Thất bại",
                hidden: "Đã ẩn"
            };
            return labels[normalized] || "Chưa xác định";
        }

        function localizeSessionTitle(title) {
            const normalized = String(title || "").trim().toLowerCase();
            const labels = {
                "new chat": "Trò chuyện mới",
                "new session": "Trò chuyện mới",
                "subject chat": "Trò chuyện môn học"
            };
            return labels[normalized] || title || "Trò chuyện mới";
        }

        const uploadDocForm = document.getElementById("upload-doc-form");
        const fileUploadInput = document.getElementById("file-upload");
        const processingOverlay = document.getElementById("documentProcessingOverlay");
        if (uploadDocForm && processingOverlay) {
            uploadDocForm.addEventListener("submit", function () {
                processingOverlay.style.display = "flex";
            });
        }
        function escapeHtml(str) {
            if (!str) return "";
            return str
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function renderInlineMarkdown(value) {
            const codeSpans = [];
            let html = escapeHtml(String(value || "")).replace(/`([^`\n]+)`/g, function (_, code) {
                const token = `@@CODE_SPAN_${codeSpans.length}@@`;
                codeSpans.push(`<code>${code}</code>`);
                return token;
            });
            html = html
                .replace(/\*\*([^*\n]+)\*\*/g, "<strong>$1</strong>")
                .replace(/__([^_\n]+)__/g, "<strong>$1</strong>")
                .replace(/(^|[^*])\*([^*\n]+)\*/g, "$1<em>$2</em>")
                .replace(/(^|[^_])_([^_\n]+)_/g, "$1<em>$2</em>");
            codeSpans.forEach(function (code, index) {
                html = html.replace(`@@CODE_SPAN_${index}@@`, code);
            });
            return html;
        }

        function renderMarkdown(value) {
            const lines = String(value || "").replace(/\r\n?/g, "\n").split("\n");
            const output = [];
            let listType = null;
            let inCodeBlock = false;
            const codeLines = [];

            function closeList() {
                if (listType) output.push(`</${listType}>`);
                listType = null;
            }

            lines.forEach(function (line) {
                if (/^\s*```/.test(line)) {
                    closeList();
                    if (inCodeBlock) {
                        output.push(`<pre><code>${escapeHtml(codeLines.join("\n"))}</code></pre>`);
                        codeLines.length = 0;
                    }
                    inCodeBlock = !inCodeBlock;
                    return;
                }
                if (inCodeBlock) {
                    codeLines.push(line);
                    return;
                }

                const unordered = line.match(/^\s*[-*+]\s+(.+)$/);
                const ordered = line.match(/^\s*\d+[.)]\s+(.+)$/);
                const nextListType = unordered ? "ul" : (ordered ? "ol" : null);
                if (nextListType) {
                    if (listType !== nextListType) {
                        closeList();
                        listType = nextListType;
                        output.push(`<${listType}>`);
                    }
                    output.push(`<li>${renderInlineMarkdown((unordered || ordered)[1])}</li>`);
                    return;
                }

                closeList();
                if (!line.trim()) return;
                const heading = line.match(/^\s*(#{1,4})\s+(.+)$/);
                if (heading) {
                    const level = Math.min(4, heading[1].length + 2);
                    output.push(`<h${level}>${renderInlineMarkdown(heading[2])}</h${level}>`);
                } else if (/^\s*>\s?/.test(line)) {
                    output.push(`<blockquote>${renderInlineMarkdown(line.replace(/^\s*>\s?/, ""))}</blockquote>`);
                } else {
                    output.push(`<p>${renderInlineMarkdown(line)}</p>`);
                }
            });
            closeList();
            if (inCodeBlock && codeLines.length) {
                output.push(`<pre><code>${escapeHtml(codeLines.join("\n"))}</code></pre>`);
            }
            return output.join("");
        }

        document.querySelectorAll(".message.assistant .ai-markdown").forEach(function (element) {
            element.innerHTML = renderMarkdown(element.textContent || "");
        });

        // Há»— trá»£ gá»­i tin nháº¯n báº±ng tá»• há»£p phÃ­m Enter (nhÆ°ng cho phÃ©p Shift+Enter Ä‘á»ƒ xuá»‘ng dÃ²ng)
        const textarea = document.getElementById("chatQuestionTextarea");
        if (textarea) {
            textarea.addEventListener("keydown", function(e) {
                if (e.key === "Enter" && !e.shiftKey) {
                    e.preventDefault();
                    // KÃ­ch hoáº¡t submit form Ä‘Æ°á»£c xá»­ lÃ½ báº±ng AJAX á»Ÿ dÆ°á»›i
                    this.form.dispatchEvent(new Event("submit", { cancelable: true }));
                }
            });
        }

        // Xá»­ lÃ½ gá»­i tin nháº¯n báº±ng AJAX (KhÃ´ng táº£i láº¡i trang)
        const questionSuggestions = document.querySelector("[data-question-suggestions]");
        const suggestionList = document.querySelector("[data-suggestion-list]");
        const suggestionHelper = document.querySelector("[data-suggestion-helper]");
        const generateQuestionsButton = document.querySelector("[data-generate-questions]");

        document.addEventListener("click", function(e) {
            const chip = e.target.closest("[data-question-template]");
            if (!chip || !textarea) return;

            textarea.value = chip.getAttribute("data-question-template") || chip.textContent.trim();
            textarea.focus();
            textarea.style.height = "auto";
            textarea.style.height = `${textarea.scrollHeight}px`;
        });

        if (generateQuestionsButton && questionSuggestions && suggestionList) {
            generateQuestionsButton.addEventListener("click", function () {
                const datasetId = questionSuggestions.getAttribute("data-dataset-id");
                if (!datasetId) return;

                generateQuestionsButton.disabled = true;
                generateQuestionsButton.textContent = "Đang tạo...";
                if (suggestionHelper) {
                    suggestionHelper.textContent = "Đang tìm tài liệu và tạo gợi ý học tập...";
                }

                fetch(`?handler=SuggestQuestions&datasetId=${encodeURIComponent(datasetId)}`)
                    .then(response => {
                        if (!response.ok) {
                            return response.json().then(data => { throw new Error(data.error || "Không thể tạo gợi ý câu hỏi.") });
                        }
                        return response.json();
                    })
                    .then(data => {
                        const questions = data.questions || [];
                        if (questions.length === 0) {
                            throw new Error("Chưa tạo được gợi ý câu hỏi cho môn học này.");
                        }

                        suggestionList.innerHTML = questions.map(q => `
                            <button type="button" class="suggestion-chip" data-question-template="${escapeHtml(q)}">${escapeHtml(q)}</button>
                        `).join("");

                        if (suggestionHelper) {
                            suggestionHelper.textContent = "Chọn một gợi ý để điền vào ô chat.";
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        if (suggestionHelper) {
                            suggestionHelper.textContent = "Không thể tạo gợi ý câu hỏi. Vui lòng thử lại.";
                        }
                    })
                    .finally(() => {
                        generateQuestionsButton.disabled = false;
                        generateQuestionsButton.textContent = "Gợi ý câu hỏi";
                    });
            });
        }

        let chatConnectionReady = Promise.resolve(false);
        const composerForm = document.querySelector(".composer");
        if (composerForm) {
            composerForm.addEventListener("submit", async function(e) {
                e.preventDefault();
                
                const questionInput = document.getElementById("chatQuestionTextarea");
                if (!questionInput) return;
                const question = questionInput.value.trim();
                if (!question) return;

                // Do not start the HTTP request until the browser has joined the
                // SignalR session group; otherwise the first streamed chunks are lost.
                const streamingReady = await chatConnectionReady;
                if (!streamingReady) {
                    console.warn("Không thể thiết lập kết nối streaming; yêu cầu vẫn tiếp tục bằng phản hồi hoàn chỉnh.");
                }
                
                // Clear vÃ  reset textarea ngay láº­p tá»©c
                questionInput.value = "";
                questionInput.style.height = "auto";
                
                // 1. Hiá»ƒn thá»‹ tin nháº¯n cá»§a User ngay láº­p tá»©c lÃªn mÃ n hÃ¬nh
                appendMessage("user", question, formatVietnamTime(new Date()));
                
                // 2. ThÃªm bong bÃ³ng chá» tráº£ lá»i (Loading) tá»« Assistant
                const loadingBubble = appendLoadingBubble();
                
                // Cuá»™n xuá»‘ng cuá»‘i
                if (chatStream) {
                    chatStream.scrollTop = chatStream.scrollHeight;
                }
                
                // 3. Gá»­i yÃªu cáº§u qua Fetch API tá»›i Backend
                const formData = new FormData(composerForm);
                formData.set("question", question);
                composerForm.dataset.realtimeSuppress = "true";
                
                fetch("?handler=SendMessageAjax", {
                    method: "POST",
                    body: formData
                })
                .then(response => {
                    if (!response.ok) {
                        return response.json().then(data => {
                            const requestError = new Error(data.error || "Gửi tin nhắn thất bại.");
                            requestError.code = data.code;
                            requestError.status = response.status;
                            throw requestError;
                        });
                    }
                    return response.json();
                })
                .then(data => {
                    // XÃ³a bong bÃ³ng loading
                    if (loadingBubble && loadingBubble.classList.contains("loading-bubble")) loadingBubble.remove();
                    
                    // ThÃªm cÃ¢u tráº£ lá» i cá»§a AI vÃ o giao diá»‡n
                    const assistantId = String(data.assistantMessage.messageId);
                    if (!document.querySelector(`[data-message-id="${assistantId}"]`)) {
                        appendMessage("assistant", data.assistantMessage.content, data.assistantMessage.createdAt, data.assistantMessage.messageId, data.citations && data.citations.length > 0);
                    }
                    
                    // Hiá»ƒn thá»‹ ngay cÃ¡c nguá»…n trÃ­ch dáº«n tÆ°Æ¡ng á»©ng bÃªn cá»™t pháº£i
                    if (data.citations && data.citations.length > 0) {
                        renderCitationsDirectly(data.citations);
                    }
                    
                    // Cap nhat Token Usage dynamic
                    if (data.dailyTokensUsed !== null && data.dailyTokensUsed !== undefined &&
                        data.dailyTokenLimit !== null && data.dailyTokenLimit !== undefined) {
                        const progressText = document.getElementById("dailyTokenProgressText");
                        const progressBar = document.getElementById("dailyTokenProgressBar");
                        if (progressText && progressBar) {
                            progressText.textContent = `${Number(data.dailyTokensUsed).toLocaleString()} / ${Number(data.dailyTokenLimit).toLocaleString()}`;
                            const pct = Math.min(100, Math.max(0, (data.dailyTokensUsed / data.dailyTokenLimit) * 100));
                            progressBar.style.width = `${pct}%`;
                            progressBar.setAttribute("aria-valuenow", data.dailyTokensUsed);
                            progressBar.className = "progress-bar";
                            if (pct > 85) {
                                progressBar.classList.add("bg-danger");
                            } else if (pct > 60) {
                                progressBar.classList.add("bg-warning");
                            } else {
                                progressBar.classList.add("bg-primary");
                            }
                        }
                    }
                    
                    // Cuá»™n xuá»‘ng cuá»‘i
                    updateCreditBalanceDisplay(data.creditBalance);

                    if (data.creditSpend) {
                        updateCreditSpendDisplay(data.creditSpend);
                    }

                    if (chatStream) {
                        chatStream.scrollTop = chatStream.scrollHeight;
                    }
                    setTimeout(function () { delete composerForm.dataset.realtimeSuppress; }, 750);
                })
                .catch(err => {
                    if (!err.code) console.error(err);
                    // ReceiveChatFailed normally handles this first. If the HTTP response
                    // arrives first, convert this request's loading bubble in place instead
                    // of creating a second assistant bubble.
                    if (loadingBubble && !loadingBubble.classList.contains("failed-message")) {
                        markAssistantBubbleAsFailed(loadingBubble, err.message || friendlyAiUnavailableMessage);
                    }
                    
                    if (chatStream) {
                        chatStream.scrollTop = chatStream.scrollHeight;
                    }
                    delete composerForm.dataset.realtimeSuppress;
                });
            });
        }

        window.addEventListener("rag:document-progress", function (event) {
            const payload = event.detail;
            if (!payload) return;

            const workspaceEl = document.querySelector("[data-rag-app]");
            if (workspaceEl && workspaceEl.dataset.selectedDatasetId && payload.datasetId && workspaceEl.dataset.selectedDatasetId !== String(payload.datasetId)) {
                return;
            }

            const documentRow = document.querySelector(`[data-document-id="${payload.documentId}"]`);
            if (payload.action === "deleted") {
                if (documentRow) documentRow.remove();
                return;
            }

            if (!documentRow) {
                const list = document.querySelector("[data-document-list]");
                if (list && (payload.action === "completed" || payload.action === "uploaded" || payload.action === "processing")) {
                    const emptyState = list.querySelector(".helper-text");
                    if (emptyState) emptyState.remove();
                    list.prepend(createDocumentRow(payload));
                }
                return;
            }

            const status = documentRow.querySelector("[data-document-status]");
            if (status) {
                status.textContent = localizeDocumentStatus(payload.status || payload.action);
                status.className = `status-pill ${(payload.status || "").toLowerCase()}`;
            }

            const progress = documentRow.querySelector("[data-document-progress]");
            if (progress) {
                progress.style.width = `${Math.max(0, Math.min(100, payload.percentComplete || 0))}%`;
            }
        });

        function createDocumentRow(payload) {
            const item = document.createElement("div");
            item.className = "document-item";
            item.dataset.documentId = payload.documentId;
            const status = payload.status || "uploaded";
            const sizeKb = Math.ceil((payload.fileSize || 0) / 1024);
            item.innerHTML = `
                <div class="document-card-header">
                    <div class="document-card-main">
                        <strong class="document-name" title="${escapeHtml(payload.fileName || "Tài liệu")}">${escapeHtml(payload.fileName || "Tài liệu")}</strong>
                        <span class="document-meta">${escapeHtml(String(payload.fileType || "")).toUpperCase()} - ${sizeKb} KB</span>
                    </div>
                </div>
                <div class="progress-track" aria-hidden="true">
                    <span class="progress-fill" data-document-progress style="width: ${Math.max(0, Math.min(100, payload.percentComplete || 0))}%"></span>
                </div>
                <div class="document-actions-row">
                    <span class="status-pill ${escapeHtml(status.toLowerCase())}" data-document-status>${escapeHtml(localizeDocumentStatus(status))}</span>
                    <a class="document-preview-link" href="/Documents/Preview?documentId=${encodeURIComponent(payload.documentId)}" title="Xem các đoạn đã lập chỉ mục và thông tin tài liệu">Xem đoạn nội dung</a>
                    <form method="post" action="?handler=DeleteDocument" style="margin: 0; padding: 0;" onsubmit="return confirm('Tài liệu này sẽ bị ẩn khỏi cuộc trò chuyện và xóa khỏi chỉ mục RAG. Bạn có muốn tiếp tục?');">
                        ${antiForgeryInput()}
                        <input type="hidden" name="datasetId" value="${escapeHtml(payload.datasetId)}" />
                        <input type="hidden" name="documentId" value="${escapeHtml(payload.documentId)}" />
                        <button class="document-delete-button" type="submit" title="Ẩn tài liệu">Ẩn</button>
                    </form>
                </div>
            `;
            return item;
        }

        function antiForgeryInput() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            return token ? `<input name="__RequestVerificationToken" type="hidden" value="${escapeHtml(token.value)}" />` : "";
        }

        // =====================================================================
        // Real-time: Dataset Changed (created / updated / deleted / approved)
        // Admin thay đổi dataset → tự động cập nhật sidebar của Teacher/Student
        // =====================================================================
        window.addEventListener("rag:dataset-changed", function (event) {
            const payload = event.detail;
            if (!payload || !payload.datasetId) return;

            const datasetId = String(payload.datasetId);
            const action = payload.action;
            const datasetList = document.querySelector("[data-dataset-list]");
            const workspaceEl = document.querySelector("[data-rag-app]");
            const existingEntry = datasetList
                ? Array.from(datasetList.querySelectorAll("[data-dataset-id]"))
                    .find(function (el) { return el.dataset.datasetId === datasetId; })
                : null;

            if (action === "deleted") {
                const deletedName = escapeHtml(payload.name || "Môn học");
                // Xóa dataset khỏi sidebar
                if (existingEntry) existingEntry.remove();
                // Nếu user đang xem dataset bị xóa → redirect về trang chủ
                if (workspaceEl && workspaceEl.dataset.selectedDatasetId === datasetId) {
                    if (window.showToastNotification) {
                        window.showToastNotification(`Môn học "${deletedName}" đã được quản trị viên xóa.`);
                    }
                    setTimeout(function () { window.location.assign("/"); }, 1500);
                } else if (existingEntry && window.showToastNotification) {
                    // Dataset bị xóa nhưng user không đang xem → vẫn báo
                    window.showToastNotification(`Môn học "${deletedName}" đã bị xóa.`);
                }
                // Cập nhật counter
                if (datasetList) {
                    const count = document.querySelector("[data-dataset-count]");
                    if (count) {
                        count.textContent = String(datasetList.querySelectorAll("[data-dataset-id]").length);
                    }
                }
                return;
            }

            if (action === "created") {
                // Thêm dataset mới vào đầu sidebar
                if (!existingEntry && datasetList) {
                    const emptyState = datasetList.querySelector(".helper-text");
                    if (emptyState) emptyState.remove();

                    const wrapper = document.createElement("div");
                    wrapper.className = "dataset-entry";
                    wrapper.dataset.datasetId = datasetId;

                    const link = document.createElement("a");
                    link.className = "dataset-item";
                    link.href = "/?datasetId=" + encodeURIComponent(datasetId);

                    const isPublicIcon = !payload.isPublic ? ' <span title="Môn học riêng tư" style="font-size: 0.8rem; color: var(--muted); border: 1px solid var(--muted); padding: 1px 4px; border-radius: 4px; margin-left: 4px;">Riêng tư</span>' : "";
                    const isApprovedIcon = !payload.isApproved ? '<span title="Đang chờ duyệt" style="color: var(--warning); font-size: 0.8rem; border: 1px solid var(--warning); padding: 1px 4px; border-radius: 4px; margin-right: 4px;">Chờ duyệt</span> ' : "";

                    link.innerHTML = `
                        <span class="dataset-name">${isApprovedIcon}${escapeHtml(payload.name || "Môn học mới")}${isPublicIcon}</span>
                        <span class="dataset-meta">0 tài liệu</span>
                    `;
                    wrapper.appendChild(link);
                    datasetList.prepend(wrapper);

                    const count = document.querySelector("[data-dataset-count]");
                    if (count) {
                        count.textContent = String(datasetList.querySelectorAll("[data-dataset-id]").length);
                    }

                    // Notify teacher/student when a new subject becomes available.
                    if (window.showToastNotification) {
                        window.showToastNotification(`Đã thêm môn học mới: "${escapeHtml(payload.name || "Môn học mới")}"`);
                    }
                }
                return;
            }

            if ((action === "updated" || action === "approved" || action === "unapproved") && existingEntry) {
                const subjectName = escapeHtml(payload.name || "Môn học");

                // Cập nhật tên môn học (Hỗ trợ cả Card Grid và Sidebar)
                const nameEl = existingEntry.querySelector(".subject-card-title") || existingEntry.querySelector(".dataset-name");
                if (nameEl && payload.name) {
                    nameEl.textContent = payload.name;
                }

                // Cập nhật mô tả (Chỉ cho Card Grid)
                const descEl = existingEntry.querySelector(".card-body p");
                if (descEl && payload.description) {
                    descEl.textContent = payload.description;
                }

                // Cập nhật Pending Badge cho Card Grid
                const headerEl = existingEntry.querySelector(".card-body > div");
                if (headerEl) {
                    let badgeEl = headerEl.querySelector(".badge");
                    if (!payload.isApproved) {
                        if (!badgeEl) {
                            badgeEl = document.createElement("span");
                            badgeEl.className = "badge";
                            badgeEl.style.fontSize = "0.75rem";
                            badgeEl.style.borderRadius = "4px";
                            badgeEl.style.background = "var(--warning-soft)";
                            badgeEl.style.color = "var(--warning)";
                            badgeEl.style.fontWeight = "600";
                            badgeEl.textContent = "Chờ duyệt";
                            headerEl.appendChild(badgeEl);
                        }
                    } else {
                        if (badgeEl) {
                            badgeEl.remove();
                        }
                    }
                }

                // Nếu đang xem chính dataset này → cũng highlight lại link
                const link = existingEntry.querySelector(".dataset-item");
                if (link && workspaceEl && workspaceEl.dataset.selectedDatasetId === datasetId) {
                    link.classList.add("active");
                }

                // Toast thông báo theo action
                if (window.showToastNotification) {
                    if (action === "updated") {
                        window.showToastNotification(`Quản trị viên đã cập nhật môn học "${subjectName}".`);
                    } else if (action === "approved") {
                        window.showToastNotification(`Môn học "${subjectName}" đã được duyệt và đang hoạt động.`);
                    } else if (action === "unapproved") {
                        window.showToastNotification(`Môn học "${subjectName}" đã tạm ngưng hoạt động.`);
                    }
                }
                return;
            }
        });

        window.addEventListener("rag:chat-session-changed", function (event) {
            const payload = event.detail;
            const workspaceEl = document.querySelector("[data-rag-app]");
            const sessionList = document.querySelector("[data-session-list]");
            if (!payload || !workspaceEl || !sessionList || workspaceEl.dataset.selectedDatasetId !== String(payload.datasetId)) {
                return;
            }

            if (sessionList.querySelector(`[data-session-id="${payload.sessionId}"]`)) {
                return;
            }

            const emptyState = sessionList.querySelector(".helper-text");
            if (emptyState) emptyState.remove();

            const link = document.createElement("a");
            link.className = "session-item";
            link.dataset.sessionId = payload.sessionId;
            link.href = `?datasetId=${encodeURIComponent(payload.datasetId)}&sessionId=${encodeURIComponent(payload.sessionId)}`;
            link.style.textDecoration = "none";
            link.innerHTML = `
                <span class="session-name">${escapeHtml(localizeSessionTitle(payload.title))}</span>
                <span class="session-meta">Cập nhật ${formatVietnamTime(new Date(payload.updatedAt || payload.changedAt))}</span>
            `;
            sessionList.prepend(link);
        });

        window.addEventListener("rag:chat-message-saved", function (event) {
            const payload = event.detail;
            const workspaceEl = document.querySelector("[data-rag-app]");
            if (!payload || !workspaceEl || workspaceEl.dataset.selectedSessionId !== String(payload.sessionId)) {
                return;
            }

            if (composerForm && composerForm.dataset.realtimeSuppress === "true") {
                return;
            }

            appendRealtimeMessage(payload.userMessage);
            appendRealtimeMessage(payload.assistantMessage, payload.citations && payload.citations.length > 0);

            if (payload.citations && payload.citations.length > 0) {
                renderCitationsDirectly(payload.citations);
            }

            if (chatStream) {
                chatStream.scrollTop = chatStream.scrollHeight;
            }
        });

        function appendMessage(role, content, time, messageId = null, hasCitations = false) {
            if (messageId && document.querySelector(`[data-message-id="${messageId}"]`)) {
                const existing = document.querySelector(`[data-message-id="${messageId}"]`);
                const existingText = existing.querySelector(".message-bubble .message-content");
                if (existingText && content) {
                    if (role === "assistant") {
                        existingText.innerHTML = renderMarkdown(content);
                    } else {
                        existingText.textContent = content;
                    }
                }
                return existing;
            }

            const emptyState = chatStream.querySelector(".empty-state");
            if (emptyState) emptyState.remove();

            const messageDiv = document.createElement("div");
            messageDiv.className = `message flex flex-col ${role} ${role === 'user' ? 'items-end' : 'items-start'}`;
            if (messageId) {
                messageDiv.dataset.messageId = messageId;
            }
            
            let citationHtml = "";
            if (role === "assistant" && messageId && hasCitations) {
                citationHtml = `
                    <div class="citation-row mt-2">
                        <button class="citation-chip view-sources-btn inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-xs font-medium text-gray-600 hover:bg-gray-50 hover:text-ink hover:border-gray-400 transition-colors shadow-sm" 
                                data-message-id="${messageId}">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                             Xem nguồn trích dẫn
                        </button>
                    </div>
                `;
            }

            const bubbleClass = role === 'user' 
                ? 'bg-accent-strong text-white rounded-br-sm' 
                : 'bg-white border border-gray-200 text-ink rounded-bl-sm';
            
            const contentClass = role === 'assistant' ? 'ai-markdown prose prose-sm prose-indigo max-w-none' : 'user-message-text whitespace-pre-wrap';

            messageDiv.innerHTML = `
                <div class="message-bubble max-w-[85%] sm:max-w-[75%] rounded-2xl px-5 py-3.5 shadow-sm ${bubbleClass}">
                    <div class="message-content text-[15px] leading-relaxed ${contentClass}">${role === "assistant" ? renderMarkdown(content) : escapeHtml(content)}</div>
                </div>
                <div class="message-meta text-[11px] font-medium text-gray-400 mt-1.5 px-1">
                    ${role === "user" ? "Bạn" : "Trợ lý"} &bull; ${time}
                </div>
                ${citationHtml}
            `;
            chatStream.appendChild(messageDiv);
            return messageDiv;
        }

        function appendRealtimeMessage(message, hasCitations = false) {
            if (!message) return;

            const role = String(message.role || "").toLowerCase();
            appendMessage(
                role === "assistant" ? "assistant" : "user",
                message.content || "",
                formatVietnamTime(new Date(message.createdAt)),
                message.messageId,
                hasCitations
            );
        }

        function updateCreditBalanceDisplay(creditBalance) {
            if (!creditBalance) return;
            const totalCredits = creditBalance.totalCredits ?? creditBalance.TotalCredits;
            const freeCredits = creditBalance.freeCredits ?? creditBalance.FreeCredits;
            const paidCredits = creditBalance.paidCredits ?? creditBalance.PaidCredits;
            const creditTotalText = document.getElementById("creditTotalText");
            const creditFreeText = document.getElementById("creditFreeText");
            const creditPaidText = document.getElementById("creditPaidText");
            const creditTotalPortal = document.getElementById("creditTotalPortal");
            const creditFreePortal = document.getElementById("creditFreePortal");
            const creditPaidPortal = document.getElementById("creditPaidPortal");
            if (creditTotalText) creditTotalText.textContent = Number(totalCredits || 0).toLocaleString();
            if (creditFreeText) creditFreeText.textContent = Number(freeCredits || 0).toLocaleString();
            if (creditPaidText) creditPaidText.textContent = Number(paidCredits || 0).toLocaleString();
            if (creditTotalPortal) creditTotalPortal.textContent = Number(totalCredits || 0).toLocaleString();
            if (creditFreePortal) creditFreePortal.textContent = Number(freeCredits || 0).toLocaleString();
            if (creditPaidPortal) creditPaidPortal.textContent = Number(paidCredits || 0).toLocaleString();
        }

        function updateCreditSpendDisplay(creditSpend) {
            if (!creditSpend) return;
            const latestCreditChargeText = document.getElementById("latestCreditChargeText");
            if (!latestCreditChargeText) return;
            const calculatedValue = creditSpend.calculatedCredits ?? creditSpend.CalculatedCredits ?? 0;
            const chargedValue = creditSpend.chargedCredits ?? creditSpend.ChargedCredits ?? 0;
            const insufficient = creditSpend.wasInsufficientBalance ?? creditSpend.WasInsufficientBalance;
            const calculated = Number(calculatedValue).toLocaleString();
            const charged = Number(chargedValue).toLocaleString();
            latestCreditChargeText.textContent = insufficient
                ? `Câu trả lời gần nhất cần ${calculated} Credit, đã dùng ${charged} Credit còn lại.`
                : `Câu trả lời gần nhất đã dùng ${charged} Credit.`;
        }

        function formatVietnamTime(value) {
            return new Intl.DateTimeFormat("vi-VN", {
                timeZone: "Asia/Ho_Chi_Minh",
                hour: "2-digit",
                minute: "2-digit",
                hour12: false
            }).format(value);
        }

        function appendLoadingBubble() {
            const emptyState = chatStream.querySelector(".empty-state");
            if (emptyState) emptyState.remove();

            const loadingDiv = document.createElement("div");
            loadingDiv.className = "message flex flex-col items-start assistant loading-bubble";
            loadingDiv.innerHTML = `
                <div class="message-bubble max-w-[85%] sm:max-w-[75%] rounded-2xl px-5 py-3.5 shadow-sm bg-white border border-gray-200 text-ink rounded-bl-sm flex items-center gap-2">
                    <span style="display: inline-block; animation: spin 1s linear infinite;">&#9203;</span>
                    <span class="text-sm italic text-gray-500">Đang tìm tài liệu và tạo câu trả lời...</span>
                </div>
                <div class="message-meta text-[11px] font-medium text-gray-400 mt-1.5 px-1">
                    Trợ lý &bull; Đang chuẩn bị
                </div>
            `;
            chatStream.appendChild(loadingDiv);
            return loadingDiv;
        }

        function getOrCreatePendingAssistant(messageId) {
            const key = String(messageId);
            if (pendingAssistantMessages.has(key)) {
                return pendingAssistantMessages.get(key);
            }

            let pending = chatStream ? chatStream.querySelector(".loading-bubble") : null;
            if (!pending) {
                pending = appendMessage("assistant", "", formatVietnamTime(new Date()));
            }

            pending.classList.remove("loading-bubble");
            pending.classList.add("pending-message");
            pending.dataset.pendingMessageId = key;
            pending.innerHTML = `
                <div class="message-bubble max-w-[85%] sm:max-w-[75%] rounded-2xl px-5 py-3.5 shadow-sm bg-white border border-gray-200 text-ink rounded-bl-sm">
                    <div class="message-content text-[15px] leading-relaxed ai-markdown prose prose-sm prose-indigo max-w-none"></div>
                </div>
                <div class="message-meta text-[11px] font-medium text-gray-400 mt-1.5 px-1">
                    Trợ lý &bull; Đang trả lời
                </div>
            `;
            pendingAssistantMessages.set(key, pending);
            return pending;
        }

        function appendPendingAssistantChunk(messageId, chunk) {
            const pending = getOrCreatePendingAssistant(messageId);
            const text = pending.querySelector(".message-bubble .message-content");
            if (text) {
                text._rawMarkdown = (text._rawMarkdown || "") + (chunk || "");
                text.innerHTML = renderMarkdown(text._rawMarkdown);
            }
            if (chatStream) {
                chatStream.scrollTop = chatStream.scrollHeight;
            }
        }

        function finalizePendingAssistant(message, citations) {
            if (!message) return;
            const key = String(message.messageId || message.MessageId);
            let pending = pendingAssistantMessages.get(key);
            if (!pending && key) {
                pending = document.querySelector(`[data-pending-message-id="${key}"]`);
            }

            if (!pending) {
                appendRealtimeMessage(message, citations && citations.length > 0);
                return;
            }

            pendingAssistantMessages.delete(key);
            pending.classList.remove("pending-message");
            pending.dataset.messageId = key;
            delete pending.dataset.pendingMessageId;
            const content = message.content ?? message.Content ?? "";
            const createdAt = message.createdAt ?? message.CreatedAt ?? new Date();
            const hasCitations = citations && citations.length > 0;
            let citationHtml = "";
            if (hasCitations) {
                citationHtml = `
                    <div class="citation-row" style="margin-top: 8px;">
                        <button class="citation-chip view-sources-btn"
                                data-message-id="${key}"
                                style="background: none; border: none; font: inherit; text-decoration: none; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 4px;">
                            &#128269; Xem nguồn trích dẫn
                        </button>
                    </div>
                `;
            }

            pending.innerHTML = `
                <div class="message-bubble">
                    <div class="message-content ai-markdown">${renderMarkdown(content)}</div>
                </div>
                <div class="message-meta">
                    Trợ lý &bull; ${formatVietnamTime(new Date(createdAt))}
                </div>
                ${citationHtml}
            `;
        }

        function markAssistantBubbleAsFailed(bubble, errorMessage) {
            bubble.classList.remove("pending-message", "loading-bubble");
            bubble.classList.add("failed-message");
            bubble.innerHTML = `
                <div class="message-bubble">
                    <p style="margin: 0; white-space: pre-wrap;">${escapeHtml(errorMessage || friendlyAiUnavailableMessage)}</p>
                </div>
                <div class="message-meta">
                    Trợ lý &bull; Thất bại
                </div>
            `;
        }

        function failPendingAssistant(messageId, errorMessage) {
            const key = String(messageId);
            if (failedAssistantMessageIds.has(key)) {
                return;
            }

            const pending = pendingAssistantMessages.get(key) ||
                document.querySelector(`[data-pending-message-id="${key}"]`) ||
                (chatStream ? chatStream.querySelector(".loading-bubble") : null);
            pendingAssistantMessages.delete(key);
            if (pending) {
                markAssistantBubbleAsFailed(pending, errorMessage || friendlyAiUnavailableMessage);
            }

            failedAssistantMessageIds.add(key);
        }

        const workspaceForChatHub = document.querySelector("[data-rag-app]");
        if (workspaceForChatHub && workspaceForChatHub.dataset.selectedSessionId && window.signalR) {
            const chatConnection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/chat")
                .withAutomaticReconnect()
                .build();

            chatConnection.on("ReceiveChatChunk", function (messageId, chunk) {
                appendPendingAssistantChunk(messageId, chunk);
            });

            chatConnection.on("ReceiveChatComplete", function (message, citations, creditInfo) {
                finalizePendingAssistant(message, citations || []);
                if (citations && citations.length > 0) {
                    renderCitationsDirectly(citations);
                }
                if (creditInfo) {
                    updateCreditBalanceDisplay(creditInfo.creditBalance || creditInfo.CreditBalance);
                    updateCreditSpendDisplay(creditInfo.creditSpend || creditInfo.CreditSpend);
                }
                if (chatStream) {
                    chatStream.scrollTop = chatStream.scrollHeight;
                }
            });

            chatConnection.on("ReceiveChatFailed", function (messageId, errorMessage) {
                failPendingAssistant(messageId, errorMessage);
                if (chatStream) {
                    chatStream.scrollTop = chatStream.scrollHeight;
                }
            });

            chatConnectionReady = chatConnection.start()
                .then(function () {
                    return chatConnection.invoke("JoinSession", workspaceForChatHub.dataset.selectedSessionId);
                })
                .then(function () { return true; })
                .catch(function (error) {
                    console.warn("Không thể thiết lập kết nối streaming cho cuộc trò chuyện.", error);
                    return false;
                });
        }

        // Láº¯ng nghe sá»± kiá»‡n click vÃ o nÃºt xem trÃ­ch dáº«n (Event Delegation Ä‘á»ƒ há»— trá»£ cáº£ tin nháº¯n má»›i)
        document.addEventListener("click", function(e) {
            const btn = e.target.closest(".view-sources-btn");
            if (btn) {
                e.preventDefault();
                const messageId = btn.getAttribute("data-message-id");
                fetchCitations(messageId);
            }
        });

        function fetchCitations(messageId) {
            openReferencePanel();

            const referencePanel = document.querySelector(".reference-panel");
            if (!referencePanel) return;

            // Render giao diá»‡n chá» táº£i trÃ­ch dáº«n bÃªn cá»™t pháº£i
            referencePanel.innerHTML = `
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">TÀI LIỆU THAM KHẢO</p>
                        <h2>Nguồn trích dẫn</h2>
                    </div>
                    <button type="button" class="reference-close-btn" aria-label="Đóng nguồn trích dẫn" title="Đóng nguồn trích dẫn" data-close-references>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                </div>
                <div style="padding: 24px; text-align: center; color: var(--muted);">
                    <span style="display: inline-block; font-size: 1.5rem; margin-bottom: 8px; animation: spin 1.2s linear infinite;">&#9203;</span>
                    <p style="font-size: 0.85rem; margin: 0;">Đang tải nguồn trích dẫn...</p>
                </div>
            `;

            // Tá»± Ä‘á»™ng chuyá»ƒn tab trÃªn Mobile sang tab "Sources"
            const workspace = document.querySelector(".workspace");
            if (workspace && window.innerWidth <= 820) {
                workspace.setAttribute("data-active-tab", "reference-panel");
                const refTabBtn = document.querySelector('.mobile-tab-btn[data-target="reference-panel"]');
                if (refTabBtn) {
                    document.querySelectorAll(".mobile-tab-btn").forEach(b => b.classList.remove("active"));
                    refTabBtn.classList.add("active");
                }
            }

            // Gá»i API láº¥y thÃ´ng tin trÃ­ch dáº«n
            fetch(`?handler=GetCitations&messageId=${messageId}`)
                .then(response => {
                    if (!response.ok) throw new Error("Không thể tải nguồn trích dẫn.");
                    return response.json();
                })
                .then(citations => {
                    renderCitationsDirectly(citations);
                })
                .catch(err => {
                    console.error(err);
                    referencePanel.innerHTML = `
                        <div class="panel-header">
                            <div>
                                <p class="eyebrow">TÀI LIỆU THAM KHẢO</p>
                                <h2>Nguồn trích dẫn</h2>
                            </div>
                            <button type="button" class="reference-close-btn" aria-label="Đóng nguồn trích dẫn" title="Đóng nguồn trích dẫn" data-close-references>
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                            </button>
                        </div>
                        <div style="padding: 24px; text-align: center; color: var(--danger);">
                            <p style="font-size: 0.85rem; margin: 0;">Không thể tải nguồn trích dẫn. Vui lòng thử lại.</p>
                        </div>
                    `;
                });
        }

        function renderCitationsDirectly(citations) {
            openReferencePanel();

            const referencePanel = document.querySelector(".reference-panel");
            if (!referencePanel) return;

            let html = `
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">TÀI LIỆU THAM KHẢO</p>
                        <h2>Nguồn trích dẫn</h2>
                    </div>
                    <button type="button" class="reference-close-btn" aria-label="Đóng nguồn trích dẫn" title="Đóng nguồn trích dẫn" data-close-references>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                </div>
            `;

            if (!citations || citations.length === 0) {
                html += `
                    <div class="reference-empty">
                        <h3>Không có nguồn trích dẫn</h3>
                        <p>Không tìm thấy đoạn tài liệu cụ thể cho câu trả lời này.</p>
                    </div>
                `;
            } else {
                html += `<div class="reference-content">`;
                citations.forEach(c => {
                    const docId = c.documentId || '';
                    const chunkId = c.chunkId || '';
                    const quoteText = c.quoteText || '';
                    const isPdf = String(c.fileType || '').toLowerCase() === 'pdf';
                    const locationLabel = isPdf
                        ? `<p><strong>Trang:</strong> ${c.pageNumber > 0 ? c.pageNumber : 'Không xác định'}</p>`
                        : `<p><strong>Đoạn:</strong> ${c.chunkIndex || 'Không xác định'}</p>`;
                    
                    let previewBtn = '';
                    if (docId && chunkId) {
                        previewBtn = `
                            <button type="button" class="btn btn-sm btn-outline-primary w-100 mt-2 d-flex align-items-center justify-content-center gap-1 preview-evidence-btn"
                                    data-document-id="${escapeHtml(docId)}"
                                    data-chunk-id="${escapeHtml(chunkId)}"
                                    data-quote="${escapeHtml(quoteText)}"
                                    style="border-radius: 6px; font-size: 0.8rem; font-weight: 600; padding: 6px 12px; border: 1.5px solid var(--accent); color: var(--accent); background: transparent; transition: all 0.2s;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                Xem trong tài liệu
                            </button>
                        `;
                    }

                    html += `
                        <div class="reference-card">
                            <h3 title="${escapeHtml(c.fileName)}">${escapeHtml(c.fileName)}</h3>
                            ${locationLabel}
                            <p><strong>Nhãn nguồn:</strong> ${escapeHtml(c.sourceLabel || "Không có")}</p>
                            <p style="margin-top: 6px; font-style: italic; background: var(--surface-muted); padding: 8px; border-radius: 6px; border-left: 3px solid var(--accent); margin-bottom: 8px;">
                                "${escapeHtml(quoteText)}"
                            </p>
                            ${previewBtn}
                        </div>
                    `;
                });
                html += `</div>`;
            }
            referencePanel.innerHTML = html;
        }

        // Event delegation cho preview evidence button
        document.addEventListener("click", function(e) {
            const btn = e.target.closest(".preview-evidence-btn");
            if (btn) {
                e.preventDefault();
                const docId = btn.getAttribute("data-document-id");
                const chunkId = btn.getAttribute("data-chunk-id");
                const quote = btn.getAttribute("data-quote");
                previewDocument(docId, chunkId, quote);
            }
        });

        function previewDocument(documentId, targetChunkId, quoteText) {
            const body = document.getElementById("docPreviewBody");
            const modal = document.getElementById("docPreviewModal");
            const title = document.getElementById("docPreviewTitle");

            title.textContent = "Đang tải xem trước tài liệu...";
            body.innerHTML = `
                <div style="text-align: center; color: var(--muted); padding: 40px;">
                    <span style="display: inline-block; font-size: 1.5rem; margin-bottom: 8px; animation: spin 1.2s linear infinite;">&#9203;</span>
                    <p style="font-size: 0.85rem; margin: 0;">Đang tải các đoạn nội dung...</p>
                </div>
            `;
            modal.style.display = "flex";

            fetch(`?handler=DocumentChunks&documentId=${documentId}`)
                .then(r => {
                    if (!r.ok) throw new Error("Không thể tải các đoạn nội dung.");
                    return r.json();
                })
                .then(data => {
                    title.textContent = data.fileName;
                    body.innerHTML = "";
                    
                    data.chunks.forEach(chunk => {
                        const chunkDiv = document.createElement("div");
                        chunkDiv.className = "preview-chunk-item";
                        chunkDiv.style.padding = "16px";
                        chunkDiv.style.border = "1.5px solid var(--line)";
                        chunkDiv.style.borderRadius = "8px";
                        chunkDiv.style.transition = "all 0.3s ease";
                        
                        const isTarget = chunk.chunkId === targetChunkId;
                        let contentHtml = escapeHtml(chunk.content);
                        
                        if (isTarget) {
                            chunkDiv.style.background = "rgba(245, 158, 11, 0.05)";
                            chunkDiv.style.borderColor = "var(--accent)";
                            chunkDiv.style.boxShadow = "0 0 12px rgba(37, 99, 235, 0.15)";
                            if (quoteText) {
                                const escapedQuote = escapeHtml(quoteText.trim());
                                if (contentHtml.includes(escapedQuote)) {
                                    contentHtml = contentHtml.replace(escapedQuote, `<mark class="highlight-evidence" style="background: #fef08a; color: #854d0e; padding: 2px 4px; border-radius: 4px; font-weight: 600; border-bottom: 1.5px solid #ca8a04;">${escapedQuote}</mark>`);
                                } else {
                                    // Case insensitive check
                                    const lowerContent = contentHtml.toLowerCase();
                                    const lowerQuote = escapedQuote.toLowerCase();
                                    const idx = lowerContent.indexOf(lowerQuote);
                                    if (idx >= 0) {
                                        const originalQuotePart = contentHtml.substring(idx, idx + escapedQuote.length);
                                        contentHtml = contentHtml.substring(0, idx) + 
                                                      `<mark class="highlight-evidence" style="background: #fef08a; color: #854d0e; padding: 2px 4px; border-radius: 4px; font-weight: 600; border-bottom: 1.5px solid #ca8a04;">${originalQuotePart}</mark>` + 
                                                      contentHtml.substring(idx + escapedQuote.length);
                                    }
                                }
                            }
                        } else {
                            chunkDiv.style.background = "var(--surface-muted)";
                        }
                        
                        chunkDiv.innerHTML = `
                            <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--muted); margin-bottom: 8px; border-bottom: 1px dashed var(--line); padding-bottom: 6px;">
                                <strong style="display: flex; align-items: center; gap: 4px;">
                                    Đoạn #${chunk.chunkIndex}
                                    ${isTarget ? '<span style="color: var(--accent); font-weight: 700; background: rgba(37,99,235,0.1); padding: 2px 6px; border-radius: 4px; font-size: 0.65rem;">★ Nội dung đối chiếu</span>' : ''}
                                </strong>
                                <span>Trang ${chunk.pageNumber}</span>
                            </div>
                            <pre style="white-space: pre-wrap; font-family: inherit; color: var(--ink); margin: 0; font-size: 0.88rem; line-height: 1.6;">${contentHtml}</pre>
                        `;
                        
                        body.appendChild(chunkDiv);
                        
                        if (isTarget) {
                            setTimeout(() => {
                                chunkDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            }, 150);
                        }
                    });
                })
                .catch(err => {
                    title.textContent = "Không thể tải tài liệu";
                    body.innerHTML = `<p style="color: var(--danger); text-align: center; padding: 20px;">Không thể tải nội dung tài liệu. Vui lòng thử lại.</p>`;
                });
        }
        
        function closeDocPreviewModal() {
            document.getElementById("docPreviewModal").style.display = "none";
        }

        // Logic chuyá»ƒn Ä‘á»•i Tab trÃªn thiáº¿t bá»‹ di Ä‘á»™ng
        function openReferencePanel() {
            const workspace = document.querySelector(".workspace");
            if (workspace) {
                workspace.classList.add("citations-active");
            }
        }

        function closeReferencePanel() {
            const workspace = document.querySelector(".workspace");
            if (workspace) {
                workspace.classList.remove("citations-active");
            }
        }

        document.addEventListener("click", function(e) {
            const closeBtn = e.target.closest("[data-close-references]");
            if (closeBtn) {
                e.preventDefault();
                closeReferencePanel();
            }
        });

        const tabBtns = document.querySelectorAll(".mobile-tab-btn");
        const workspace = document.querySelector(".workspace");
        if (tabBtns && workspace) {
            tabBtns.forEach(btn => {
                btn.addEventListener("click", () => {
                    tabBtns.forEach(b => b.classList.remove("active"));
                    btn.classList.add("active");
                    const target = btn.getAttribute("data-target");
                    workspace.setAttribute("data-active-tab", target);
                });
            });
        }

        function triggerUpload() {
            const fileInput = document.getElementById('file-upload');
            const uploadForm = document.getElementById('upload-doc-form');
            if (!fileInput || !uploadForm || uploadForm.dataset.submitting === "true") {
                return;
            }

            if (fileInput && fileInput.files && fileInput.files.length > 0) {
                const file = fileInput.files[0];
                const maxSize = 50 * 1024 * 1024; // 50MB
                if (file.size > maxSize) {
                    alert('Tệp vượt quá dung lượng cho phép (tối đa 50 MB). Vui lòng chọn tệp nhỏ hơn.');
                    fileInput.value = ""; // Reset
                    return;
                }
            } else {
                return;
            }

            const dropzone = document.getElementById('upload-dropzone');
            const idleState = document.getElementById('upload-idle-state');
            const loadingState = document.getElementById('upload-loading-state');

            uploadForm.dataset.submitting = "true";
            if (dropzone) {
                dropzone.dataset.uploading = "true";
                dropzone.style.cursor = "not-allowed";
                dropzone.style.borderColor = "var(--accent)";
            }
            if (idleState) idleState.style.display = "none";
            if (loadingState) loadingState.style.display = "flex";
            if (processingOverlay) processingOverlay.style.display = "flex";

            uploadForm.requestSubmit();
        }

    </script>
}
