@page
@model RagChatbotSystem.Presentation.Pages.IndexModel
@{
    ViewData["Title"] = "Không gian học tập";
    var defaultMobileTab = Model.SelectedMessageId.HasValue ? "reference-panel" : "chat-panel";
    var roleValue = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var localizedRole = roleValue switch
    {
        "Student" => "Sinh viên",
        "Teacher" => "Giảng viên",
        "Admin" => "Quản trị viên",
        _ => roleValue
    };
    Func<string?, string> localizeDocumentStatus = status => status?.Trim().ToLowerInvariant() switch
    {
        "completed" => "Đã xử lý",
        "processing" => "Đang xử lý",
        "uploaded" => "Đã tải lên",
        "failed" => "Thất bại",
        "hidden" => "Đã ẩn",
        _ => status ?? "Chưa xác định"
    };
    Func<string?, string> localizeSessionTitle = title => title?.Trim().ToLowerInvariant() switch
    {
        "new chat" => "Trò chuyện mới",
        "new session" => "Trò chuyện mới",
        "subject chat" => "Trò chuyện môn học",
        _ => title ?? "Trò chuyện mới"
    };
}

@if (!Model.SelectedDatasetId.HasValue)
{
    <!-- Subject Portal Page -->
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-3">
            <div>
                <p class="eyebrow" style="color: var(--muted); text-transform: uppercase; font-size: 0.75rem; font-weight: 700; letter-spacing: 1px; margin-bottom: 6px;">CỔNG HỌC TẬP</p>
                <h1 class="fw-bold m-0" style="color: var(--ink); font-size: 2.2rem; letter-spacing: -0.5px;">Chọn không gian học tập</h1>
                <p class="text-muted mb-0 mt-1">Chọn môn học để bắt đầu trò chuyện dựa trên nguồn tài liệu đã cung cấp.</p>
            </div>
            @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
            {
                <a asp-page="/Datasets/Index" class="btn btn-outline-primary d-flex align-items-center gap-2" style="border-radius: 8px; font-weight: 600; padding: 10px 18px; border-color: var(--accent); color: var(--accent); text-decoration: none;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.1a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    Quản lý môn học
                </a>
                <a asp-page="/Admin/ModelComparison/Index" class="btn btn-outline-primary d-flex align-items-center gap-2" style="border-radius: 8px; font-weight: 600; padding: 10px 18px; border-color: var(--accent); color: var(--accent); text-decoration: none;">
                    So sánh mô hình
                </a>
            }
            @if (User.IsInRole("Student"))
            {
                    @if (Model.CreditBalance != null)
                    {
                        <div class="p-3 shadow-sm border" style="border-radius: 12px; background: var(--surface); min-width: 280px; max-width: 320px;">
                            <div class="d-flex justify-content-between small">
                                <span class="text-muted fw-bold">Số dư Credit</span>
                                <span class="fw-bold" id="creditTotalPortal">@Model.CreditBalance.TotalCredits.ToString("N0")</span>
                            </div>
                            <div class="d-flex justify-content-between small mt-1">
                                <span class="text-muted">Credit miễn phí</span>
                                <span id="creditFreePortal">@Model.CreditBalance.FreeCredits.ToString("N0")</span>
                            </div>
                            <div class="d-flex justify-content-between small">
                                <span class="text-muted">Credit đã mua</span>
                                <span id="creditPaidPortal">@Model.CreditBalance.PaidCredits.ToString("N0")</span>
                            </div>
                            <a asp-page="/Credits" class="small fw-bold d-inline-block mt-2" style="color: var(--accent); text-decoration: none;">Nạp Credit</a>
                        </div>
                    }
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger mb-4" style="border-radius: 8px;">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success mb-4" style="border-radius: 8px;">@Model.SuccessMessage</div>
        }

        <div class="row g-4" data-dataset-list>
            @if (Model.Datasets.Count == 0)
            {
                <div class="col-12 text-center py-5">
                    <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--surface); border: 1px solid var(--line); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path><path d="M6 6h10"></path><path d="M6 10h10"></path></svg>
                    </div>
                    <h3 class="fw-bold" style="color: var(--ink);">Chưa có môn học khả dụng</h3>
                    <p class="text-muted" style="max-width: 400px; margin: 8px auto 0;">Bạn chưa có quyền truy cập môn học nào. Vui lòng liên hệ quản trị viên hoặc giảng viên.</p>
                </div>
            }
            else
            {
                @foreach (var ds in Model.Datasets)
                {
                    <div class="col-md-6 col-lg-4" data-dataset-id="@ds.DatasetId">
                        <a href="?datasetId=@ds.DatasetId" class="card h-100 border-0 shadow-soft text-decoration-none subject-portal-card" style="border-radius: 12px; background: var(--surface); border: 1px solid var(--line) !important; display: flex; flex-direction: column; transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);">
                            <div class="card-body p-4 d-flex flex-column h-100">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h4 class="fw-bold m-0 subject-card-title" style="color: var(--ink); line-height: 1.3;">@ds.Name</h4>
                                    @if (!ds.IsApproved)
                                    {
                                        <span class="badge" style="font-size: 0.75rem; border-radius: 4px; background: var(--warning-soft); color: var(--warning); font-weight: 600;">Chờ duyệt</span>
                                    }
                                </div>
                                <p class="dataset-description text-muted small flex-grow-1" style="line-height: 1.5; margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                    @(string.IsNullOrWhiteSpace(ds.Description) ? "Chưa có mô tả." : ds.Description)
                                </p>
                                <div class="d-flex justify-content-between align-items-center mt-auto pt-3" style="border-top: 1px solid var(--line);">
                                <span class="dataset-document-count text-muted small d-flex align-items-center gap-1">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                        @ds.DocumentCount tài liệu
                                    </span>
                                    <span class="small fw-bold enter-workspace-text" style="color: var(--accent); transition: all 0.2s;">
                                        Vào không gian học tập &rarr;
                                    </span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
        </div>
    </div>
}
else
{
    <section class="workspace" data-rag-app data-active-tab="@defaultMobileTab" data-selected-dataset-id="@Model.SelectedDatasetId" data-selected-session-id="@Model.SelectedSessionId">
        <!-- Mobile Navigation Tabs (Only visible on mobile screens) -->
        <div class="mobile-workspace-tabs" aria-label="Điều hướng không gian học tập">
            <button class="mobile-tab-btn @(defaultMobileTab == "chat-panel" ? "active" : "")" data-target="chat-panel">Trò chuyện</button>
            <button class="mobile-tab-btn @(defaultMobileTab == "management-panel" ? "active" : "")" data-target="management-panel">Môn học</button>
            <button class="mobile-tab-btn @(defaultMobileTab == "reference-panel" ? "active" : "")" data-target="reference-panel">
                Nguồn @(Model.Citations.Count > 0 ? $"({Model.Citations.Count})" : "")
            </button>
        </div>

        <!-- Cot 1: Bang dieu khien quan ly (Management) -->
        <aside class="workspace-panel management-panel" aria-label="Quản lý môn học">
            <div class="panel-header" style="padding: 20px; margin: -16px -16px 16px -16px; border-bottom: 1px solid var(--line); border-radius: var(--radius) var(--radius) 0 0; background: var(--surface-muted);">
                <div>
                    <a asp-page="/Index" class="text-decoration-none d-inline-flex align-items-center gap-1 mb-2" style="font-size: 0.8rem; color: var(--muted); font-weight: 600;">
                        &larr; Quay lại danh sách môn học
                    </a>
                    <h1 style="font-weight: 700; margin: 0; color: var(--ink); font-size: 1.25rem;">@Model.SelectedDataset?.Name</h1>
                    <p class="text-muted small mb-0">Không gian học tập</p>
                </div>
                <a class="icon-button" href="?datasetId=@Model.SelectedDatasetId&sessionId=@Model.SelectedSessionId" title="Làm mới không gian học tập" aria-label="Làm mới không gian học tập" style="text-decoration: none;">
                    <span aria-hidden="true">Làm mới</span>
                </a>
            </div>

            <!-- Thong bao loi hoac thanh cong -->
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger" style="background: rgba(180, 35, 24, 0.1); border: 1px solid rgba(180, 35, 24, 0.2); padding: 0.75rem; border-radius: 8px; color: var(--danger); margin-bottom: 1rem; font-size: 0.84rem; font-weight: 500;">
                    @Model.ErrorMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success" style="background: rgba(15, 118, 110, 0.1); border: 1px solid rgba(15, 118, 110, 0.2); padding: 0.75rem; border-radius: 8px; color: var(--accent-strong); margin-bottom: 1rem; font-size: 0.84rem; font-weight: 500;">
                    @Model.SuccessMessage
                </div>
            }

            <!-- Thong tin nguoi dung dang nhap -->
            <div style="border-bottom: 1px solid var(--line); padding-bottom: 16px; margin-bottom: 20px;">
                <div style="display: flex; align-items: center; gap: 12px;">
                    <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--surface-muted); border: 1px solid var(--line); display: flex; align-items: center; justify-content: center; font-weight: bold; color: var(--ink-soft);">
                        @(Model.SelectedUser?.FullName?.Substring(0,1).ToUpper() ?? "U")
                    </div>
                    <div>
                        <div class="fw-bold" style="color: var(--ink); font-size: 0.95rem;">@Model.SelectedUser?.FullName</div>
                        <div class="text-muted small" style="font-size: 0.75rem; font-weight: bold;">Vai trò: @localizedRole</div>
                    </div>
                </div>
                @if (User.IsInRole("Student"))
                {
                    <div class="credit-summary mt-3 p-3" style="background: rgba(37, 99, 235, 0.04); border: 1px solid rgba(37, 99, 235, 0.12); border-radius: 10px;">
                        @if (Model.CreditBalance != null)
                        {
                            <div>
                                <div class="credit-summary-row credit-summary-total d-flex justify-content-between align-items-center">
                                    <span class="small text-muted fw-bold">Số dư Credit</span>
                                    <span class="small fw-bold" id="creditTotalText" style="color: var(--accent-strong);">@Model.CreditBalance.TotalCredits.ToString("N0")</span>
                                </div>
                                <div class="credit-summary-row d-flex justify-content-between small mt-1">
                                    <span class="text-muted">Credit miễn phí</span>
                                    <span id="creditFreeText">@Model.CreditBalance.FreeCredits.ToString("N0")</span>
                                </div>
                                <div class="credit-summary-row d-flex justify-content-between small">
                                    <span class="text-muted">Credit đã mua</span>
                                    <span id="creditPaidText">@Model.CreditBalance.PaidCredits.ToString("N0")</span>
                                </div>
                                <a asp-page="/Credits" class="small fw-bold d-inline-block mt-2" style="color: var(--accent); text-decoration: none;">Nạp Credit</a>
                                <p id="latestCreditChargeText" class="helper-text mt-2 mb-0" style="font-size: 0.7rem; color: var(--muted); line-height: 1.3;"></p>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Quáº£n lÃ½ TÃ i liá»‡u (Documents) -->
            <div class="section-block">
                <div class="section-title">
                    <h2>Tài liệu</h2>
                    @if (Model.SelectedDatasetId.HasValue && (User.IsInRole("Teacher") || User.IsInRole("Admin")))
                    {
                        <a asp-page="/Documents/Index" asp-route-datasetId="@Model.SelectedDatasetId" style="font-size: 0.8rem; font-weight: 500; text-decoration: none; color: var(--accent); margin-left: auto; margin-right: 8px;">Quản lý</a>
                    }
                    <span>@Model.Documents.Count</span>
                </div>
                @if (Model.SelectedDatasetId.HasValue && Model.SelectedDataset?.IsArchived != true)
                {
                    <div class="document-list" aria-live="polite" data-document-list>
                        @if (Model.Documents.Count == 0)
                        {
                            <p class="helper-text">Môn học này chưa có tài liệu. Định dạng hỗ trợ: TXT, PDF, DOCX.</p>
                        }
                        @foreach (var doc in Model.Documents)
                        {
                            <div class="document-item" data-document-id="@doc.DocumentId">
                                <div class="document-card-header">
                                    <div class="document-card-main">
                                        <strong class="document-name" title="@doc.FileName">@doc.FileName</strong>
                                        <span class="document-meta">@doc.FileType.ToUpper() - @Math.Ceiling(doc.FileSize / 1024.0) KB</span>
                                    </div>
                                </div>
                                <div style="margin-top: 6px; display: flex; align-items: center; gap: 6px;">
                                    <span class="status-pill @doc.Status.ToLower()" data-document-status style="font-size: 0.75rem; border-radius: 4px; padding: 2px 6px;">@localizeDocumentStatus(doc.Status)</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="helper-text">Chọn một môn học để xem tài liệu.</p>
                }
            </div>

            <!-- Quáº£n lÃ½ Chat Sessions -->
            <div class="section-block">
                <div class="section-title">
                    <h2>Cuộc trò chuyện</h2>
                    <span>@Model.Sessions.Count</span>
                </div>
                <p class="helper-text">Mỗi môn học có thể có nhiều cuộc trò chuyện. Chọn một cuộc trò chuyện hoặc tạo phiên mới.</p>
                @if (Model.SelectedDatasetId.HasValue && Model.SelectedDataset?.IsArchived != true)
                {
                    <form method="post" asp-page-handler="CreateSession" class="create-form" style="margin-bottom: 6px;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                        <div class="input-row">
                            <input name="title" type="text" placeholder="Tên cuộc trò chuyện (không bắt buộc)" aria-label="Tên cuộc trò chuyện" />
                            <button type="submit">Tạo mới</button>
                        </div>
                    </form>
                    <div class="session-list" aria-live="polite" data-session-list>
                        @if (Model.Sessions.Count == 0)
                        {
                            <p class="helper-text">Chưa có cuộc trò chuyện nào.</p>
                        }
                        @foreach (var ss in Model.Sessions)
                        {
                            <a class="session-item @(Model.SelectedSessionId == ss.SessionId ? "active" : "")" 
                               data-session-id="@ss.SessionId"
                               href="?datasetId=@Model.SelectedDatasetId&sessionId=@ss.SessionId"
                               style="text-decoration: none;">
                                 <span class="session-name">@localizeSessionTitle(ss.Title)</span>
                                <span class="session-meta">Cập nhật @RagChatbotSystem.Presentation.Helpers.VietnamTime.Format(ss.UpdatedAt, "HH:mm dd/MM")</span>
                            </a>
                        }
                    </div>
                }
            </div>

            <!-- Thống kê -->
            <div class="section-block mt-4 pt-3" style="border-top: 1px solid var(--line);">
                <div class="section-title mb-2">
                    <h2 style="font-size: 1rem; font-weight: 700; color: var(--ink);">Thống kê</h2>
                </div>
                <div class="d-flex flex-column gap-2" style="font-size: 0.85rem;">
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Tổng tài liệu</span>
                        <strong style="color: var(--accent); font-weight: 700;">@Model.Documents.Count</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Cuộc trò chuyện</span>
                        <strong style="color: #8b5cf6; font-weight: 700;">@Model.Sessions.Count</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Tin nhắn trong phiên</span>
                        <strong style="color: #10b981; font-weight: 700;">@Model.MessageHistory.Count</strong>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Cot 2: Giao dien Hoi thoai (Chat Panel) -->
        <main class="chat-panel" aria-label="Không gian trò chuyện">
        <div class="chat-header" style="padding: 20px; border-bottom: 1px solid var(--line); margin-bottom: 16px; background: var(--surface-muted); border-radius: var(--radius) var(--radius) 0 0;">
            <div>
                <p class="eyebrow" style="letter-spacing: 0.1em; color: var(--muted);">KHÔNG GIAN TRÒ CHUYỆN</p>
                @if (Model.SelectedSession != null)
                {
                    <h2 data-chat-title>@localizeSessionTitle(Model.SelectedSession.Title)</h2>
                }
                else if (Model.SelectedDataset != null)
                {
                    <h2 data-chat-title>Chọn hoặc tạo cuộc trò chuyện</h2>
                }
                else
                {
                    <h2 data-chat-title>Chọn môn học để bắt đầu</h2>
                }
            </div>
            @if (Model.SelectedDatasetId.HasValue && Model.SelectedDataset?.IsArchived != true)
            {
                <form method="post" asp-page-handler="CreateSession" style="margin: 0; padding: 0;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                    <input type="hidden" name="title" value="Trò chuyện môn học" />
                    <button class="secondary-button" type="submit">Phiên mới</button>
                </form>
            }
        </div>

        @if (Model.SelectedDatasetId.HasValue && Model.SelectedSessionId.HasValue)
        {
            <section class="question-suggestions" data-question-suggestions data-dataset-id="@Model.SelectedDatasetId">
                <div class="question-suggestions-header">
                    <div>
                        <p class="eyebrow">GỢI Ý CÂU HỎI AI</p>
                        <h3>Gợi ý học tập cho môn này</h3>
                    </div>
                    <button type="button" class="secondary-button" data-generate-questions>Gợi ý câu hỏi</button>
                </div>
                <div class="suggestion-list" data-suggestion-list>
                    <button type="button" class="suggestion-chip" data-question-template="Tóm tắt các ý chính của môn học này theo tài liệu đã tải lên?">Tóm tắt ý chính</button>
                    <button type="button" class="suggestion-chip" data-question-template="Những khái niệm quan trọng nhất trong tài liệu này là gì?">Khái niệm quan trọng</button>
                    <button type="button" class="suggestion-chip" data-question-template="Hãy tạo 5 câu hỏi ôn tập từ tài liệu của môn học này.">Câu hỏi ôn tập</button>
                </div>
                <p class="suggestion-helper" data-suggestion-helper>Chọn một gợi ý để điền vào ô chat.</p>
            </section>
        }

        <div class="chat-stream" aria-live="polite" id="chatStream">
            @if (Model.SelectedSession != null)
            {
                if (Model.MessageHistory.Count == 0)
                {
                    <div class="empty-state" style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; opacity: 0.8; margin-top: 10vh; text-align: center; padding: 24px;">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent); margin-bottom: 16px;"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                        <h3 style="font-weight: 700; color: var(--ink); margin-bottom: 12px; font-size: 1.25rem;">Đặt câu hỏi dựa trên tài liệu của bạn</h3>
                        <p style="color: var(--muted); max-width: 400px; line-height: 1.6; font-size: 0.95rem;">Nhập câu hỏi bên dưới. AI sẽ tìm các phần liên quan nhất trong tài liệu để trả lời.</p>
                    </div>
                }
                else
                {
                    @foreach (var msg in Model.MessageHistory)
                    {
                        <div class="message @msg.Role.ToLower()" data-message-id="@msg.MessageId">
                            <div class="message-bubble">
                                <div class="message-content @(msg.Role == "Assistant" ? "ai-markdown" : "user-message-text")">@msg.Content</div>
                            </div>
                            <div class="message-meta">
                                @(msg.Role == "User" ? "Bạn" : "Trợ lý") &bull; @RagChatbotSystem.Presentation.Helpers.VietnamTime.Format(msg.CreatedAt, "HH:mm")
                            </div>
                            @if (msg.Role == "Assistant" && Model.MessageIdsWithCitations.Contains(msg.MessageId))
                            {
                                <div class="citation-row" style="margin-top: 8px;">
                                    <button class="citation-chip view-sources-btn" 
                                       data-message-id="@msg.MessageId"
                                       style="background: none; border: 1px solid var(--line); font: inherit; font-size: 0.85rem; padding: 4px 10px; border-radius: 6px; text-decoration: none; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px; color: var(--muted); transition: all 0.2s;" onmouseover="this.style.background='var(--surface-muted)'; this.style.color='var(--ink)';" onmouseout="this.style.background='none'; this.style.color='var(--muted)';">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                                         Xem nguồn trích dẫn
                                    </button>
                                </div>
                            }
                        </div>
                    }
                }
            }
            else
            {
                <div class="empty-state" style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; opacity: 0.8; margin-top: 10vh; text-align: center; padding: 24px;">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent); margin-bottom: 16px;"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                    <h3 style="font-weight: 700; color: var(--ink); margin-bottom: 12px; font-size: 1.25rem;">Chào mừng bạn đến với trợ lý học tập</h3>
                    <p style="color: var(--muted); max-width: 400px; line-height: 1.6; font-size: 0.95rem;">Hãy chọn một môn học, tải tài liệu lên, sau đó bắt đầu cuộc trò chuyện để trao đổi dựa trên tài liệu của bạn.</p>
                </div>
            }
        </div>

        @if (Model.SelectedDataset?.IsArchived == true)
        {
            <div class="alert alert-warning" role="status">Môn học đã được lưu trữ. Bạn có thể xem lịch sử và nguồn trích dẫn nhưng không thể tạo phiên hoặc gửi câu hỏi mới.</div>
        }
        else if (Model.SelectedSessionId.HasValue)
        {
            <form method="post" asp-page-handler="SendMessage" class="composer">
                @Html.AntiForgeryToken()
                <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                <input type="hidden" name="sessionId" value="@Model.SelectedSessionId" />
                <textarea name="question" rows="1" placeholder="Hỏi về môn học này..." required id="chatQuestionTextarea" aria-label="Câu hỏi"></textarea>
                <button type="submit" class="composer-send-btn">Gửi</button>
            </form>
        }
    </main>

    <!-- Cá»™t 3: Hiá»ƒn thá»‹ trÃ­ch dáº«n tÃ i liá»‡u tham chiáº¿u (Reference Panel) -->
    <aside class="workspace-panel reference-panel" aria-label="Tài liệu tham khảo">
        <div class="panel-header">
            <div>
                <p class="eyebrow">TÀI LIỆU THAM KHẢO</p>
                <h2>Nguồn trích dẫn</h2>
            </div>
            <button type="button" class="reference-close-btn" aria-label="Đóng nguồn trích dẫn" title="Đóng nguồn trích dẫn" data-close-references>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        @if (Model.SelectedMessageId.HasValue && Model.Citations.Count > 0)
        {
            <div class="reference-content">
                @foreach (var c in Model.Citations)
                {
                    <div class="reference-card">
                        <h3 title="@c.FileName">@c.FileName</h3>
                        @if (string.Equals(c.FileType, "pdf", StringComparison.OrdinalIgnoreCase))
                        {
                            <p><strong>Trang:</strong> @(c.PageNumber > 0 ? c.PageNumber.ToString() : "Không xác định")</p>
                        }
                        else
                        {
                            <p><strong>Đoạn:</strong> @(c.ChunkIndex?.ToString() ?? "Không xác định")</p>
                        }
                        <p><strong>Nhãn nguồn:</strong> @c.SourceLabel</p>
                        <p style="margin-top: 6px; font-style: italic; background: var(--surface-muted); padding: 8px; border-radius: 6px; border-left: 3px solid var(--accent);">
                            "@c.QuoteText"
                        </p>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="reference-empty">
                <h3>Chưa chọn nguồn trích dẫn</h3>
                <p>Khi câu trả lời có nguồn trích dẫn, hãy chọn một nguồn để xem đoạn nội dung và tên tài liệu.</p>
            </div>
        }
    </aside>

    <!-- Document Chunk Preview Modal -->
    <div id="docPreviewModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); align-items: center; justify-content: center; padding: 20px;">
        <div class="modal-content" style="background: var(--surface); border-radius: 12px; max-width: 800px; width: 100%; max-height: 85%; display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.2); border: 1px solid var(--line);">
            <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; padding: 16px 24px; border-bottom: 1px solid var(--line); background: var(--surface-muted);">
                <div>
                    <span style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); font-weight: 700; display: block; margin-bottom: 2px;">XEM TRƯỚC TÀI LIỆU</span>
                    <h3 id="docPreviewTitle" style="margin: 0; font-size: 1.15rem; font-weight: 600; color: var(--ink);">Tài liệu môn học</h3>
                </div>
                <button type="button" onclick="closeDocPreviewModal()" style="background: none; border: none; font-size: 1.75rem; color: var(--muted); cursor: pointer; padding: 0; line-height: 1; transition: color 0.2s;" onmouseover="this.style.color='var(--ink)'" onmouseout="this.style.color='var(--muted)'">&times;</button>
            </div>
            <div id="docPreviewBody" style="padding: 24px; overflow-y: auto; flex: 1; display: flex; flex-direction: column; gap: 16px; background: var(--surface);">
                <!-- Chunks will be dynamically populated here -->
            </div>
        </div>
    </div>
</section>
}

@section Scripts {
    <style>
        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .upload-dropzone {
            position: relative;
            display: flex;
            flex-direction: column;
