                padding: 12px;
            }

            body:has(.workspace) .workspace {
                width: 100%;
                grid-template-columns: minmax(0, 1fr) !important;
            }

            body:has(.workspace) .chat-panel {
                width: 100% !important;
            }

            .question-suggestions-header {
                align-items: flex-start;
                flex-direction: column;
            }

