            border-bottom: 1px solid rgba(37, 99, 235, 0.12);
        }

        .reference-card h3 {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .message.pending-message .message-bubble,
        .message.loading-bubble .message-bubble {
            border: 1px solid rgba(37, 99, 235, 0.2);
            background: rgba(37, 99, 235, 0.045);
        }

        .message.failed-message .message-bubble {
            border: 1px solid rgba(180, 122, 32, 0.3);
            background: rgba(245, 158, 11, 0.09);
