@page
@model RagChatbotSystem.Presentation.Pages.IndexModel
@{
    var defaultMobileTab = Model.SelectedMessageId.HasValue ? "reference-panel" : "chat-panel";
}

<section class="workspace" data-rag-app data-active-tab="@defaultMobileTab" data-selected-dataset-id="@Model.SelectedDatasetId" data-selected-session-id="@Model.SelectedSessionId">
    <!-- Mobile Navigation Tabs (Only visible on mobile screens) -->
    <div class="mobile-workspace-tabs" aria-label="Workspace navigation">
        <button class="mobile-tab-btn @(defaultMobileTab == "chat-panel" ? "active" : "")" data-target="chat-panel">&#128172; Chat</button>
        <button class="mobile-tab-btn @(defaultMobileTab == "management-panel" ? "active" : "")" data-target="management-panel">&#128218; Knowledge</button>
        <button class="mobile-tab-btn @(defaultMobileTab == "reference-panel" ? "active" : "")" data-target="reference-panel">
            &#128269; Sources @(Model.Citations.Count > 0 ? $"({Model.Citations.Count})" : "")
        </button>
    </div>

    <!-- Cá»™t 1: Báº£ng Ä‘iá»u khiá»ƒn quáº£n lÃ½ (Management) -->
    <aside class="workspace-panel management-panel" aria-label="Subject management">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Management</p>
                <h1>Knowledge workspace</h1>
            </div>
            <a class="icon-button" href="?datasetId=@Model.SelectedDatasetId&sessionId=@Model.SelectedSessionId" title="Refresh workspace" aria-label="Refresh workspace" style="text-decoration: none;">
                <span aria-hidden="true">&#8635;</span>
            </a>
        </div>

        <!-- ThÃ´ng bÃ¡o lá»—i hoáº·c thÃ nh cÃ´ng -->
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" style="background: rgba(180, 35, 24, 0.1); border: 1px solid rgba(180, 35, 24, 0.2); padding: 0.75rem; border-radius: 8px; color: var(--danger); margin-bottom: 1rem; font-size: 0.84rem; font-weight: 500;">
                @Model.ErrorMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success" style="background: rgba(15, 118, 110, 0.1); border: 1px solid rgba(15, 118, 110, 0.2); padding: 0.75rem; border-radius: 8px; color: var(--accent-strong); margin-bottom: 1rem; font-size: 0.84rem; font-weight: 500;">
                @Model.SuccessMessage
            </div>
        }

        <!-- ThÃ´ng tin ngÆ°á»i dÃ¹ng Ä‘Äƒng nháº­p -->
        <div style="border-bottom: 1px solid var(--line); padding-bottom: 12px; margin-bottom: 16px;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 1.2rem;">&#128100;</span>
                <div>
                    <div class="fw-bold" style="color: var(--ink); font-size: 0.95rem;">@Model.SelectedUser?.FullName</div>
                    <div class="text-muted small text-uppercase" style="font-size: 0.75rem; font-weight: bold; color: var(--accent-strong);">Role: @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                </div>
            </div>
        </div>

        <!-- Quáº£n lÃ½ Datasets -->
        <div class="section-block">
            <div class="section-title">
                <h2>Subjects</h2>
                <span data-dataset-count>@Model.Datasets.Count</span>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <form method="post" asp-page-handler="CreateDataset" class="create-form">
                    @Html.AntiForgeryToken()
                    <input name="name" type="text" placeholder="Subject name" required />
                    <textarea name="description" rows="2" placeholder="Short description"></textarea>
                    
                    <div style="display: flex; align-items: center; gap: 6px; margin: 8px 0;">
                        <input type="checkbox" name="isPublic" id="isPublic" value="true" checked style="width: auto; height: auto;" />
                        <label for="isPublic" style="font-size: 0.85rem; color: var(--muted); cursor: pointer; margin: 0;">Public Subject</label>
                    </div>

                    <button type="submit">Create subject</button>
                </form>
            }

            <div class="dataset-list" aria-live="polite" data-dataset-list>
                @if (Model.Datasets.Count == 0)
                {
                    <p class="helper-text">No subjects yet.</p>
                }
                @foreach (var ds in Model.Datasets)
                {
                    <div class="dataset-entry" data-dataset-id="@ds.DatasetId">
                        <a class="dataset-item @(Model.SelectedDatasetId == ds.DatasetId ? "active" : "")" 
                           href="?datasetId=@ds.DatasetId">
                            <span class="dataset-name">
                                @if (!ds.IsApproved)
                                {
                                    <span title="Pending approval" style="color: var(--warning);">&#9203;</span>
                                }
                                @ds.Name
                                @if (!ds.IsPublic)
                                {
                                    <span title="Private subject" style="font-size: 0.8rem; color: var(--muted);">&#128274;</span>
                                }
                            </span>
                            <span class="dataset-meta">@ds.DocumentCount document(s)</span>
                        </a>

                        @if (User.IsInRole("Admin") || ds.CreatedBy == Model.SelectedUserId)
                        {
                            <!-- Subject delete action -->
                            <form method="post" asp-page-handler="DeleteDataset" class="dataset-entry-action" onsubmit="return confirm('Delete this subject and all documents inside it?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@ds.DatasetId" />
                                <button type="submit" class="dataset-entry-delete" title="Delete subject">Delete</button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Quáº£n lÃ½ TÃ i liá»‡u (Documents) -->
        <div class="section-block">
            <div class="section-title">
                <h2>Documents</h2>
                <span>@Model.Documents.Count</span>
            </div>
            @if (Model.SelectedDatasetId.HasValue)
            {
                @if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
                {
                    <form method="post" asp-page-handler="Upload" enctype="multipart/form-data" class="upload-form" id="upload-doc-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                        <div id="upload-dropzone" style="position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 2px dashed var(--line); border-radius: 12px; padding: 22px 16px; background: var(--surface-muted); text-align: center; cursor: pointer; transition: all 0.2s;" onclick="if(!this.dataset.uploading) document.getElementById('file-upload').click();" onmouseover="this.style.borderColor='var(--accent)';" onmouseout="this.style.borderColor='var(--line)';">
                            <div id="upload-idle-state" style="display: flex; flex-direction: column; align-items: center;">
                                <span style="font-size: 1.8rem; margin-bottom: 6px;">&#128228;</span>
                                <span style="font-weight: 700; font-size: 0.9rem; color: var(--ink);">Upload documents for RAG</span>
                                <span style="font-size: 0.75rem; color: var(--muted); margin-top: 4px;">PDF, TXT, MD, or DOCX files supported</span>
                            </div>
                            <div id="upload-loading-state" style="display: none; flex-direction: column; align-items: center; justify-content: center; padding: 10px 0;">
                                <span style="display: inline-block; font-size: 1.8rem; margin-bottom: 6px; animation: spin 1s linear infinite;">&#9203;</span>
                                <span style="font-weight: 700; font-size: 0.9rem; color: var(--accent);">Uploading &amp; Processing...</span>
                                <span style="font-size: 0.75rem; color: var(--muted); margin-top: 4px;">Please wait while we extract text, chunk and index embeddings.</span>
                            </div>
                            <input id="file-upload" name="file" type="file" required style="display: none;" onchange="triggerUpload();" />
                        </div>
                    </form>
                }
                
                <div class="document-list" aria-live="polite" data-document-list>
                    @if (Model.Documents.Count == 0)
                    {
                        <p class="helper-text">No documents in this subject. Supported files: TXT, PDF, DOCX.</p>
                    }
                    @foreach (var doc in Model.Documents)
                    {
                        <div class="document-item" data-document-id="@doc.DocumentId">
                            <div class="document-card-header">
                                <div class="document-card-main">
                                    <strong class="document-name" title="@doc.FileName">@doc.FileName</strong>
                                    <span class="document-meta">@doc.FileType.ToUpper() - @Math.Ceiling(doc.FileSize / 1024.0) KB</span>
                                </div>
                            </div>
                            @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                            {
                                <div class="progress-track" aria-hidden="true">
                                    <span class="progress-fill" data-document-progress style="width: @(doc.Status.Equals("Processing", StringComparison.OrdinalIgnoreCase) ? "55%" : "100%")"></span>
                                </div>
                                <div class="document-actions-row">
                                    <span class="status-pill @doc.Status.ToLower()" data-document-status>@doc.Status</span>
                                    <a class="document-preview-link" asp-page="/Documents/Preview" asp-route-documentId="@doc.DocumentId" title="View indexed chunks and metadata">Preview chunks</a>
                                    <form method="post" asp-page-handler="DeleteDocument" style="margin: 0; padding: 0;" onsubmit="return confirm('Are you sure you want to delete this document?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                                        <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                        <button class="document-delete-button" type="submit" title="Delete document">Delete</button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="helper-text">Select a subject to view documents.</p>
            }
        </div>

        <!-- Quáº£n lÃ½ Chat Sessions -->
        <div class="section-block">
            <div class="section-title">
                <h2>Chat sessions</h2>
                <span>@Model.Sessions.Count</span>
            </div>
            <p class="helper-text">A subject can have many conversations. Select one or start a fresh session.</p>
            @if (Model.SelectedDatasetId.HasValue)
            {
                <form method="post" asp-page-handler="CreateSession" class="create-form" style="margin-bottom: 6px;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                    <div class="input-row">
                        <input name="title" type="text" placeholder="Session title (optional)" />
                        <button type="submit">New</button>
                    </div>
                </form>
                <div class="session-list" aria-live="polite" data-session-list>
                    @if (Model.Sessions.Count == 0)
                    {
                        <p class="helper-text">No sessions yet.</p>
                    }
                    @foreach (var ss in Model.Sessions)
                    {
                        <a class="session-item @(Model.SelectedSessionId == ss.SessionId ? "active" : "")" 
                           data-session-id="@ss.SessionId"
                           href="?datasetId=@Model.SelectedDatasetId&sessionId=@ss.SessionId"
                           style="text-decoration: none;">
                            <span class="session-name">@ss.Title</span>
                            <span class="session-meta">Updated @RagChatbotSystem.Presentation.Helpers.VietnamTime.Format(ss.UpdatedAt, "HH:mm dd/MM")</span>
                        </a>
                    }
                </div>
            }
        </div>

        <!-- Statistics -->
        <div class="section-block mt-4 pt-3" style="border-top: 1px solid var(--line);">
            <div class="section-title mb-2">
                <h2 style="font-size: 1rem; font-weight: 700; color: var(--ink);">Statistics</h2>
            </div>
            <div class="d-flex flex-column gap-2" style="font-size: 0.85rem;">
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Total Documents</span>
                    <strong style="color: var(--accent); font-weight: 700;">@Model.Documents.Count</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Chat Sessions</span>
                    <strong style="color: #8b5cf6; font-weight: 700;">@Model.Sessions.Count</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Messages In Session</span>
                    <strong style="color: #10b981; font-weight: 700;">@Model.MessageHistory.Count</strong>
                </div>
            </div>
        </div>
    </aside>

    <!-- Cá»™t 2: Giao diá»‡n Há»™i thoáº¡i (Chat Panel) -->
    <main class="chat-panel" aria-label="Chat interface">
        <div class="chat-header">
            <div>
                <p class="eyebrow">Chat</p>
                @if (Model.SelectedSession != null)
                {
                    <h2 data-chat-title>@Model.SelectedSession.Title</h2>
                }
                else if (Model.SelectedDataset != null)
                {
                    <h2 data-chat-title>Select or create a chat session</h2>
                }
                else
                {
                    <h2 data-chat-title>Select a subject to start</h2>
                }
            </div>
            @if (Model.SelectedDatasetId.HasValue)
            {
                <form method="post" asp-page-handler="CreateSession" style="margin: 0; padding: 0;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                    <input type="hidden" name="title" value="Subject chat" />
                    <button class="secondary-button" type="submit">New session</button>
                </form>
            }
        </div>

        <div class="chat-stream" aria-live="polite" id="chatStream">
            @if (Model.SelectedSession != null)
            {
                if (Model.MessageHistory.Count == 0)
                {
                    <div class="empty-state">
                        <h3>Ask questions grounded in your uploaded documents.</h3>
                        <p>Type your message below. The AI will retrieve the most relevant sections of your documents to provide answers.</p>
                    </div>
                }
                else
                {
                    @foreach (var msg in Model.MessageHistory)
                    {
                        <div class="message @msg.Role.ToLower()" data-message-id="@msg.MessageId">
                            <div class="message-bubble">
                                <p style="margin: 0; white-space: pre-wrap;">@msg.Content</p>
                            </div>
                            <div class="message-meta">
                                @(msg.Role == "User" ? "You" : "Assistant") &bull; @RagChatbotSystem.Presentation.Helpers.VietnamTime.Format(msg.CreatedAt, "HH:mm")
                            </div>
                            @if (msg.Role == "Assistant")
                            {
                                <div class="citation-row" style="margin-top: 8px;">
                                    <button class="citation-chip view-sources-btn" 
                                       data-message-id="@msg.MessageId"
                                       style="background: none; border: none; font: inherit; text-decoration: none; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 4px;">
                                        &#128269; View Sources
                                    </button>
                                </div>
                            }
                        </div>
                    }
                }
            }
            else
            {
                <div class="empty-state">
                    <h3>Ask questions grounded in your uploaded documents.</h3>
                    <p>Create or select a subject, upload a document, then start a chat session.</p>
                </div>
            }
        </div>

        @if (Model.SelectedSessionId.HasValue)
        {
            <form method="post" asp-page-handler="SendMessage" class="composer">
                @Html.AntiForgeryToken()
                <input type="hidden" name="datasetId" value="@Model.SelectedDatasetId" />
                <input type="hidden" name="sessionId" value="@Model.SelectedSessionId" />
                <textarea name="question" rows="1" placeholder="Ask about this subject..." required id="chatQuestionTextarea"></textarea>
                <button type="submit">Send</button>
            </form>
        }
    </main>

    <!-- Cá»™t 3: Hiá»ƒn thá»‹ trÃ­ch dáº«n tÃ i liá»‡u tham chiáº¿u (Reference Panel) -->
    <aside class="workspace-panel reference-panel" aria-label="Citation references">
        <div class="panel-header">
            <div>
                <p class="eyebrow">References</p>
                <h2>Sources</h2>
            </div>
        </div>

        @if (Model.SelectedMessageId.HasValue && Model.Citations.Count > 0)
        {
            <div class="reference-content">
                @foreach (var c in Model.Citations)
                {
                    <div class="reference-card">
                        <h3 title="@c.FileName">@c.FileName</h3>
                        <p><strong>Page:</strong> @(c.PageNumber > 0 ? c.PageNumber.ToString() : "1")</p>
                        <p><strong>Source label:</strong> @c.SourceLabel</p>
                        <p style="margin-top: 6px; font-style: italic; background: var(--surface-muted); padding: 8px; border-radius: 6px; border-left: 3px solid var(--accent);">
                            "@c.QuoteText"
                        </p>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="reference-empty">
                <h3>No citation selected</h3>
                <p>When an AI answer includes sources, select a reference to inspect the chunk and file name.</p>
            </div>
        }
    </aside>
</section>

<div id="documentProcessingOverlay" style="display:none; position: fixed; inset: 0; z-index: 9999; background: rgba(3, 7, 18, 0.76); backdrop-filter: blur(6px); align-items: center; justify-content: center;">
    <div style="background: var(--surface); border: 1px solid var(--line); border-radius: 14px; padding: 28px; width: min(420px, calc(100vw - 32px)); text-align: center; box-shadow: var(--shadow);">
        <div style="width: 46px; height: 46px; margin: 0 auto 16px; border: 4px solid rgba(255,255,255,0.16); border-top-color: var(--accent-strong); border-radius: 50%; animation: spin 0.9s linear infinite;"></div>
        <h3 style="margin: 0 0 8px; color: var(--ink);">Processing document...</h3>
        <p style="margin: 0; color: var(--muted); font-size: 0.92rem;">AI is extracting text, splitting chunks, and indexing this file. Please keep this page open.</p>
    </div>
</div>

@section Scripts {
    <style>
        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .upload-dropzone {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 6px;
            min-height: 112px;
            border: 2px dashed var(--line);
            border-radius: 12px;
            padding: 18px 12px;
            background: var(--surface-muted);
            text-align: center;
            cursor: pointer;
            transition: border-color 0.2s, background 0.2s;
            overflow: hidden;
        }

        .upload-dropzone:hover {
            border-color: var(--accent);
            background: rgba(37, 99, 235, 0.04);
        }

        .upload-title,
        .upload-subtitle {
            display: block;
            max-width: 100%;
            overflow-wrap: anywhere;
            line-height: 1.25;
        }

        .upload-title {
            font-weight: 800;
            font-size: 0.9rem;
            color: var(--ink);
        }

        .upload-subtitle {
            font-size: 0.74rem;
            color: var(--muted);
        }

        .document-card-header,
        .document-card-main {
            min-width: 0;
            width: 100%;
        }

        .document-name {
            display: block;
            max-width: 100%;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .document-actions-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 8px;
            margin-top: 8px;
        }

        .document-preview-link,
        .document-delete-button {
            border-radius: 6px;
            font-size: 0.76rem;
            font-weight: 700;
            padding: 5px 8px;
            line-height: 1;
            text-decoration: none;
        }

        .document-preview-link {
            border: 1px solid rgba(14, 165, 233, 0.28);
            background: rgba(14, 165, 233, 0.08);
            color: var(--accent-strong);
        }

        .document-delete-button {
            border: 1px solid rgba(220, 38, 38, 0.25);
            background: rgba(220, 38, 38, 0.05);
            color: var(--danger);
            cursor: pointer;
        }
    </style>
    <script>
        // Tá»± Ä‘á»™ng cuá»™n khung chat xuá»‘ng dÆ°á»›i cÃ¹ng khi cÃ³ tin nháº¯n má»›i hoáº·c táº£i trang
        const chatStream = document.getElementById("chatStream");
        if (chatStream) {
            chatStream.scrollTop = chatStream.scrollHeight;
        }

        const uploadDocForm = document.getElementById("upload-doc-form");
        const fileUploadInput = document.getElementById("file-upload");
        const processingOverlay = document.getElementById("documentProcessingOverlay");
        if (uploadDocForm && processingOverlay) {
            uploadDocForm.addEventListener("submit", function () {
                processingOverlay.style.display = "flex";
            });
        }
        function escapeHtml(str) {
            if (!str) return "";
            return str
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        // Há»— trá»£ gá»­i tin nháº¯n báº±ng tá»• há»£p phÃ­m Enter (nhÆ°ng cho phÃ©p Shift+Enter Ä‘á»ƒ xuá»‘ng dÃ²ng)
        const textarea = document.getElementById("chatQuestionTextarea");
        if (textarea) {
            textarea.addEventListener("keydown", function(e) {
                if (e.key === "Enter" && !e.shiftKey) {
                    e.preventDefault();
                    // KÃ­ch hoáº¡t submit form Ä‘Æ°á»£c xá»­ lÃ½ báº±ng AJAX á»Ÿ dÆ°á»›i
                    this.form.dispatchEvent(new Event("submit", { cancelable: true }));
                }
            });
        }

        // Xá»­ lÃ½ gá»­i tin nháº¯n báº±ng AJAX (KhÃ´ng táº£i láº¡i trang)
        const composerForm = document.querySelector(".composer");
        if (composerForm) {
            composerForm.addEventListener("submit", function(e) {
                e.preventDefault();
                
                const questionInput = document.getElementById("chatQuestionTextarea");
                if (!questionInput) return;
                const question = questionInput.value.trim();
                if (!question) return;
                
                // Clear vÃ  reset textarea ngay láº­p tá»©c
                questionInput.value = "";
                questionInput.style.height = "auto";
                
                // 1. Hiá»ƒn thá»‹ tin nháº¯n cá»§a User ngay láº­p tá»©c lÃªn mÃ n hÃ¬nh
                appendMessage("user", question, formatVietnamTime(new Date()));
                
                // 2. ThÃªm bong bÃ³ng chá» tráº£ lá»i (Loading) tá»« Assistant
                const loadingBubble = appendLoadingBubble();
                
                // Cuá»™n xuá»‘ng cuá»‘i
                if (chatStream) {
                    chatStream.scrollTop = chatStream.scrollHeight;
                }
                
                // 3. Gá»­i yÃªu cáº§u qua Fetch API tá»›i Backend
                const formData = new FormData(composerForm);
                formData.set("question", question);
                composerForm.dataset.realtimeSuppress = "true";
                
                fetch("?handler=SendMessageAjax", {
                    method: "POST",
                    body: formData
                })
                .then(response => {
                    if (!response.ok) {
                        return response.json().then(data => { throw new Error(data.error || "Gửi tin nhắn thất bại.") });
                    }
                    return response.json();
                })
                .then(data => {
                    // XÃ³a bong bÃ³ng loading
                    if (loadingBubble) loadingBubble.remove();
                    
                    // ThÃªm cÃ¢u tráº£ lá»i cá»§a AI vÃ o giao diá»‡n
                    appendMessage("assistant", data.assistantMessage.content, data.assistantMessage.createdAt, data.assistantMessage.messageId);
                    
                    // Hiá»ƒn thá»‹ ngay cÃ¡c nguá»“n trÃ­ch dáº«n tÆ°Æ¡ng á»©ng bÃªn cá»™t pháº£i
                    if (data.citations && data.citations.length > 0) {
                        renderCitationsDirectly(data.citations);
                    }
                    
                    // Cuá»™n xuá»‘ng cuá»‘i
                    if (chatStream) {
                        chatStream.scrollTop = chatStream.scrollHeight;
                    }
                    setTimeout(function () { delete composerForm.dataset.realtimeSuppress; }, 750);
                })
                .catch(err => {
                    console.error(err);
                    if (loadingBubble) loadingBubble.remove();
                    
                    // Hiá»ƒn thá»‹ bong bÃ³ng lá»—i
                    appendMessage("assistant", `Lỗi: ${err.message}`, formatVietnamTime(new Date()));
                    
                    if (chatStream) {
                        chatStream.scrollTop = chatStream.scrollHeight;
                    }
                    delete composerForm.dataset.realtimeSuppress;
                });
            });
        }

        window.addEventListener("rag:document-progress", function (event) {
            const payload = event.detail;
            if (!payload) return;

            const workspaceEl = document.querySelector("[data-rag-app]");
            if (workspaceEl && workspaceEl.dataset.selectedDatasetId && payload.datasetId && workspaceEl.dataset.selectedDatasetId !== String(payload.datasetId)) {
                return;
            }

            const documentRow = document.querySelector(`[data-document-id="${payload.documentId}"]`);
            if (payload.action === "deleted") {
                if (documentRow) documentRow.remove();
                return;
            }

            if (!documentRow) {
                const list = document.querySelector("[data-document-list]");
                if (list && (payload.action === "completed" || payload.action === "uploaded" || payload.action === "processing")) {
                    const emptyState = list.querySelector(".helper-text");
                    if (emptyState) emptyState.remove();
                    list.prepend(createDocumentRow(payload));
                }
                return;
            }

            const status = documentRow.querySelector("[data-document-status]");
            if (status) {
                status.textContent = payload.status || payload.action || "Updated";
                status.className = `status-pill ${(payload.status || "").toLowerCase()}`;
            }

            const progress = documentRow.querySelector("[data-document-progress]");
            if (progress) {
                progress.style.width = `${Math.max(0, Math.min(100, payload.percentComplete || 0))}%`;
            }
        });

        function createDocumentRow(payload) {
            const item = document.createElement("div");
            item.className = "document-item";
            item.dataset.documentId = payload.documentId;
            const status = payload.status || "Uploaded";
            const sizeKb = Math.ceil((payload.fileSize || 0) / 1024);
            item.innerHTML = `
                <div class="document-card-header">
                    <div class="document-card-main">
                        <strong class="document-name" title="${escapeHtml(payload.fileName || "Document")}">${escapeHtml(payload.fileName || "Document")}</strong>
                        <span class="document-meta">${escapeHtml(String(payload.fileType || "")).toUpperCase()} - ${sizeKb} KB</span>
                    </div>
                </div>
                <div class="progress-track" aria-hidden="true">
                    <span class="progress-fill" data-document-progress style="width: ${Math.max(0, Math.min(100, payload.percentComplete || 0))}%"></span>
                </div>
                <div class="document-actions-row">
                    <span class="status-pill ${escapeHtml(status.toLowerCase())}" data-document-status>${escapeHtml(status)}</span>
                    <a class="document-preview-link" href="/Documents/Preview?documentId=${encodeURIComponent(payload.documentId)}" title="View indexed chunks and metadata">Preview chunks</a>
                    <form method="post" action="?handler=DeleteDocument" style="margin: 0; padding: 0;" onsubmit="return confirm('Are you sure you want to delete this document?');">
                        ${antiForgeryInput()}
                        <input type="hidden" name="datasetId" value="${escapeHtml(payload.datasetId)}" />
                        <input type="hidden" name="documentId" value="${escapeHtml(payload.documentId)}" />
                        <button class="document-delete-button" type="submit" title="Delete document">Delete</button>
                    </form>
                </div>
            `;
            return item;
        }

        function antiForgeryInput() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            return token ? `<input name="__RequestVerificationToken" type="hidden" value="${escapeHtml(token.value)}" />` : "";
        }

        window.addEventListener("rag:chat-session-changed", function (event) {
            const payload = event.detail;
            const workspaceEl = document.querySelector("[data-rag-app]");
            const sessionList = document.querySelector("[data-session-list]");
            if (!payload || !workspaceEl || !sessionList || workspaceEl.dataset.selectedDatasetId !== String(payload.datasetId)) {
                return;
            }

            if (sessionList.querySelector(`[data-session-id="${payload.sessionId}"]`)) {
                return;
            }

            const emptyState = sessionList.querySelector(".helper-text");
            if (emptyState) emptyState.remove();

            const link = document.createElement("a");
            link.className = "session-item";
            link.dataset.sessionId = payload.sessionId;
            link.href = `?datasetId=${encodeURIComponent(payload.datasetId)}&sessionId=${encodeURIComponent(payload.sessionId)}`;
            link.style.textDecoration = "none";
            link.innerHTML = `
                <span class="session-name">${escapeHtml(payload.title || "Subject chat")}</span>
                <span class="session-meta">Updated ${formatVietnamTime(new Date(payload.updatedAt || payload.changedAt))}</span>
            `;
            sessionList.prepend(link);
        });

        window.addEventListener("rag:chat-message-saved", function (event) {
            const payload = event.detail;
            const workspaceEl = document.querySelector("[data-rag-app]");
            if (!payload || !workspaceEl || workspaceEl.dataset.selectedSessionId !== String(payload.sessionId)) {
                return;
            }

            if (composerForm && composerForm.dataset.realtimeSuppress === "true") {
                return;
            }

            appendRealtimeMessage(payload.userMessage);
            appendRealtimeMessage(payload.assistantMessage);

            if (payload.citations && payload.citations.length > 0) {
                renderCitationsDirectly(payload.citations);
            }

            if (chatStream) {
                chatStream.scrollTop = chatStream.scrollHeight;
            }
        });

        function appendMessage(role, content, time, messageId = null) {
            if (messageId && document.querySelector(`[data-message-id="${messageId}"]`)) {
                return document.querySelector(`[data-message-id="${messageId}"]`);
            }

            const emptyState = chatStream.querySelector(".empty-state");
            if (emptyState) emptyState.remove();

            const messageDiv = document.createElement("div");
            messageDiv.className = `message ${role}`;
            if (messageId) {
                messageDiv.dataset.messageId = messageId;
            }
            
            let citationHtml = "";
            if (role === "assistant" && messageId) {
                citationHtml = `
                    <div class="citation-row" style="margin-top: 8px;">
                        <button class="citation-chip view-sources-btn" 
                                data-message-id="${messageId}"
                                style="background: none; border: none; font: inherit; text-decoration: none; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 4px;">
                            &#128269; View Sources
                        </button>
                    </div>
                `;
            }

            messageDiv.innerHTML = `
                <div class="message-bubble">
                    <p style="margin: 0; white-space: pre-wrap;">${escapeHtml(content)}</p>
                </div>
                <div class="message-meta">
                    ${role === "user" ? "You" : "Assistant"} &bull; ${time}
                </div>
                ${citationHtml}
            `;
            chatStream.appendChild(messageDiv);
            return messageDiv;
        }

        function appendRealtimeMessage(message) {
            if (!message) return;

            const role = String(message.role || "").toLowerCase();
            appendMessage(
                role === "assistant" ? "assistant" : "user",
                message.content || "",
                formatVietnamTime(new Date(message.createdAt)),
                message.messageId
            );
        }

        function formatVietnamTime(value) {
            return new Intl.DateTimeFormat("vi-VN", {
                timeZone: "Asia/Ho_Chi_Minh",
                hour: "2-digit",
                minute: "2-digit",
                hour12: false
            }).format(value);
        }

        function appendLoadingBubble() {
            const emptyState = chatStream.querySelector(".empty-state");
            if (emptyState) emptyState.remove();

            const loadingDiv = document.createElement("div");
            loadingDiv.className = "message assistant loading-bubble";
            loadingDiv.innerHTML = `
                <div class="message-bubble" style="display: flex; align-items: center; gap: 8px;">
                    <span style="display: inline-block; animation: spin 1s linear infinite;">&#9203;</span>
                    <span style="font-style: italic; color: var(--muted);">Searching knowledge base and thinking...</span>
                </div>
                <div class="message-meta">
                    Assistant &bull; Loading
                </div>
            `;
            chatStream.appendChild(loadingDiv);
            return loadingDiv;
        }

        // Láº¯ng nghe sá»± kiá»‡n click vÃ o nÃºt xem trÃ­ch dáº«n (Event Delegation Ä‘á»ƒ há»— trá»£ cáº£ tin nháº¯n má»›i)
        document.addEventListener("click", function(e) {
            const btn = e.target.closest(".view-sources-btn");
            if (btn) {
                e.preventDefault();
                const messageId = btn.getAttribute("data-message-id");
                fetchCitations(messageId);
            }
        });

        function fetchCitations(messageId) {
            const referencePanel = document.querySelector(".reference-panel");
            if (!referencePanel) return;

            // Render giao diá»‡n chá» táº£i trÃ­ch dáº«n bÃªn cá»™t pháº£i
            referencePanel.innerHTML = `
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">References</p>
                        <h2>Sources</h2>
                    </div>
                </div>
                <div style="padding: 24px; text-align: center; color: var(--muted);">
                    <span style="display: inline-block; font-size: 1.5rem; margin-bottom: 8px; animation: spin 1.2s linear infinite;">&#9203;</span>
                    <p style="font-size: 0.85rem; margin: 0;">Retrieving source documents...</p>
                </div>
            `;

            // Tá»± Ä‘á»™ng chuyá»ƒn tab trÃªn Mobile sang tab "Sources"
            const workspace = document.querySelector(".workspace");
            if (workspace && window.innerWidth <= 820) {
                workspace.setAttribute("data-active-tab", "reference-panel");
                const refTabBtn = document.querySelector('.mobile-tab-btn[data-target="reference-panel"]');
                if (refTabBtn) {
                    document.querySelectorAll(".mobile-tab-btn").forEach(b => b.classList.remove("active"));
                    refTabBtn.classList.add("active");
                }
            }

            // Gá»i API láº¥y thÃ´ng tin trÃ­ch dáº«n
            fetch(`?handler=GetCitations&messageId=${messageId}`)
                .then(response => {
                    if (!response.ok) throw new Error("Failed to load citations");
                    return response.json();
                })
                .then(citations => {
                    renderCitationsDirectly(citations);
                })
                .catch(err => {
                    console.error(err);
                    referencePanel.innerHTML = `
                        <div class="panel-header">
                            <div>
                                <p class="eyebrow">References</p>
                                <h2>Sources</h2>
                            </div>
                        </div>
                        <div style="padding: 24px; text-align: center; color: var(--danger);">
                            <p style="font-size: 0.85rem; margin: 0;">Error loading sources: ${err.message}</p>
                        </div>
                    `;
                });
        }

        function renderCitationsDirectly(citations) {
            const referencePanel = document.querySelector(".reference-panel");
            if (!referencePanel) return;

            let html = `
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">References</p>
                        <h2>Sources</h2>
                    </div>
                </div>
            `;

            if (!citations || citations.length === 0) {
                html += `
                    <div class="reference-empty">
                        <h3>No citations found</h3>
                        <p>No specific chunks were retrieved for this response.</p>
                    </div>
                `;
            } else {
                html += `<div class="reference-content">`;
                citations.forEach(c => {
                    html += `
                        <div class="reference-card">
                            <h3 title="${escapeHtml(c.fileName)}">${escapeHtml(c.fileName)}</h3>
                            <p><strong>Page:</strong> ${c.pageNumber > 0 ? c.pageNumber : 1}</p>
                            <p><strong>Source label:</strong> ${escapeHtml(c.sourceLabel || "N/A")}</p>
                            <p style="margin-top: 6px; font-style: italic; background: var(--surface-muted); padding: 8px; border-radius: 6px; border-left: 3px solid var(--accent);">
                                "${escapeHtml(c.quoteText)}"
                            </p>
                        </div>
                    `;
                });
                html += `</div>`;
            }
            referencePanel.innerHTML = html;
        }

        // Logic chuyá»ƒn Ä‘á»•i Tab trÃªn thiáº¿t bá»‹ di Ä‘á»™ng
        const tabBtns = document.querySelectorAll(".mobile-tab-btn");
        const workspace = document.querySelector(".workspace");
        if (tabBtns && workspace) {
            tabBtns.forEach(btn => {
                btn.addEventListener("click", () => {
                    tabBtns.forEach(b => b.classList.remove("active"));
                    btn.classList.add("active");
                    const target = btn.getAttribute("data-target");
                    workspace.setAttribute("data-active-tab", target);
                });
            });
        }

        function triggerUpload() {
            const fileInput = document.getElementById('file-upload');
            const uploadForm = document.getElementById('upload-doc-form');
            if (!fileInput || !uploadForm || uploadForm.dataset.submitting === "true") {
                return;
            }

            if (fileInput && fileInput.files && fileInput.files.length > 0) {
                const file = fileInput.files[0];
                const maxSize = 50 * 1024 * 1024; // 50MB
                if (file.size > maxSize) {
                    alert('Kích thước tệp vượt quá giới hạn cho phép (tối đa 50MB). Vui lòng chọn tệp nhỏ hơn.');
                    fileInput.value = ""; // Reset
                    return;
                }
            } else {
                return;
            }

            const dropzone = document.getElementById('upload-dropzone');
            const idleState = document.getElementById('upload-idle-state');
            const loadingState = document.getElementById('upload-loading-state');

            uploadForm.dataset.submitting = "true";
            if (dropzone) {
                dropzone.dataset.uploading = "true";
                dropzone.style.cursor = "not-allowed";
                dropzone.style.borderColor = "var(--accent)";
            }
            if (idleState) idleState.style.display = "none";
            if (loadingState) loadingState.style.display = "flex";
            if (processingOverlay) processingOverlay.style.display = "flex";

            uploadForm.requestSubmit();
        }

    </script>
}
